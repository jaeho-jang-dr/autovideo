  function speakKo(text: string) {
    // 낱자 기호가 입력된 경우 맵핑 테이블을 통해 한글 명칭 파일명으로 변환
    const filename = JAMO_AUDIO_MAP[text] || text;
    
    // 단일 글자(음절)인 경우, 단독 발음 끝소리 대표음화 적용
    let processedFilename = filename;
    if (text.length === 1 && !JAMO_AUDIO_MAP[text] && text !== '•' && text !== '—') {
      processedFilename = getPronunciationOfSyllable(text);
    }

    const audioUrl = `/audio/jamo/${encodeURIComponent(processedFilename)}.mp3`;
    const audio = new Audio(audioUrl);
    
    audio.volume = 0.85;
    
    let fallbackTriggered = false;
    
    // 비동기 gTTS 생성 및 즉시 재생 함수
    const requestTtsGenerationAndPlay = async (targetText: string) => {
      try {
        const response = await fetch('/api/generate-tts', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ text: targetText })
        });
        const result = await response.json();
        if (result.success) {
          DYNAMIC_AUDIO_CACHE.add(targetText);
          console.log(`[Sori Hangeul] Successfully generated dynamic gTTS for: [${targetText}]`);
          // 생성 완료 후 깨끗한 성우 음원으로 재로드 및 재생
          const newAudio = new Audio(audioUrl);
          newAudio.volume = 0.85;
          newAudio.play().catch(e => console.warn("Failed to play dynamically generated jamo:", e));
        }
      } catch (e) {
        console.error(`Failed to request dynamic TTS generation for: [${targetText}]`, e);
      }
    };
    
    audio.addEventListener('error', () => {
      if (fallbackTriggered) return;
      fallbackTriggered = true;
      
      // 로컬 파일이 없으므로 백엔드에 즉시 동적 생성 및 재생 요청
      requestTtsGenerationAndPlay(processedFilename);
    });
    
    audio.play().catch(err => {
      if (fallbackTriggered) return;
      fallbackTriggered = true;
      console.warn("Audio play failed, requesting dynamic generation:", err);
      requestTtsGenerationAndPlay(processedFilename);
    });
  }

