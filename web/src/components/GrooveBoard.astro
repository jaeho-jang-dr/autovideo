  // 한글 1글자에 대해 끝소리 대표음화 발음 치환을 수행하는 헬퍼 함수 (단음절 단독 읽기 전용)
  function getPronunciationOfSyllable(char: string): string {
    if (!char || char.length !== 1) return char;
    const code = char.charCodeAt(0);
    // 한글 음절 범위가 아니면 그대로 반환
    if (code < 0xAC00 || code > 0xD7A3) return char;

    const offset = code - 0xAC00;
    const jongIdx = offset % 28;
    const jungIdx = Math.floor(offset / 28) % 21;
    const choIdx = Math.floor(Math.floor(offset / 28) / 21);

    const cho = CHO_LIST[choIdx];
    const jung = JUNG_LIST[jungIdx];
    const jong = JONG_LIST[jongIdx];

    // 종성(받침)이 없으면 변환 없이 그대로 반환
    if (!jong) return char;

    // 종성 대표음화 규칙 적용 (7종성: ㄱ, ㄴ, ㄷ, ㄹ, ㅁ, ㅂ, ㅇ)
    let phoneticJong = jong;
    if (['ㄲ', 'ㅋ', 'ㄳ', 'ㄺ'].includes(jong)) {
