    p.addEventListener('click', async (e) => {
      const btn = e.currentTarget as HTMLButtonElement;
      const jamo = btn.getAttribute('data-jamo') || '';
      const isCho = btn.classList.contains('cho');
      
      await ensureAudio();
      
      // 햅틱 효과 클래스 트리거
      btn.classList.add('hit');
