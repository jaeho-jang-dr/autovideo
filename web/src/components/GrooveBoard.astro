  // 천지인 입력 가능한 모든 유효 접두사 집합 생성
  const VALID_VOWEL_PREFIXES = new Set<string>();
  for (const key in VOWEL_COMBINATIONS) {
    for (let i = 1; i <= key.length; i++) {
      VALID_VOWEL_PREFIXES.add(key.slice(0, i));
    }
  }

  // 모음 상태 처리기 (원래 시퀀스 기반 오토마타 복구)
  function composeVowel(seq: string[]): string | null {
    const combined = seq.join('');
    
    // 1. 완벽히 매칭되는 모음이 있으면 그것을 반환
    if (VOWEL_COMBINATIONS[combined]) {
      return VOWEL_COMBINATIONS[combined];
    }
    
    // 2. 만약 현재 입력 시퀀스가 유효한 모음의 접두사 중 하나라면,
    // 매칭되는 도중이므로 임시로 빈 모음이나 이전 단계 모음을 유지
    if (VALID_VOWEL_PREFIXES.has(combined)) {
      // 최대한 매칭 가능한 이전 단계 모음이라도 찾아서 반환 (예: "•ㅡㅣ" 까지 쳤을 때 "ㅚ" 반환)
      for (let len = combined.length - 1; len > 0; len--) {
        const sub = combined.slice(0, len);
        if (VOWEL_COMBINATIONS[sub]) {
          return VOWEL_COMBINATIONS[sub];
        }
      }
      return null;
    }
    
    // 3. 만약 유효하지 않은 조합 시퀀스가 쌓였다면 안전하게 마지막 입력만 남김
    if (seq.length > 0) {
      const last = seq[seq.length - 1];
      state.jamoSeq = [last];
      return VOWEL_COMBINATIONS[last] || null;
    }
    
    return null;
  }

  // 조음 상형 팝업 제어
  let popupTimeout: number | null = null;
  function showAnatomy(jamo: string) {
    const popup = document.getElementById('articulatory-popup');
    const title = document.getElementById('anatomy-title');
    const desc = document.getElementById('anatomy-desc');
    const emoji = document.getElementById('anatomy-emoji');
    if (!popup || !title || !desc || !emoji) return;

    if (popupTimeout) {
      clearTimeout(popupTimeout);
    }

    const data = ANATOMY_MAP[jamo];
    if (data) {
      title.textContent = data.title;
      desc.textContent = data.desc;
      emoji.textContent = data.emoji;
      popup.classList.remove('hidden');

      popupTimeout = window.setTimeout(() => {
        popup.classList.add('hidden');
      }, 1200);
    } else {
      popup.classList.add('hidden');
    }
  }

