  // 패드 이벤트 바인딩
  const pads = document.querySelectorAll('.pad');
  pads.forEach(p => {
    p.addEventListener('click', async (e) => {
      const btn = e.currentTarget as HTMLButtonElement;
      const jamo = btn.getAttribute('data-jamo') || '';
      const isCho = btn.classList.contains('cho');
      
      try {
        await ensureAudio();
      } catch (err) {
        console.warn("AudioContext init failed, proceeding without sound:", err);
      }
      
      // 햅틱 효과 클래스 트리거
      btn.classList.add('hit');
      setTimeout(() => btn.classList.remove('hit'), 100);

      if (isCho) {
        // 자음 입력 및 순환 오토마타
        const cycle = CONSONANT_CYCLES[jamo];
        
        if (!state.jung) {
          // 초성(cho) 단계 순환
          if (state.lastPadType === 'cho' && state.lastPadValue === jamo) {
            state.cycleIdx = (state.cycleIdx + 1) % cycle.length;
            state.cho = cycle[state.cycleIdx];
          } else {
            state.cho = jamo;
            state.jamoSeq = [];
            state.jung = null;
            state.jong = null;
            state.lastPadType = 'cho';
            state.lastPadValue = jamo;
            state.cycleIdx = 0;
          }
        } else {
          // 종성(jong) 단계 순환 및 겹받침 합성
          if (state.lastPadType === 'jong' && state.lastPadValue === jamo) {
            state.cycleIdx = (state.cycleIdx + 1) % cycle.length;
            state.jong = cycle[state.cycleIdx];
          } else {
            // 이미 종성이 존재하고 복자음 합성이 가능한 경우
            if (state.jong && COMPLEX_JONG_MAP[state.jong + jamo]) {
              state.jong = COMPLEX_JONG_MAP[state.jong + jamo];
              state.lastPadType = 'jong';
              state.lastPadValue = jamo;
              state.cycleIdx = 0;
            } else {
              state.jong = jamo;
              state.lastPadType = 'jong';
              state.lastPadValue = jamo;
              state.cycleIdx = 0;
            }
          }
        }
        
        // 기계음 대신 성우 목소리로 명칭 재생
        const currentJamo = (!state.jung) ? state.cho! : state.jong!;
        speakKo(currentJamo);
        showAnatomy(jamo);
      } else {
        // 모음 입력
        if (state.cho && state.jong) {
          // 연음 법칙: 겹받침(복자음)이 있을 경우 마지막 자음만 초성으로 넘김
          const prevJong = state.jong;
          if (DECOMPOSE_JONG_MAP[prevJong]) {
            const [first, second] = DECOMPOSE_JONG_MAP[prevJong];
            state.word += String.fromCharCode(
              0xAC00 + (CHO_LIST.indexOf(state.cho) * 21 + JUNG_LIST.indexOf(state.jung!)) * 28 + JONG_LIST.indexOf(first)
            );
            state.cho = second; // 겹받침 중 두 번째 자음이 다음 글자의 초성으로 넘어감
          } else {
            const text = renderSyllable();
            if (text !== '—') {
              state.word += text;
            }
            state.cho = prevJong;
          }
          state.jamoSeq = [jamo];
          state.jung = composeVowel(state.jamoSeq);
          state.jong = null;
          state.lastPadType = 'jung';
          state.lastPadValue = jamo;
          state.cycleIdx = 0;
        } else if (state.cho) {
          state.jamoSeq.push(jamo);
          state.jung = composeVowel(state.jamoSeq);
          state.lastPadType = 'jung';
          state.lastPadValue = jamo;
        } else {
          state.cho = 'ㅇ';
          state.jamoSeq = [jamo];
          state.jung = composeVowel(state.jamoSeq);
          state.jong = null;
          state.lastPadType = 'jung';
          state.lastPadValue = jamo;
          state.cycleIdx = 0;
        }
        
        // 현재 구성된 모음 소리 성우 목소리로 재생
        if (state.jung) {
          speakKo(state.jung);
        }
      }

      updateDisplay();
      scheduleCommit();
    });
  });

  // 단어 입력 제어 버튼들 이벤트 바인딩
  const btnReset = document.getElementById('btn-reset');
  const btnBackspace = document.getElementById('btn-backspace');
  const btnSpace = document.getElementById('btn-space');
  const btnEnter = document.getElementById('btn-enter');
  const btnSpeakWord = document.getElementById('btn-speak-word');

  if (btnReset) {
    btnReset.addEventListener('click', () => {
      state.cho = null;
      state.jung = null;
      state.jong = null;
      state.jamoSeq = [];
      state.currentSyllable = '';
      state.word = '';
      state.english = ''; // 영어 클리어
      state.lastPadType = null;
      state.lastPadValue = null;
      state.cycleIdx = 0;
      
      const engInput = document.getElementById('input-english') as HTMLInputElement;
      if (engInput) engInput.value = ''; // 인풋 클리어
      
      updateDisplay();
      updateWordDisplay();
      
      const coachBubble = document.getElementById('coach-bubble');
      if (coachBubble) {
        coachBubble.textContent = "조립판이 초기화되었습니다. 패드를 눌러 새로운 단어를 만들어 보세요!";
      }
    });
  }

  // 단어 조립판 한꺼번에 지우기(×) 버튼
  const btnClearAll = document.getElementById('btn-clear-all');
  if (btnClearAll) {
    btnClearAll.addEventListener('click', () => {
      state.word = '';
      state.english = '';
      state.cho = null;
      state.jung = null;
      state.jong = null;
      state.jamoSeq = [];
      state.currentSyllable = '';
      state.lastPadType = null;
      state.lastPadValue = null;
      state.cycleIdx = 0;

      const engInput = document.getElementById('input-english') as HTMLInputElement;
      if (engInput) engInput.value = '';

      updateDisplay();
      updateWordDisplay();

      const coachBubble = document.getElementById('coach-bubble');
      if (coachBubble) {
        coachBubble.textContent = "조립판이 한꺼번에 지워졌습니다.";
      }
    });
  }

  // 단어 조립판 KOR input 박스: 직접 타이핑/외부 한글 복사-붙여넣기(Paste) 실시간 동기화
  const wordTextEl = document.getElementById('word-text') as HTMLInputElement | null;
  if (wordTextEl) {
    const syncInput = () => {
      state.word = wordTextEl.value;
      updatePhonetics();
      checkGameAnswer();

      // 붙여넣은 텍스트가 있으면 한꺼번에 지우기(×) 버튼 즉시 노출
      const btnClearAll = document.getElementById('btn-clear-all');
      if (btnClearAll) {
        btnClearAll.style.display = state.word ? 'flex' : 'none';
      }
    };

    wordTextEl.addEventListener('input', syncInput);
    wordTextEl.addEventListener('paste', () => {
      setTimeout(syncInput, 50); // 클립보드 텍스트가 입력창에 안착된 후 스캔하도록 딜레이
    });
  }

  if (btnBackspace) {
    btnBackspace.addEventListener('click', () => {
      // 1. 현재 조립 중인 한글이 있을 때
      if (state.cho) {
        if (state.jong) {
          // 겹받침(복자음)이면 앞의 자음만 남김
          if (DECOMPOSE_JONG_MAP[state.jong]) {
            state.jong = DECOMPOSE_JONG_MAP[state.jong][0];
            state.lastPadType = 'jong';
            state.lastPadValue = state.jong;
          } else {
            state.jong = null;
            state.lastPadType = 'jung';
          }
        } else if (state.jung) {
          state.jamoSeq.pop();
          state.jung = composeVowel(state.jamoSeq);
          if (!state.jung) {
            state.lastPadType = 'cho';
          }
        } else {
          state.cho = null;
          state.lastPadType = null;
        }
      } 
      // 2. 조립 중인 한글이 없고 조립판 단어가 있을 때
      else if (state.word) {
        // 단어의 마지막 글자가 겹받침을 가지고 있는지 확인하고 쪼갤 수 있다면 쪼개기
        const lastChar = state.word.slice(-1);
        const code = lastChar.charCodeAt(0);
        if (code >= 0xAC00 && code <= 0xD7A3) {
          const offset = code - 0xAC00;
          const jongIdx = offset % 28;
          const jungIdx = Math.floor((offset % 588) / 28);
          const choIdx = Math.floor(offset / 588);
          
          if (jongIdx > 0) {
            const currentJong = JONG_LIST[jongIdx];
            if (DECOMPOSE_JONG_MAP[currentJong]) {
              // 마지막 완성형 글자의 겹받침을 분해하여 뒤쪽만 제거
              const firstJong = DECOMPOSE_JONG_MAP[currentJong][0];
              const newChar = String.fromCharCode(
                0xAC00 + (choIdx * 21 + jungIdx) * 28 + JONG_LIST.indexOf(firstJong)
              );
              state.word = state.word.slice(0, -1) + newChar;
            } else {
              // 단일 받침이면 받침만 제거
              const newChar = String.fromCharCode(
                0xAC00 + (choIdx * 21 + jungIdx) * 28
              );
              state.word = state.word.slice(0, -1) + newChar;
            }
          } else {
            // 받침이 없으면 글자 전체 삭제
            state.word = state.word.slice(0, -1);
          }
        } else {
          // 완성형 한글이 아니면 그냥 한 자 지우기
          state.word = state.word.slice(0, -1);
        }
      }
      
      updateDisplay();
      updateWordDisplay();
    });
  }

  if (btnSpace) {
    btnSpace.addEventListener('click', () => {
      const text = renderSyllable();
      if (text !== '—') {
        state.word += text;
      }
      state.word += ' ';
      
      state.cho = null;
      state.jung = null;
      state.jong = null;
      state.jamoSeq = [];
      state.lastPadType = null;
      state.lastPadValue = null;
      state.cycleIdx = 0;
      
      updateDisplay();
      updateWordDisplay();
    });
  }

  if (btnEnter) {
    btnEnter.addEventListener('click', () => {
      const text = renderSyllable();
      if (text !== '—') {
        state.word += text;
        speakKo(text); // 확정된 글자 성우 음성으로 들려주기
      }
      
      state.cho = null;
      state.jung = null;
      state.jong = null;
      state.jamoSeq = [];
      state.lastPadType = null;
      state.lastPadValue = null;
      state.cycleIdx = 0;
      
      updateDisplay();
      updateWordDisplay();
    });
  }

  if (btnSpeakWord) {
    btnSpeakWord.addEventListener('click', () => {
      const currentText = renderSyllable();
      const finalSyllable = (currentText !== '—') ? currentText : '';
      const fullText = state.word + finalSyllable;

      if (fullText.trim()) {
        // 기계음(SpeechSynthesis) 전체 읽기를 제거하고, 한글 발음 법칙으로 연음화한 뒤
        // 로컬 gTTS 성우 음원(/audio/jamo/*.mp3)을 낱자 단위로 순차 결합 재생한다.
        const phoneticText = getPhoneticSubstitute(fullText);
        playSentence(phoneticText);
      }
    });
  }

  // BGM 재생 버튼
  const bgmBtn = document.getElementById('btn-toggle-bgm');
  const statusText = document.getElementById('playback-status');
  const discIcon = document.getElementById('disc-icon');
  const eqAnim = document.getElementById('eq-animation');

  if (bgmBtn && statusText) {
    bgmBtn.addEventListener('click', async () => {
      await ensureAudio();
      
      const playIcon = bgmBtn.querySelector('.play-icon');
      
      if (isBgmPlaying) {
        // 정지
        if (songSource) {
          songSource.stop();
          songSource = null;
        }
        isBgmPlaying = false;
        
        if (playIcon) playIcon.textContent = '▶';
        if (discIcon) discIcon.classList.remove('spinning');
        if (eqAnim) eqAnim.classList.remove('active');
        
        statusText.textContent = 'Stopped';
        statusText.style.color = '';
      } else {
        // 재생
        statusText.textContent = 'Loading...';
        try {
          const buf = await loadSong('/audio/kpop_song_1.wav');
          if (buf && audioCtx && bgmGain) {
            songSource = audioCtx.createBufferSource();
            songSource.buffer = buf;
            songSource.loop = true;
            songSource.connect(bgmGain);
            songSource.start(0);
            
            isBgmPlaying = true;
            
            if (playIcon) playIcon.textContent = '⏸';
            if (discIcon) discIcon.classList.add('spinning');
            if (eqAnim) eqAnim.classList.add('active');
            
            statusText.textContent = 'Looping';
            statusText.style.color = '#00F0FF';
          }
        } catch (err) {
          statusText.textContent = 'Error';
          if (discIcon) discIcon.classList.remove('spinning');
          if (eqAnim) eqAnim.classList.remove('active');
          console.error('Audio load failed:', err);
        }
      }
    });
  }

  // 마이크 코치 버튼
  const micBtn = document.getElementById('btn-mic') as HTMLButtonElement;
  const coachBubble = document.getElementById('coach-bubble');
  if (micBtn && coachBubble) {
    const micIcon = micBtn.querySelector('.mic-icon');
    const micText = document.getElementById('mic-text');

    // SpeechRecognition 인스턴스 생성 여부 파악하여 안내문구
    if (!SR) {
      micBtn.style.display = 'none';
      coachBubble.innerHTML += '<br><small style="color:hsl(350, 100%, 65%);">(음성 인식이 지원되지 않는 브라우저입니다. Chrome을 사용해 주세요.)</small>';
    } else {
      micBtn.addEventListener('click', async () => {
        if (!state.currentSyllable && state.langMode === 'ko') return;
        
        await ensureAudio();
        
        // 이미 녹음 중이면 리턴
        if (micBtn.classList.contains('recording')) return;

        try {
          // 에코/노이즈 캔슬러 및 자동 감도 조절 옵션을 강제 주입하여 음성 유입 성능을 극대화
          await navigator.mediaDevices.getUserMedia({ 
            audio: {
              echoCancellation: true,
              noiseSuppression: true,
              autoGainControl: true
            } 
          });
        } catch (err) {
          coachBubble.textContent = '마이크 권한을 허용해 주세요! 🎤';
          return;
        }

        if (!recognizer) {
          recognizer = new SR();
          recognizer.interimResults = false;
          recognizer.maxAlternatives = 1;
          recognizer.continuous = false;
        }
        
        // 언어 모드 동적 할당
        recognizer.lang = (state.langMode === 'en') ? 'en-US' : 'ko-KR';

        // BGM 완전 음소거 (배경 소음으로 인한 마이크 인식 장애 원천 차단)
        if (bgmGain && isBgmPlaying) {
          bgmGain.gain.setValueAtTime(0.0, audioCtx!.currentTime);
        }

        recognizer.onstart = () => {
          micBtn.classList.add('recording');
          if (micIcon) micIcon.textContent = '🛑';
          if (micText) micText.textContent = 'Listening...';
          
          if (state.langMode === 'en') {
            coachBubble.textContent = "영어로 말씀해 보세요... (Speak in English...)";
          } else {
            coachBubble.textContent = `"${state.currentSyllable}" 발음을 또박또박 말씀해 보세요...`;
          }
        };

        recognizer.onresult = (e: any) => {
          const heard = e.results[0][0].transcript.trim();
          
          if (state.langMode === 'en') {
            // 영어 음성 인식 완료
            state.english = heard;
            updateWordDisplay();
            translateSentence(heard);
          } else {
            // 한글 발음 평가
            const score = scorePronunciation(heard, state.currentSyllable);
            
            let comment = '';
            if (score >= 90) {
              comment = '완벽한 발음입니다! 🎉 K-Pop 그루브가 느껴져요!';
              state.combo++;
            } else if (score >= 60) {
              comment = '거의 비슷합니다! 조금 더 또박또박 발음해볼까요?';
            } else {
              comment = '입모양을 조금 더 크게 벌리고 소리를 내 보세요. 다시 도전!';
              state.combo = 0;
            }

            coachBubble.innerHTML = `인식된 발음: <strong>"${heard}"</strong> (일치율 ${score}점)<br>${comment}`;
            
            // 정답 TTS 재생
            setTimeout(() => {
              speakKo(state.currentSyllable);
            }, 500);
          }
        };

        recognizer.onerror = (e: any) => {
          coachBubble.textContent = `다시 말해볼까요? (에러: ${e.error})`;
        };

        recognizer.onend = () => {
          micBtn.classList.remove('recording');
          if (micIcon) micIcon.textContent = '🎤';
          if (micText) micText.textContent = 'Coach';
          
          // BGM 음량 복구
          if (bgmGain && isBgmPlaying) {
            bgmGain.gain.setValueAtTime(0.15, audioCtx!.currentTime);
          }
        };

        recognizer.start();
      });
    }
  }

  // 상황별 데이터 셋
  const PHRASE_DATA: Record<string, Array<{ ko: string; en: string; coach: string }>> = {
    restaurant: [
      { ko: '물 주세요', en: 'Please give me water', coach: '식당에서 물을 달라고 정중히 요청해 보세요! 🥤' },
      { ko: '밥 주세요', en: 'Please give me rice', coach: '식사 전 밥을 요청하는 생존 한글 표현입니다. 🍚' },
      { ko: '맛있어요', en: 'It is delicious', coach: '음식을 먹은 뒤 "맛있어요!"라고 칭찬과 긍정 피드백을 전달하세요! 😋' }
    ],
    restroom: [
      { ko: '화장실 어디에요', en: 'Where is the restroom?', coach: '화장실 위치를 묻는 가장 중요한 일상 표현입니다! 🚻' },
      { ko: '휴지 주세요', en: 'Please give me toilet paper', coach: '급한 상황에서 휴지를 부탁할 때 유용하게 쓰입니다. 🧻' }
    ],
    airport: [
      { ko: '여권 여기 있어요', en: 'Here is my passport', coach: '입국 심사나 체크인 시 여권을 보여주며 사용합니다. ✈️' },
      { ko: '비행기 어디에요', en: 'Where is the airplane?', coach: '게이트나 탑승 장소를 묻는 공항 필수 표현입니다. 🛫' }
    ],
    station: [
      { ko: '표 주세요', en: 'Please give me a ticket', coach: '매표소에서 목적지 행 티켓을 요청하는 문장입니다. 🎫' },
      { ko: '기차 어디에요', en: 'Where is the train?', coach: '기차 플랫폼의 위치를 묻는 핵심 기차역 표현입니다. 🚉' }
    ]
  };

  // 상황 탭 & 카드 이벤트 바인딩
  const tabBtns = document.querySelectorAll('.situation-tabs .tab-btn');
  const phraseListEl = document.getElementById('phrase-list');

  tabBtns.forEach(tab => {
    tab.addEventListener('click', (e) => {
      const target = e.currentTarget as HTMLButtonElement;
      const category = target.getAttribute('data-category') || 'restaurant';

      // 활성 탭 스타일 전환
      tabBtns.forEach(b => b.classList.remove('active'));
      target.classList.add('active');

      // 리스트 갱신
      if (phraseListEl) {
        phraseListEl.innerHTML = '';
        const phrases = PHRASE_DATA[category] || [];
        
        phrases.forEach(p => {
          const btn = document.createElement('button');
          btn.className = 'phrase-card';
          btn.setAttribute('data-phrase', p.ko);
          btn.innerHTML = `
            <span class="phrase-ko">${p.ko}</span>
            <span class="phrase-en">${p.en}</span>
          `;
          phraseListEl.appendChild(btn);

          // 클릭 리스너 동적 연동
          btn.addEventListener('click', () => {
            handlePhraseClick(p.ko, p.coach);
          });
        });
      }
    });
  });

  // 문장 카드 클릭 공통 처리 핸들러
  function handlePhraseClick(phrase: string, coachMsg: string) {
    // 1. 단어 조립판에 즉시 대입
    state.word = phrase;
    updateWordDisplay();

    // 2. 조립 중인 임시 글자 영역 초기화
    state.cho = null;
    state.jung = null;
    state.jong = null;
    state.jamoSeq = [];
    state.lastPadType = null;
    state.lastPadValue = null;
    state.cycleIdx = 0;
    updateDisplay();

    // 3. 성우 연속 음성 큐 발동
    playSentence(phrase);

    // 4. AI 코치 말풍선 멘트 갱신
    const coachBubble = document.getElementById('coach-bubble');
    if (coachBubble) {
      coachBubble.textContent = coachMsg;
    }
  }

  // 초기 예문 리스트 카드들에도 클릭 핸들러 바인딩
  const initialCards = document.querySelectorAll('.phrase-list .phrase-card');
  initialCards.forEach(card => {
    card.addEventListener('click', (e) => {
      const target = e.currentTarget as HTMLButtonElement;
      const phrase = target.getAttribute('data-phrase') || '';
      
      // 코치 메세지 조회
      let coachMsg = '가이드를 터치해 단어를 배워보세요!';
      for (const cat in PHRASE_DATA) {
        const item = PHRASE_DATA[cat].find(p => p.ko === phrase);
        if (item) {
          coachMsg = item.coach;
          break;
        }
      }
      handlePhraseClick(phrase, coachMsg);
    });
  });

  // 영어 텍스트 입력창 이벤트 바인딩
  const inputEnglish = document.getElementById('input-english') as HTMLInputElement;
  if (inputEnglish) {
    inputEnglish.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        const text = inputEnglish.value.trim();
        if (text) {
          state.english = text;
          updateWordDisplay();
          translateSentence(text);
          inputEnglish.value = ''; // 입력 후 비우기
          inputEnglish.blur(); // 포커스 아웃
        }
      }
    });
  }
  // 언어 모드에 맞춰 UI 메뉴 텍스트 다국어 업데이트
  function updateUIForLanguage() {
    const isEn = state.langMode === 'en';
    
    // 1. Reset 버튼
    const btnReset = document.getElementById('btn-reset');
    if (btnReset) {
      btnReset.textContent = isEn ? '↺ Reset' : '↺ 초기화';
    }

    // 2. 홈 버튼
    const homeBtn = document.querySelector('.home-btn');
    if (homeBtn) {
      homeBtn.textContent = isEn ? '🏠 Home' : '🏠 홈으로';
    }

    // 3. 지우기 버튼
    const btnBackspace = document.getElementById('btn-backspace');
    if (btnBackspace) {
      btnBackspace.textContent = isEn ? '⌫ Clear' : '⌫ 지우기';
    }

    // 4. 띄어쓰기 버튼
    const btnSpace = document.getElementById('btn-space');
    if (btnSpace) {
      btnSpace.textContent = isEn ? '␣ Space' : '␣ 띄어쓰기';
    }

    // 5. 확정 버튼
    const btnEnter = document.getElementById('btn-enter');
    if (btnEnter) {
      btnEnter.textContent = isEn ? '↵ Done' : '↵ 확정';
    }

    // 6. 전체 읽기 버튼
    const btnSpeakWord = document.getElementById('btn-speak-word');
    if (btnSpeakWord) {
      btnSpeakWord.textContent = isEn ? '🔊 Speak All' : '🔊 전체 읽기';
    }

    // 7. 마이크 코치 버튼
    const micIcon = document.querySelector('#btn-mic .mic-icon');
    if (micIcon) {
      micIcon.textContent = isEn ? '🎤 Coach Mic' : '🎤 코치 마이크';
    }

    // 8. 상방 모드 스위처 버튼 번역
    const switcherBtns = document.querySelectorAll('.switcher-btn');
    switcherBtns.forEach(btn => {
      const mode = btn.getAttribute('data-mode');
      if (mode === 'launchpad') {
        btn.innerHTML = isEn ? '🎹 Pad' : '🎹 런치';
      } else if (mode === 'translator') {
        btn.innerHTML = isEn ? '🌐 Trans' : '🌐 번역';
      } else if (mode === 'phrases') {
        btn.innerHTML = isEn ? '📖 Phrase' : '📖 상황';
      } else if (mode === 'game') {
        btn.innerHTML = isEn ? '🎮 Game' : '🎮 게임';
      }
    });

    // 발음 설명 언어 동적 갱신
    updatePhonetics();
  }

  // 언어 모드 토글 버튼 바인딩
  const btnLangKo = document.getElementById('btn-lang-ko');
  const btnLangEn = document.getElementById('btn-lang-en');

  if (btnLangKo && btnLangEn) {
    btnLangKo.addEventListener('click', () => {
      state.langMode = 'ko';
      btnLangKo.classList.add('active');
      btnLangEn.classList.remove('active');
      updateDisplay();
      updateUIForLanguage();
      
      const coachBubble = document.getElementById('coach-bubble');
      if (coachBubble) {
        coachBubble.textContent = "한국어 모드 활성화. 런치패드로 조립하거나 마이크로 발음을 연습해 보세요!";
      }
    });

    btnLangEn.addEventListener('click', () => {
      state.langMode = 'en';
      btnLangEn.classList.add('active');
      btnLangKo.classList.remove('active');
      updateDisplay();
      updateUIForLanguage();
      
      const coachBubble = document.getElementById('coach-bubble');
      if (coachBubble) {
        coachBubble.textContent = "영어 모드 활성화. 아래 창에 타핑하거나 마이크로 영어를 말씀하세요!";
      }
    });
  }

  // 초기 로드 시 1회 다국어 UI 적용
  updateUIForLanguage();

  // ── 한글 아케이드 게임 엔진 ──
  const QUIZ_POOL = [
    { ko: '물 주세요', en: 'Please give me water' },
    { ko: '밥 주세요', en: 'Please give me rice' },
    { ko: '맛있어요', en: 'It is delicious' },
    { ko: '화장실 어디에요', en: 'Where is the restroom?' },
    { ko: '휴지 주세요', en: 'Please give me toilet paper' },
    { ko: '여권 여기 있어요', en: 'Here is my passport' },
    { ko: '비행기 어디에요', en: 'Where is the airplane?' },
    { ko: '표 주세요', en: 'Please give me a ticket' },
    { ko: '기차 어디에요', en: 'Where is the train?' }
  ];

  const gameState = {
    isPlaying: false,
    score: 0,
    combo: 0,
    timeLeft: 30,
    targetPhrase: '',
    targetEnglish: '',
    timerId: null as number | null
  };

  function startArcadeGame() {
    stopArcadeGame(); // 안전 정지
    
    // 게임 HUD 패널 노출
    const hudPanel = document.getElementById('game-hud-panel');
    if (hudPanel) hudPanel.classList.remove('hidden');

    gameState.isPlaying = true;
    gameState.score = 0;
    gameState.combo = 0;
    gameState.timeLeft = 30;
    
    // 점수판 초기화
    updateGameScoreboard();

    // BGM 자동 재생 트리거
    triggerGameBGM(true);

    // 첫 문제 출제
    nextQuiz();

    // 타이머 가동
    gameState.timerId = window.setInterval(() => {
      gameState.timeLeft--;
      updateGameTimerUI();

      if (gameState.timeLeft <= 0) {
        stopArcadeGame();
        const coachBubble = document.getElementById('coach-bubble');
        if (coachBubble) {
          coachBubble.innerHTML = `🏁 <strong>게임 종료!</strong> 최종 점수: <strong>${gameState.score}점</strong> (최대 콤보: ${gameState.combo})`;
        }
      }
    }, 1000) as any;

    // UI 버튼 변경
    const toggleBtn = document.getElementById('btn-game-toggle');
    if (toggleBtn) {
      toggleBtn.textContent = '🛑 Game Stop';
      toggleBtn.classList.add('playing');
    }
  }

  function stopArcadeGame() {
    gameState.isPlaying = false;
    if (gameState.timerId) {
      clearInterval(gameState.timerId);
      gameState.timerId = null;
    }
    
    // 게임 HUD 패널 숨김
    const hudPanel = document.getElementById('game-hud-panel');
    if (hudPanel) hudPanel.classList.add('hidden');

    triggerGameBGM(false);

    const toggleBtn = document.getElementById('btn-game-toggle');
    if (toggleBtn) {
      toggleBtn.textContent = '🚀 Game Start';
      toggleBtn.classList.remove('playing');
    }

    const quizKoEl = document.getElementById('quiz-korean');
    const quizEnEl = document.getElementById('quiz-english');
    if (quizKoEl) quizKoEl.textContent = 'Game Start를 눌러주세요';
    if (quizEnEl) quizEnEl.textContent = '—';
  }

  function nextQuiz() {
    if (!gameState.isPlaying) return;

    // 무작위로 하나 선정
    const idx = Math.floor(Math.random() * QUIZ_POOL.length);
    const quiz = QUIZ_POOL[idx];

    gameState.targetPhrase = quiz.ko;
    gameState.targetEnglish = quiz.en;

    const quizKoEl = document.getElementById('quiz-korean');
    const quizEnEl = document.getElementById('quiz-english');
    if (quizKoEl) quizKoEl.textContent = '???'; // 한글 정답은 숨깁니다
    if (quizEnEl) quizEnEl.textContent = quiz.en; // 영어 힌트만 노출

    // 퀴즈 출제 시 단어 조립판 자동 초기화
    state.cho = null;
    state.jung = null;
    state.jong = null;
    state.jamoSeq = [];
    state.word = '';
    state.english = '';
    updateDisplay();
    updateWordDisplay();

    const coachBubble = document.getElementById('coach-bubble');
    if (coachBubble) {
      coachBubble.textContent = `영어 "${quiz.en}"에 해당하는 한글 문장을 조립해 보세요!`;
    }
  }

  function updateGameScoreboard() {
    const scoreEl = document.getElementById('game-score');
    const comboEl = document.getElementById('game-combo');
    if (scoreEl) scoreEl.textContent = String(gameState.score);
    if (comboEl) comboEl.textContent = String(gameState.combo);
  }

  function updateGameTimerUI() {
    const barEl = document.getElementById('game-timer-bar');
    const textEl = document.getElementById('game-timer-text');
    if (barEl) {
      const pct = (gameState.timeLeft / 30) * 100;
      barEl.style.width = `${pct}%`;
    }
    if (textEl) {
      textEl.textContent = `${gameState.timeLeft}s`;
    }
  }

  function checkGameAnswer() {
    if (!gameState.isPlaying) return;

    // 입력 단어에서 띄어쓰기를 정리하고 매칭 체크
    const currentAns = state.word.replace(/\s+/g, '').trim();
    const targetAns = gameState.targetPhrase.replace(/\s+/g, '').trim();

    if (currentAns === targetAns) {
      // 정답 달성!
      gameState.score += 100 + (gameState.combo * 20); // 콤보 가속 점수
      gameState.combo++;
      gameState.timeLeft = Math.min(30, gameState.timeLeft + 8); // 시간 보너스
      
      updateGameScoreboard();
      updateGameTimerUI();

      // 우렁차게 한글 성우 정답 재생
      playSentence(gameState.targetPhrase);

      // 성공 네온 이펙트 팝업
      const quizKoEl = document.getElementById('quiz-korean');
      if (quizKoEl) {
        quizKoEl.textContent = `🎉 CORRECT: ${gameState.targetPhrase}`;
        quizKoEl.style.color = 'var(--gv-neon-jung)';
      }

      setTimeout(() => {
        if (quizKoEl) quizKoEl.style.color = '';
        nextQuiz();
      }, 1200);
    }
  }

  // 게임 BGM 트리거 제어
  function triggerGameBGM(play: boolean) {
    const bgmBtn = document.getElementById('btn-toggle-bgm');
    
    // 현재 BGM 플레이 상태와 맞지 않을 때만 강제 클릭 트리거
    if (play && !isBgmPlaying) {
      bgmBtn?.click();
    } else if (!play && isBgmPlaying) {
      bgmBtn?.click();
    }
  }

  // 게임시작 버튼 리스너 바인딩
  const gameToggleBtn = document.getElementById('btn-game-toggle');
  if (gameToggleBtn) {
    gameToggleBtn.addEventListener('click', () => {
      if (gameState.isPlaying) {
        stopArcadeGame();
      } else {
        startArcadeGame();
      }
    });
  }
</script>
