}

.stage-play-content {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  flex-grow: 1;
  height: 100%;
}

.stage-play-content.hidden {
  display: none !important;
}

/* Stage 1: 가획의 과학 */
.stage1-layout-container {
  display: flex;
  flex-direction: column;
  gap: 12px;
  height: 100%;
  flex-grow: 1;
  z-index: 10;
}

.stage1-quiz-panel {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 16px;
  background: radial-gradient(circle at center, hsl(245 30% 12%), hsl(245 40% 6%)) !important;
  border: 1.5px solid var(--gv-border);
  border-radius: var(--gv-radius-sm);
  min-height: 160px;
  position: relative;
  overflow: hidden;
}

.stage1-quiz-panel::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(rgba(255,255,255,0.02) 50%, rgba(0,0,0,0.1) 50%);
  background-size: 100% 4px;
  pointer-events: none;
}

.stage1-image-box {
  font-size: 5rem;
  line-height: 1;
  filter: drop-shadow(0 0 15px rgba(255,255,255,0.25));
  animation: pulseEmoji 2s infinite alternate;
}

@keyframes pulseEmoji {
  from { transform: scale(0.98); }
  to { transform: scale(1.05); }
}

.stage1-target-word {
  font-size: 2.2rem;
  font-weight: 900;
  color: var(--gv-text-0);
  text-shadow: 0 0 10px rgba(255,255,255,0.4);
  margin: 6px 0;
  letter-spacing: 2px;
}

.stage1-pron-hint {
  font-size: 0.78rem;
  font-weight: 800;
  color: var(--gv-text-2);
  letter-spacing: 2px;
  font-family: monospace;
  background: hsla(255, 60%, 80%, 0.1);
  padding: 4px 12px;
  border-radius: 12px;
  border: 1px solid var(--gv-border);
  margin-bottom: 8px;
}

.stage1-instruction {
  font-size: 0.72rem;
  color: var(--gv-text-2);
  opacity: 0.8;
  letter-spacing: 1px;
}

.stage1-math-panel {
  padding: 16px;
  border: 1.5px solid var(--gv-border-active);
  border-radius: var(--gv-radius-sm);
  background: hsl(245 35% 8% / 0.85) !important;
  box-shadow: 0 8px 24px rgba(0,0,0,0.6);
}

.math-formula {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16px;
  margin-bottom: 16px;
  padding: 12px;
  background: rgba(0, 0, 0, 0.4);
  border-radius: 8px;
  border: 1px dashed var(--gv-border);
}

.math-term {
  font-size: 2.2rem;
  font-weight: 900;
  font-family: monospace;
}

.neon-text-purple {
  color: var(--gv-neon-accent);
  text-shadow: var(--gv-glow-accent);
}

.neon-text-cyan {
  color: var(--gv-neon-jung);
  text-shadow: var(--gv-glow-jung);
}

.slot-blink {
  color: var(--gv-text-2);
  border: 2px dashed var(--gv-text-2);
  padding: 0 16px;
  border-radius: 6px;
  animation: slotPulse 1s infinite alternate;
  font-size: 1.8rem;
}

@keyframes slotPulse {
  from { opacity: 0.4; border-color: rgba(255,255,255,0.2); }
  to { opacity: 1.0; border-color: var(--gv-neon-cho); color: var(--gv-neon-cho); text-shadow: var(--gv-glow-cho); }
}

.math-operator {
  font-size: 1.6rem;
  font-weight: 800;
  color: var(--gv-text-2);
}

.stage1-stroke-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10px;
}

.stage1-stroke-btn {
  background: var(--gv-surface);
  border: 1.5px solid var(--gv-border);
  border-radius: 8px;
  padding: 14px 0;
  font-size: 1.5rem;
  font-weight: 900;
  color: var(--gv-text-0);
  cursor: pointer;
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 4px 10px rgba(0,0,0,0.4);
}

.stage1-stroke-btn:hover {
  border-color: var(--gv-neon-cho);
  box-shadow: var(--gv-glow-cho);
  background: var(--gv-surface-2);
  transform: translateY(-2px);
}

.stage1-stroke-btn:active {
  transform: translateY(0);
}

.stage1-stroke-btn.correct {
  background: hsl(150, 60%, 15% / 0.8) !important;
  border-color: hsl(150, 80%, 45%) !important;
  color: hsl(150, 90%, 70%) !important;
  box-shadow: 0 0 15px hsl(150 80% 45% / 0.5) !important;
}

.stage1-stroke-btn.wrong {
  background: hsl(0, 60%, 15% / 0.8) !important;
  border-color: hsl(0, 80%, 45%) !important;
  color: hsl(0, 90%, 70%) !important;
  box-shadow: 0 0 15px hsl(0 80% 45% / 0.5) !important;
  animation: shakeButton 0.3s;
}

@keyframes shakeButton {
  0% { transform: translateX(0); }
  25% { transform: translateX(-4px); }
  50% { transform: translateX(4px); }
  75% { transform: translateX(-4px); }
  100% { transform: translateX(0); }
}

/* Stage 2: 초/중/종성 3D 공간 기하학 */
.stage2-layout-container {
  display: flex;
  flex-direction: column;
  height: 100%;
  flex-grow: 1;
  z-index: 10;
}

.stage2-drop-zone-area {
  flex-grow: 1;
  background: radial-gradient(120% 120% at 50% 100%, hsl(245 40% 10%), hsl(245 50% 3%));
  border: 1.5px solid var(--gv-border-active);
  border-radius: var(--gv-radius-sm);
  position: relative;
  overflow: hidden;
  margin-bottom: 12px;
  min-height: 220px;
  box-shadow: inset 0 0 25px rgba(0,0,0,0.9);
}

.danger-baseline {
  position: absolute;
  bottom: 24px;
  left: 0;
  width: 100%;
  height: 3px;
  background: repeating-linear-gradient(90deg, hsl(0, 100%, 50%), hsl(0, 100%, 50%) 10px, transparent 10px, transparent 20px);
  opacity: 0.8;
  box-shadow: 0 0 12px hsl(0, 100%, 50% / 0.6);
  animation: pulseDanger 1.2s infinite alternate;
}

@keyframes pulseDanger {
  from { opacity: 0.4; }
  to { opacity: 0.9; }
}

.falling-jamo-box {
  position: absolute;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--gv-surface-2);
  border: 1.5px solid var(--gv-neon-accent);
  border-radius: 50%;
  width: 36px;
  height: 36px;
  font-size: 1.2rem;
  font-weight: 900;
  color: var(--gv-text-0);
  box-shadow: var(--gv-glow-accent);
  cursor: pointer;
  user-select: none;
  transition: border-color 0.2s;
  z-index: 10;
}

.falling-jamo-box.danger {
  border-color: hsl(0, 100%, 60%) !important;
  box-shadow: 0 0 10px hsl(0, 100%, 60%) !important;
  animation: vibrateBox 0.15s infinite;
}

@keyframes vibrateBox {
  0% { transform: translate(0, 0); }
  50% { transform: translate(-1.5px, 1px); }
  100% { transform: translate(1px, -1px); }
}

.stage2-hologram-layout {
  padding: 12px;
  border: 1.5px solid var(--gv-border);
  border-radius: var(--gv-radius-sm);
  background: hsl(245 30% 8% / 0.95) !important;
  box-shadow: 0 6px 20px rgba(0,0,0,0.5);
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.stage2-target-badge {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 6px 12px;
  background: rgba(0, 0, 0, 0.4);
  border-radius: 6px;
  border: 1px solid var(--gv-border);
}

.stage2-target-badge .lbl {
  font-size: 0.6rem;
  font-weight: 800;
  color: var(--gv-text-2);
  letter-spacing: 1px;
}

.stage2-target-badge .val {
  font-size: 1.3rem;
  font-weight: 900;
  color: #fff;
  text-shadow: 0 0 8px rgba(255,255,255,0.6);
  letter-spacing: 1.5px;
}

.stage2-grid-frame {
  display: grid;
  grid-template-columns: 1.2fr 1fr;
  grid-template-rows: 1fr 0.9fr;
  gap: 8px;
  height: 120px;
  perspective: 400px;
}

.grid-cell {
  border: 2px dashed rgba(255, 255, 255, 0.15);
  border-radius: 8px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  background: rgba(255, 255, 255, 0.02);
}

.grid-cell .cell-label {
  font-size: 0.55rem;
  font-weight: 800;
  color: var(--gv-text-2);
  opacity: 0.6;
  position: absolute;
  top: 4px;
  left: 6px;
}

.grid-cell .cell-val {
  font-size: 2.2rem;
  font-weight: 900;
  color: var(--gv-text-2);
  transition: transform 0.15s ease;
}

.cho-cell {
  grid-row: 1 / 2;
  grid-column: 1 / 2;
  border-color: rgba(244, 63, 94, 0.3);
}
.cho-cell.active-lock {
  border: 2px solid hsl(340, 100%, 65%);
  box-shadow: inset 0 0 10px hsl(340 100% 65% / 0.2), 0 0 12px hsl(340 100% 65% / 0.3);
}
.cho-cell.active-lock .cell-val {
  color: hsl(340, 100%, 75%);
