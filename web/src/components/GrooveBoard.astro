---
import { t } from '../lib/i18n';
import type { Lang } from '../lib/content';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const tr = t(lang);
---

<div class="groove glass">
  <div class="groove-cockpit">
    <!-- 상단 콕핏 헤더: 홈으로 링크, 리셋 버튼과 심플 타이틀 -->
    <div class="cockpit-header">
      <div class="header-main">
        <h2 id="groove-title-text">{tr.groove_title}</h2>
      </div>
      <div class="header-actions">
        <a href="/" class="action-mini-btn home-btn" title="홈으로">🏠 홈으로</a>
        <button id="btn-reset" class="action-mini-btn" title="초기화">↺ Reset</button>
      </div>
    </div>

    <!-- 콕핏 모드 선택 스위처 바 (가로 1줄 줄바꿈 방지) -->
    <div class="cockpit-mode-switcher glass">
      <button class="switcher-btn active" data-mode="launchpad">🎹 {lang === 'ko' ? '런치' : 'Pad'}</button>
      <button class="switcher-btn" data-mode="translator">🌐 {lang === 'ko' ? '번역' : 'Trans'}</button>
      <button class="switcher-btn" data-mode="phrases">📖 {lang === 'ko' ? '상황' : 'Phrase'}</button>
      <button class="switcher-btn" data-mode="game">🎮 {lang === 'ko' ? '게임' : 'Game'}</button>
    </div>

    <!-- 중앙 메인 HUD 모니터 (활성화된 모드에 따라 내장 콘텐츠 스위칭) -->
    <div class="cockpit-main-monitor glass">
      
      <!-- 1. 런치패드 모드 모니터 뷰 -->
      <div id="monitor-content-launchpad" class="monitor-view active">
        <div class="center-display-monitor">
          <!-- 왼편: 한글 글자 조어 영역 -->
          <div class="syllable-left-zone">
            <div class="syllable-container">
              <span id="display-syllable" class="syllable">—</span>
            </div>
          </div>
          
          <!-- 오른편: 조음 설명 및 소리 없음 안내 영역 -->
          <div class="monitor-right-zone">
            <div id="no-audio-badge" class="no-audio-badge hidden">⚠️ {lang === 'ko' ? '소리 없음' : 'No Sound'}</div>
            
            <div id="articulatory-popup" class="anatomy-card glass hidden">
              <div class="anatomy-avatar" id="anatomy-emoji">👅</div>
              <div class="anatomy-text">
                <strong id="anatomy-title">ㄱ</strong>
                <p id="anatomy-desc">설근폐후(혀뿌리가 목구멍을 막는 모양)</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- 2. 번역 모드 모니터 뷰 -->
      <div id="monitor-content-translator" class="monitor-view">
        <div class="english-input-wrapper-card glass">
          <span class="input-card-title">English Input (Press Enter)</span>
          <div class="english-input-wrapper">
            <input type="text" id="input-english" class="english-input" placeholder="Type English here..." />
          </div>
        </div>
      </div>

      <!-- 3. 상황 모드 모니터 뷰 -->
      <div id="monitor-content-phrases" class="monitor-view">
        <div class="situation-helper-section glass">
          <div class="situation-header">
            <span class="situation-title">📖 {lang === 'ko' ? '상황 표현 가이드' : 'Phrases'}</span>
          </div>
          <div class="situation-tabs">
            <button class="tab-btn active" data-category="restaurant">🍔 {lang === 'ko' ? '식당' : 'Dining'}</button>
            <button class="tab-btn" data-category="restroom">🚻 {lang === 'ko' ? '화장실' : 'Restroom'}</button>
            <button class="tab-btn" data-category="airport">✈️ {lang === 'ko' ? '공항' : 'Airport'}</button>
            <button class="tab-btn" data-category="station">🚄 {lang === 'ko' ? '기차역' : 'Station'}</button>
          </div>
          <div class="phrase-list" id="phrase-list">
            <button class="phrase-card" data-phrase="물 주세요">
              <span class="phrase-ko">물 주세요</span>
              <span class="phrase-en">Please give me water</span>
            </button>
            <button class="phrase-card" data-phrase="밥 주세요">
              <span class="phrase-ko">밥 주세요</span>
              <span class="phrase-en">Please give me rice</span>
            </button>
            <button class="phrase-card" data-phrase="맛있어요">
              <span class="phrase-ko">맛있어요</span>
              <span class="phrase-en">It is delicious</span>
            </button>
          </div>
        </div>
      </div>

      <!-- 4. 게임 모드 모니터 뷰 -->
      <div id="monitor-content-game" class="monitor-view">
        <div class="game-control-card glass">
          <button id="btn-game-toggle" class="control-btn game-toggle-btn glass">🚀 Game Start</button>
        </div>
        
        <!-- 게임 스코어 & 콤보 & 타이머 (게임 아케이드 실행 시 동적 노출되는 HUD 구조) -->
        <div class="game-hud-panel glass hidden" id="game-hud-panel">
          <div class="hud-score-row">
            <div class="hud-item">
              <span class="hud-label">SCORE</span>
              <span id="game-score" class="hud-val">0</span>
            </div>
            <div class="hud-timer-container">
              <div id="game-timer-bar" class="timer-bar" style="width: 100%;"></div>
              <span id="game-timer-text" class="timer-text">30s</span>
            </div>
            <div class="hud-item">
              <span class="hud-label">COMBO</span>
              <span id="game-combo" class="hud-val">0</span>
            </div>
          </div>
          <!-- 퀴즈 타겟 -->
          <div class="hud-quiz-box glass">
            <div class="quiz-row">
              <span class="q-badge eng">ENG</span>
              <p id="quiz-english" class="q-text">—</p>
            </div>
            <div class="quiz-row">
              <span class="q-badge kor">KOR</span>
              <p id="quiz-korean" class="q-target-ko">Game Start!</p>
            </div>
          </div>
        </div>
      </div>

    </div>

    <!-- 중앙 하단 공통 글자 조립판 (KOR/ENG 결과가 상시 보임 - 키보드와 바짝 밀착) -->
    <div class="word-board-section glass">
      <div class="word-display-row" id="english-row" style="display: none;">
        <span class="lang-badge eng">ENG</span>
        <span id="english-text" class="english-text">—</span>
      </div>
      <div class="word-display-row">
        <span class="lang-badge kor">KOR</span>
        <input type="text" id="word-text" class="word-text word-text-input" value="" placeholder="여기에 한글을 붙여넣으세요 (Paste Korean here)" />
        <button id="btn-clear-all" class="clear-all-btn" aria-label="Clear all words" title="한꺼번에 지우기" style="display: none;">×</button>
      </div>
      <!-- 발음 법칙 및 변음 현상 안내 바 추가 -->
      <div id="phonetic-row" class="phonetic-row glass hidden">
        <span class="phonetic-label">🗣 발음 (Phonetics):</span>
        <span id="phonetic-pron" class="phonetic-pron">[구지]</span>
        <span id="phonetic-rule" class="phonetic-rule">구개음화</span>
      </div>
    </div>

    <!-- 하단 콕핏 키보드 독 (2단 구성: 상단 자모 패드 결합, 하단 큼직한 제어 패널) -->
    <div class="cockpit-keyboard-dock">
      
      <!-- 1단: 자음 D-pad & 모음 Action-pad (중간 키가 빠져서 물리적으로 바짝 붙음) -->
      <div class="keyboard-pads-row">
        <!-- 좌측: 자음 D-pad -->
        <div class="keyboard-group-panel left-pad-panel">
          <span class="panel-label">🎹 자음 (Consonants)</span>
          <div class="launchpad dpad-layout">
            <div class="pad-wrapper">
              <button class="pad cho glass" data-jamo="ㄱ" aria-label="자음 기역">ㄱ</button>
              <div class="pad-popup glass">
                <button type="button" class="popup-item" data-value="ㄱ">ㄱ</button>
                <button type="button" class="popup-item" data-value="ㄲ">ㄲ</button>
                <button type="button" class="popup-item" data-value="ㅋ">ㅋ</button>
              </div>
            </div>
            <div class="pad-wrapper">
              <button class="pad cho glass" data-jamo="ㄴ" aria-label="자음 니은">ㄴ</button>
              <div class="pad-popup glass shift-right">
                <button type="button" class="popup-item" data-value="ㄴ">ㄴ</button>
                <button type="button" class="popup-item" data-value="ㄷ">ㄷ</button>
                <button type="button" class="popup-item" data-value="ㄸ">ㄸ</button>
                <button type="button" class="popup-item" data-value="ㅌ">ㅌ</button>
                <button type="button" class="popup-item" data-value="ㄹ">ㄹ</button>
              </div>
            </div>
            <div class="pad-wrapper">
              <button class="pad cho glass" data-jamo="ㅁ" aria-label="자음 미음">ㅁ</button>
              <div class="pad-popup glass">
                <button type="button" class="popup-item" data-value="ㅁ">ㅁ</button>
                <button type="button" class="popup-item" data-value="ㅂ">ㅂ</button>
                <button type="button" class="popup-item" data-value="ㅃ">ㅃ</button>
                <button type="button" class="popup-item" data-value="ㅍ">ㅍ</button>
              </div>
            </div>
            <div class="pad-wrapper">
              <button class="pad cho glass" data-jamo="ㅅ" aria-label="자음 시옷">ㅅ</button>
              <div class="pad-popup glass">
                <button type="button" class="popup-item" data-value="ㅅ">ㅅ</button>
                <button type="button" class="popup-item" data-value="ㅆ">ㅆ</button>
                <button type="button" class="popup-item" data-value="ㅈ">ㅈ</button>
                <button type="button" class="popup-item" data-value="ㅉ">ㅉ</button>
                <button type="button" class="popup-item" data-value="ㅊ">ㅊ</button>
              </div>
            </div>
            <div class="pad-wrapper">
              <button class="pad cho glass" data-jamo="ㅇ" aria-label="자음 이응">ㅇ</button>
              <div class="pad-popup glass">
                <button type="button" class="popup-item" data-value="ㅇ">ㅇ</button>
                <button type="button" class="popup-item" data-value="ㅎ">ㅎ</button>
              </div>
            </div>
          </div>
        </div>

        <!-- 우측: 모음 Action-pad & BGM 플레이어 -->
        <div class="keyboard-group-panel right-pad-panel">
          <span class="panel-label">☄️ 모음 & 비트 (Vowels & Beat)</span>
          <div class="vowels dpad-layout">
            <div class="pad-wrapper">
              <button class="pad jung glass" data-jamo="•" aria-label="하늘 아래아">•</button>
              <div class="pad-popup glass">
                <button type="button" class="popup-item" data-value="ㅏ">ㅏ</button>
                <button type="button" class="popup-item" data-value="ㅓ">ㅓ</button>
                <button type="button" class="popup-item" data-value="ㅗ">ㅗ</button>
                <button type="button" class="popup-item" data-value="ㅜ">ㅜ</button>
              </div>
            </div>
            <div class="pad-wrapper">
              <button class="pad jung glass" data-jamo="ㅡ" aria-label="땅 으">ㅡ</button>
              <div class="pad-popup glass">
                <button type="button" class="popup-item" data-value="ㅡ">ㅡ</button>
                <button type="button" class="popup-item" data-value="용" style="display: none;">—</button>
                <button type="button" class="popup-item" data-value="요">요</button>
                <button type="button" class="popup-item" data-value="ㅠ">ㅠ</button>
                <button type="button" class="popup-item" data-value="ㅢ">ㅢ</button>
              </div>
            </div>
            <div class="pad-wrapper">
              <button class="pad jung glass" data-jamo="ㅣ" aria-label="사람 이">ㅣ</button>
              <div class="pad-popup glass shift-left">
                <button type="button" class="popup-item" data-value="ㅣ">ㅣ</button>
                <button type="button" class="popup-item" data-value="애" style="display: none;">—</button>
                <button type="button" class="popup-item" data-value="ㅐ">ㅐ</button>
                <button type="button" class="popup-item" data-value="ㅔ">ㅔ</button>
                <button type="button" class="popup-item" data-value="ㅟ">ㅟ</button>
              </div>
            </div>
          </div>

          <!-- BGM 플레이어 위젯 -->
          <div class="music-player-widget glass">
            <div class="music-info">
              <span class="disc-icon" id="disc-icon">💿</span>
              <div class="track-details">
                <span class="track-title">K-POP Beat</span>
                <div id="playback-status" class="status-indicator">Stopped</div>
              </div>
            </div>
            <div class="player-controls">
              <div class="eq-container" id="eq-animation">
                <span class="eq-bar"></span>
                <span class="eq-bar"></span>
                <span class="eq-bar"></span>
                <span class="eq-bar"></span>
              </div>
              <button id="btn-toggle-bgm" class="player-btn" aria-label="Play beat">
                <span class="play-icon">▶</span>
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- 2단: 중간 제어 및 보조 세트 (자모 패드 아래로 내리고 크기 대폭 확장) -->
      <div class="keyboard-group-panel bottom-control-panel">
        <span class="panel-label">🎛️ 조작 컨트롤 (Controls)</span>
        <div class="bottom-controls-grid">
          <button id="btn-backspace" class="control-btn backspace-btn glass" title="글자 지우기">⌫ 지우기</button>
          <button id="btn-space" class="control-btn space-btn glass" title="띄어쓰기">␣ 띄어쓰기</button>
          <button id="btn-enter" class="control-btn enter-btn glass" title="글자 확정">↵ 확정</button>
          <button id="btn-speak-word" class="control-btn speak-btn glass" title="전체 문장 소리내기">🔊 전체 읽기</button>
          
          <!-- 마이크 버튼 및 언어 선택 바 -->
          <div class="mic-lang-row">
            <div class="lang-selector-bar glass">
              <button id="btn-lang-ko" class="lang-toggle-btn active">KO</button>
              <button id="btn-lang-en" class="lang-toggle-btn">EN</button>
            </div>
            
            <button id="btn-mic" class="mic-btn-fab">
              <div class="mic-glow-ring"></div>
              <span class="mic-icon">🎤 코치 마이크</span>
              <span id="mic-text" class="sr-only">{tr.groove_mic}</span>
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- AI 에이전트 피드백 영역 (맨 하단 배치로 키보드-조립판 밀착 극대화) -->
    <div class="agent-section glass">
      <div class="agent-avatar">🤖</div>
      <div class="agent-chat">
        <div class="chat-bubble" id="coach-bubble">
          안녕하세요! 소리 한글 (Sori Hangeul) 학습기에 오신 것을 환영합니다!
        </div>
      </div>
    </div>

    <!-- 🎮 콕핏 전체 화면 한글 그루브 아케이드 overlay -->
    <div id="game-arcade-screen" class="game-arcade-screen glass hidden">
      <!-- 이펙트 캔버스 (파티클, 레이저, 리플 효과 전용) -->
      <canvas id="arcade-fx-canvas"></canvas>

      <!-- 아케이드 헤더 -->
      <div class="arcade-header">
        <div class="arcade-header-left">
          <span class="arcade-neon-dot"></span>
          <span class="arcade-title">HANGEUL ARCADE</span>
        </div>
        <div class="arcade-header-right">
          <!-- 게임 플레이 도중 노출되는 스테이지 내비게이션 -->
          <div id="arcade-nav-controls" class="arcade-nav-controls hidden">
            <button id="btn-nav-lobby" class="nav-mini-btn glass" title="게임 목차로">목차 ☰</button>
            <button id="btn-nav-prev" class="nav-mini-btn glass" title="이전 게임">◀ 이전</button>
            <button id="btn-nav-next" class="nav-mini-btn glass" title="다음 게임">다음 ▶</button>
          </div>
          <button id="btn-arcade-close" class="action-mini-btn close-btn" title="콕핏으로 돌아가기">◀ CLOSE</button>
        </div>
      </div>

      <!-- 1. 아케이드 로비 (랜딩 화면) -->
      <div id="arcade-landing-view" class="arcade-view active">
        <div class="landing-glitch-title">
          <h1 class="glitch-text" data-text="SORI HANGEUL">SORI HANGEUL</h1>
          <p class="arcade-subtitle">SORI HANGEUL ARCADE</p>
        </div>

        <!-- 스코어 현황판 -->
        <div class="arcade-stats glass">
          <div class="stat-item">
            <span class="stat-lbl">STAGE HIGH SCORE</span>
            <span id="arcade-high-score" class="stat-val">00000</span>
          </div>
          <div class="stat-item">
            <span class="stat-lbl">TOTAL PLAYS</span>
            <span id="arcade-total-plays" class="stat-val">0</span>
          </div>
        </div>

        <!-- 스테이지 선택 리스트 -->
        <div class="stage-selection-list">
          <div class="stage-card active" data-stage="1" title="가획 수학 (Stroke Addition Math)">
            <div class="stage-img-wrapper">
              <img src="/images/arcade_stage1.png" alt="가획 수학" class="stage-img" />
              <div class="stage-number-badge">01</div>
            </div>
          </div>

          <div class="stage-card" data-stage="2" title="3D 기하 (3D Geometry Assembly)">
            <div class="stage-img-wrapper">
              <img src="/images/arcade_stage2.png" alt="3D 기하" class="stage-img" />
              <div class="stage-number-badge">02</div>
            </div>
          </div>

          <div class="stage-card" data-stage="3" title="우주 리듬 (Space Cosmic Rhythm)">
            <div class="stage-img-wrapper">
              <img src="/images/arcade_stage3.png" alt="우주 리듬" class="stage-img" />
              <div class="stage-number-badge">03</div>
            </div>
          </div>
        </div>
      </div>

      <!-- 2. 게임 플레이 화면 -->
      <div id="arcade-play-view" class="arcade-view">
        <!-- 상단 HUD 계기판 -->
        <div class="arcade-hud glass">
          <div class="hud-box">
            <span class="hud-lbl">SCORE</span>
            <span id="arcade-score" class="hud-val-neon">0</span>
          </div>
          <div class="hud-timer-box">
            <div class="hud-timer-progress" id="arcade-timer-bar"></div>
            <span id="arcade-timer-text">45s</span>
          </div>
          <div class="hud-box">
            <span class="hud-lbl">COMBO</span>
            <span id="arcade-combo" class="hud-val-neon">0</span>
          </div>
        </div>

        <!-- 메인 게임 영역 -->
        <div class="arcade-game-play-board">
          <!-- 2.1 가획의 과학 퍼즐 게임판 (Stage 1) -->
          <div id="play-stage-1" class="stage-play-content hidden">
            <div class="stage1-layout-container">
              <!-- 왼쪽: 단어 및 힌트 뷰 -->
              <div class="stage1-quiz-panel glass">
                <div id="stage1-image-box" class="stage1-image-box">🌸</div>
                <div id="stage1-target-word" class="stage1-target-word">꽃</div>
                <div id="stage1-pron-hint" class="stage1-pron-hint">KKOT</div>
                <div class="stage-help-container">
                  <button type="button" class="stage-help-trigger-btn glass" data-help-target="stage1-help">💡 게임 설명 보기</button>
                  <div id="stage1-help" class="stage-help-box glass hidden">
                    <strong>가획 수학 규칙</strong>: 왼쪽의 힌트 단어(예: 꽃)를 확인하고, 우측 식에서 기본 자음에 결합할 획(Stroke)을 아래 보기에서 찾아 클릭해 최종 자음을 완성하세요!
                  </div>
                </div>
              </div>
              
              <!-- 오른쪽: 획 추가 산식 뷰 -->
              <div class="stage1-math-panel glass">
                <div class="math-formula">
                  <span id="stage1-base-char" class="math-term neon-text-purple">ㄴ</span>
                  <span class="math-operator">+</span>
                  <span id="stage1-addition-char" class="math-term slot-blink">?</span>
                  <span class="math-operator">=</span>
                  <span id="stage1-result-char" class="math-term neon-text-cyan">ㄷ</span>
                </div>
                <!-- 획 선택지 영역 -->
                <div id="stage1-stroke-options" class="stage1-stroke-grid">
                  <!-- JS 동적 버튼 생성 -->
                </div>
              </div>
            </div>
          </div>

          <!-- 2.2 초/중/종성 3D 격자 조립 게임판 (Stage 2) -->
          <div id="play-stage-2" class="stage-play-content hidden">
            <div class="stage2-layout-container">
              <!-- 상단 자모 낙하 트랙 -->
