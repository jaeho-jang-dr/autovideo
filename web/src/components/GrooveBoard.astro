    { vowel: 'ㅗ', recipe: ['•', 'ㅡ'], display: '• + ㅡ' },
    { vowel: 'ㅜ', recipe: ['ㅡ', '•'], display: 'ㅡ + •' },
    { vowel: 'ㅑ', recipe: ['•', '•', 'ㅣ'], display: '• + • + ㅣ' },
    { vowel: 'ㅕ', recipe: ['ㅣ', '•', '•'], display: 'ㅣ + • + •' },
    { vowel: '요', recipe: ['•', '•', 'ㅡ'], display: '• + • + ㅡ' },
    { vowel: 'ㅠ', recipe: ['ㅡ', '•', '•'], display: 'ㅡ + • + •' },
    { vowel: 'ㅢ', recipe: ['ㅡ', 'ㅣ'], display: 'ㅡ + ㅣ' },
    { vowel: 'ㅘ', recipe: ['•', 'ㅡ', '•', 'ㅣ'], display: 'ㅗ + ㅏ' },
    { vowel: 'ㅝ', recipe: ['ㅡ', '•', 'ㅣ', '•'], display: 'ㅜ + ㅓ' }
  ];

  // 4. Global Game State
  const arcadeState = {
    isPlaying: false,
    currentStage: 1,
    score: 0,
    combo: 0,
    timeLeft: 45,
    maxTime: 45,
    timerId: null as number | null,
    highScore: 0,
    totalPlays: 0,
    
    // Stage 1 State
    s1Quiz: null as any,
    s1SelectedOption: null as string | null,

    // Stage 2 State
    s2Quiz: null as any,
    s2Assembly: { cho: '', jung: '', jong: '' } as Record<string, string>,
    s2FallingNode: null as { char: string, zone: 'cho' | 'jung' | 'jong', x: number, y: number, speed: number, el: HTMLDivElement } | null,
    s2LoopId: 0,

    // Stage 3 State
    s3Quiz: null as any,
    s3RecipeIndex: 0,
    s3Assembly: [] as string[],
    s3Particles: [] as Array<{ char: string, angle: number, radius: number, speed: number, el: HTMLDivElement }>,
    s3LoopId: 0
  };

  // BGM Trigger control
  function triggerGameBGM(play: boolean) {
    const bgmBtn = document.getElementById('btn-toggle-bgm');
    if (play && !isBgmPlaying) {
      bgmBtn?.click();
    } else if (!play && isBgmPlaying) {
      bgmBtn?.click();
    }
  }

  // 5. Lobby & Navigation Handling
  const btnArcadeStart = document.getElementById('btn-arcade-start');
  const btnArcadeClose = document.getElementById('btn-arcade-close');
  const lobbyView = document.getElementById('arcade-landing-view');
  const playView = document.getElementById('arcade-play-view');
  const gameOverView = document.getElementById('arcade-gameover-view');

  const stageCards = document.querySelectorAll('.stage-selection-list .stage-card');
  stageCards.forEach(card => {
    card.addEventListener('click', async () => {
      stageCards.forEach(c => c.classList.remove('active'));
      card.classList.add('active');
      const stg = parseInt(card.getAttribute('data-stage') || '1');
      arcadeState.currentStage = stg;
      
      // 카드 클릭 즉시 게임 오디오 활성화 및 기동!
      await ensureAudio();
      startArcadeGame();
    });
  });

  // stage-help-trigger-btn 토글 동작 추가
  const helpTriggerBtns = document.querySelectorAll('.stage-help-trigger-btn');
  helpTriggerBtns.forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation(); // prevent card/parent click side effects
      const targetId = btn.getAttribute('data-help-target');
      if (targetId) {
        const targetBox = document.getElementById(targetId);
        if (targetBox) {
          targetBox.classList.toggle('hidden');
        }
      }
    });
  });

  // 클릭 외부 시 도움말 닫히도록 바인딩
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (!target.closest('.stage-help-container')) {
      document.querySelectorAll('.stage-help-box').forEach(box => {
        box.classList.add('hidden');
      });
    }
  });

  // 이전 / 다음 / 목차 네비게이션 버튼 바인딩
  const btnNavLobby = document.getElementById('btn-nav-lobby');
  const btnNavPrev = document.getElementById('btn-nav-prev');
  const btnNavNext = document.getElementById('btn-nav-next');

  if (btnNavLobby) {
    btnNavLobby.addEventListener('click', () => {
      stopArcadeGame();
      if (playView) playView.classList.remove('active');
      if (gameOverView) gameOverView.classList.remove('active');
      if (lobbyView) lobbyView.classList.add('active');
    });
  }

  if (btnNavPrev) {
    btnNavPrev.addEventListener('click', () => {
      let prev = arcadeState.currentStage - 1;
      if (prev < 1) prev = 3;
      arcadeState.currentStage = prev;
      
      stageCards.forEach(c => {
        const stg = parseInt(c.getAttribute('data-stage') || '1');
        if (stg === prev) c.classList.add('active');
        else c.classList.remove('active');
      });

      startArcadeGame();
    });
  }

  if (btnNavNext) {
    btnNavNext.addEventListener('click', () => {
      let next = arcadeState.currentStage + 1;
      if (next > 3) next = 1;
      arcadeState.currentStage = next;

      stageCards.forEach(c => {
        const stg = parseInt(c.getAttribute('data-stage') || '1');
        if (stg === next) c.classList.add('active');
        else c.classList.remove('active');
      });

      startArcadeGame();
    });
  }

  if (btnArcadeStart) {
    btnArcadeStart.addEventListener('click', async () => {
      await ensureAudio();
      startArcadeGame();
    });
  }

  if (btnArcadeClose) {
    btnArcadeClose.addEventListener('click', () => {
      stopArcadeGame();

      // URL의 play=game 파라미터 안전하게 제거
      if (window.location.search.includes('play=game')) {
        const newUrl = window.location.pathname;
        window.history.pushState({}, '', newUrl);
      }

      const tabBtnLaunchpad = document.querySelector('.switcher-btn[data-mode="launchpad"]') as HTMLButtonElement;
      if (tabBtnLaunchpad) tabBtnLaunchpad.click();
    });
  }

  // High score init
  const savedHighScore = localStorage.getItem('hangeul_arcade_highscore');
  if (savedHighScore) {
    arcadeState.highScore = parseInt(savedHighScore);
    const scoreEl = document.getElementById('arcade-high-score');
    if (scoreEl) scoreEl.textContent = savedHighScore.padStart(5, '0');
  }

  // 6. Game Controls & Loops
  function startArcadeGame() {
    stopArcadeGame(); // clean up

    // UI View transition
    if (lobbyView) lobbyView.classList.remove('active');
    if (gameOverView) gameOverView.classList.remove('active');
    if (playView) playView.classList.add('active');

    // 내비게이션 컨트롤 노출
    const navControls = document.getElementById('arcade-nav-controls');
    if (navControls) navControls.classList.remove('hidden');

    // Show selected stage board
    document.getElementById('play-stage-1')?.classList.add('hidden');
    document.getElementById('play-stage-2')?.classList.add('hidden');
    document.getElementById('play-stage-3')?.classList.add('hidden');
    document.getElementById(`play-stage-${arcadeState.currentStage}`)?.classList.remove('hidden');

    // Hide all stage help boxes on start
    document.querySelectorAll('.stage-help-box').forEach(box => {
      box.classList.add('hidden');
    });

    // Init state
    arcadeState.isPlaying = true;
    arcadeState.score = 0;
    arcadeState.combo = 0;
    arcadeState.timeLeft = arcadeState.maxTime;

    updateHUD();

    // FX Canvas start
    if (!fxEngine) fxEngine = new CanvasFX();
    fxEngine.start();

    // Trigger Game BGM
    triggerGameBGM(true);

    // Increment Total Plays
    arcadeState.totalPlays++;
    const playsEl = document.getElementById('arcade-total-plays');
    if (playsEl) playsEl.textContent = String(arcadeState.totalPlays);

    // Launch Stage-specific loaders
    if (arcadeState.currentStage === 1) {
      loadStage1();
    } else if (arcadeState.currentStage === 2) {
      loadStage2();
    } else if (arcadeState.currentStage === 3) {
      loadStage3();
    }

    // HUD timer ticking
    arcadeState.timerId = window.setInterval(() => {
      arcadeState.timeLeft--;
      updateHUD();
      if (arcadeState.timeLeft <= 0) {
        endArcadeGame();
      }
    }, 1000) as any;
  }

  function stopArcadeGame() {
    arcadeState.isPlaying = false;
    if (arcadeState.timerId) {
      clearInterval(arcadeState.timerId);
      arcadeState.timerId = null;
    }
    if (fxEngine) fxEngine.stop();
    triggerGameBGM(false);

    // 내비게이션 컨트롤 숨김
    const navControls = document.getElementById('arcade-nav-controls');
    if (navControls) navControls.classList.add('hidden');

    // Clean Stage 2
    if (arcadeState.s2LoopId) {
      cancelAnimationFrame(arcadeState.s2LoopId);
      arcadeState.s2LoopId = 0;
    }
    if (arcadeState.s2FallingNode?.el) {
      arcadeState.s2FallingNode.el.remove();
      arcadeState.s2FallingNode = null;
    }
    const dropZone = document.getElementById('stage2-drop-zone');
    if (dropZone) {
      // Clear remaining DOM elements
      const items = dropZone.querySelectorAll('.stage2-node');
      items.forEach(it => it.remove());
    }

    // Clean Stage 3
    if (arcadeState.s3LoopId) {
      cancelAnimationFrame(arcadeState.s3LoopId);
      arcadeState.s3LoopId = 0;
    }
    const orbitRing = document.getElementById('stage3-orbit-ring');
    if (orbitRing) orbitRing.innerHTML = '';
  }

  function endArcadeGame() {
    stopArcadeGame();
    
    // View transitions
    if (playView) playView.classList.remove('active');
    if (gameOverView) gameOverView.classList.add('active');

    // Score calculations
    if (arcadeState.score > arcadeState.highScore) {
      arcadeState.highScore = arcadeState.score;
      localStorage.setItem('hangeul_arcade_highscore', String(arcadeState.highScore));
      const hsEl = document.getElementById('arcade-high-score');
      if (hsEl) hsEl.textContent = String(arcadeState.highScore).padStart(5, '0');
    }

    // Setup Receipt Printer details
    const receiptPaper = document.getElementById('arcade-receipt-paper');
    const rankBadge = document.getElementById('arcade-rank-badge');
    const stageNameEl = document.getElementById('gameover-stage-name');

    if (stageNameEl) {
      const stageTitles = [
        'STAGE 01: 가획의 과학',
        'STAGE 02: 한글 기하학',
        'STAGE 03: 천지인의 우주'
      ];
      stageNameEl.textContent = stageTitles[arcadeState.currentStage - 1] || 'GAME OVER';
    }

    // Compute Rank
    let rank = 'C';
    if (arcadeState.score >= 1200) rank = 'S';
    else if (arcadeState.score >= 800) rank = 'A';
    else if (arcadeState.score >= 400) rank = 'B';

    if (rankBadge) {
      rankBadge.textContent = rank;
      rankBadge.className = `rank-badge-neon rank-${rank.toLowerCase()}`;
    }

    if (receiptPaper) {
      receiptPaper.innerHTML = '';
      const lines = [
        '================================',
        '   HANGEUL COCKPIT ARCADE       ',
        '   MISSION SUMMARY REPORT       ',
        '================================',
        ` DATE: ${new Date().toLocaleDateString()}`,
        ` MISSION STAGE: 0${arcadeState.currentStage} `,
        ` FINAL SCORE:   ${arcadeState.score} PTS`,
        ` TOTAL COMBO:   ${arcadeState.combo} MAX`,
        ` EVALUATION:    RANK ${rank} `,
        '================================',
        '  STATUS: QUALIFIED / SYNCED    ',
        '  HANGEUL LEARNING COMPLETED    ',
        '================================'
      ];

      typewriterReceipt(lines, receiptPaper);
    }
  }

  function typewriterReceipt(lines: string[], container: HTMLElement) {
    let lineIdx = 0;
    
    function printLine() {
      if (lineIdx >= lines.length) return;
      const lineText = lines[lineIdx];
      const p = document.createElement('p');
      p.className = 'receipt-row';
      container.appendChild(p);

      let charIdx = 0;
      function printChar() {
        if (charIdx >= lineText.length) {
          lineIdx++;
          // Auto scroll to bottom
          container.scrollTop = container.scrollHeight;
          setTimeout(printLine, 120);
          return;
        }
        p.textContent += lineText[charIdx];
        charIdx++;
        playArcadeSound('tick');
        setTimeout(printChar, 18);
      }
      printChar();
    }
    printLine();
  }

  function updateHUD() {
    const scoreEl = document.getElementById('arcade-score');
    const comboEl = document.getElementById('arcade-combo');
    const timerText = document.getElementById('arcade-timer-text');
    const timerBar = document.getElementById('arcade-timer-bar');

    if (scoreEl) scoreEl.textContent = String(arcadeState.score);
    if (comboEl) comboEl.textContent = String(arcadeState.combo);
    if (timerText) timerText.textContent = `${arcadeState.timeLeft}s`;
    if (timerBar) {
      const pct = (arcadeState.timeLeft / arcadeState.maxTime) * 100;
      timerBar.style.width = `${pct}%`;
      // Warn under 10 seconds
      if (arcadeState.timeLeft <= 10) {
        timerBar.style.backgroundColor = 'hsl(343, 100%, 50%)';
      } else {
        timerBar.style.backgroundColor = '';
      }
    }
  }

  // 7. Stage 1 Logics (가획의 과학)
  function loadStage1() {
    // Pick random quiz
    const idx = Math.floor(Math.random() * STAGE1_QUIZZES.length);
    arcadeState.s1Quiz = STAGE1_QUIZZES[idx];
    arcadeState.s1SelectedOption = null;

    // Set UI elements
    const imgBox = document.getElementById('stage1-image-box');
    const wordEl = document.getElementById('stage1-target-word');
    const hintEl = document.getElementById('stage1-pron-hint');
    const baseChar = document.getElementById('stage1-base-char');
    const addChar = document.getElementById('stage1-addition-char');
    const resChar = document.getElementById('stage1-result-char');
    const optionsGrid = document.getElementById('stage1-stroke-options');

    if (imgBox) imgBox.textContent = arcadeState.s1Quiz.emoji;
    if (wordEl) wordEl.textContent = arcadeState.s1Quiz.targetWord;
    if (hintEl) hintEl.textContent = arcadeState.s1Quiz.targetEn;
    if (baseChar) baseChar.textContent = arcadeState.s1Quiz.base;
    if (addChar) {
      addChar.textContent = '?';
      addChar.className = 'math-term slot-blink';
    }
    if (resChar) resChar.textContent = arcadeState.s1Quiz.result;

    if (optionsGrid) {
      optionsGrid.innerHTML = '';
      // Prepare option strokes (always include the correct one)
      const correctStroke = arcadeState.s1Quiz.stroke;
      const candidates = ['•', 'ㅡ', 'ㅣ', 'ㄱ', 'ㄴ', 'ㅅ', 'ㅇ', 'ㄱ'].filter(c => c !== correctStroke);
      
      // Shuffle & Pick 3 incorrect options
      const incorrects = candidates.sort(() => 0.5 - Math.random()).slice(0, 3);
      const options = [correctStroke, ...incorrects].sort(() => 0.5 - Math.random());

      options.forEach(opt => {
        const btn = document.createElement('button');
        btn.className = 'stroke-opt-btn glass';
        btn.textContent = opt;
        btn.addEventListener('click', (e) => handleStage1Choice(opt, e.currentTarget as HTMLButtonElement));
        optionsGrid.appendChild(btn);
      });
    }
  }

  function handleStage1Choice(opt: string, btnEl: HTMLButtonElement) {
    if (!arcadeState.isPlaying || arcadeState.s1SelectedOption) return;

    const addChar = document.getElementById('stage1-addition-char');

    if (opt === arcadeState.s1Quiz.stroke) {
      // Correct!
      arcadeState.s1SelectedOption = opt;
      arcadeState.score += 100 + arcadeState.combo * 15;
      arcadeState.combo++;
      updateHUD();
      playArcadeSound('perfect');

      if (addChar) {
        addChar.textContent = opt;
        addChar.className = 'math-term neon-text-green';
      }

      // Draw Laser fusion rays from button to math slot
      if (fxEngine) {
        const r1 = btnEl.getBoundingClientRect();
        const r2 = addChar?.getBoundingClientRect();
        const pRect = fxEngine.canvas.parentElement?.getBoundingClientRect();
        if (r1 && r2 && pRect) {
          const x1 = r1.left + r1.width / 2 - pRect.left;
          const y1 = r1.top + r1.height / 2 - pRect.top;
          const x2 = r2.left + r2.width / 2 - pRect.left;
          const y2 = r2.top + r2.height / 2 - pRect.top;
          fxEngine.addLaser(x1, y1, x2, y2, 'hsl(180, 100%, 50%)');
          fxEngine.addExplosion(x2, y2, 'hsl(180, 100%, 70%)', 15);
        }
      }

      // Play vocal pronunciation for target
      playSentence(arcadeState.s1Quiz.targetWord);

      setTimeout(() => {
        loadStage1();
      }, 1300);

    } else {
      // Incorrect
      playArcadeSound('wrong');
      arcadeState.combo = 0;
      updateHUD();

      // Shake effect
      btnEl.classList.add('shake-danger');
      setTimeout(() => {
        btnEl.classList.remove('shake-danger');
      }, 500);
    }
  }

  // 8. Stage 2 Logics (3D 공간 기하학)
  function loadStage2() {
    const idx = Math.floor(Math.random() * STAGE2_QUIZZES.length);
    arcadeState.s2Quiz = STAGE2_QUIZZES[idx];
    
    // Clear slots
    arcadeState.s2Assembly = { cho: '', jung: '', jong: '' };
    
    const cellCho = document.getElementById('stage2-cell-cho');
    const cellJung = document.getElementById('stage2-cell-jung');
    const cellJong = document.getElementById('stage2-cell-jong');
    const wordBadge = document.getElementById('stage2-target-word');

    if (cellCho) cellCho.querySelector('.cell-val')!.textContent = '—';
    if (cellJung) cellJung.querySelector('.cell-val')!.textContent = '—';
    if (cellJong) cellJong.querySelector('.cell-val')!.textContent = '—';
    if (wordBadge) wordBadge.textContent = arcadeState.s2Quiz.word;

    // Reset loop
    if (arcadeState.s2LoopId) cancelAnimationFrame(arcadeState.s2LoopId);
    spawnFallingJamo();
    
    arcadeState.s2LoopId = requestAnimationFrame(stage2PhysicsLoop);
  }

  function spawnFallingJamo() {
    if (!arcadeState.isPlaying) return;

    // Determine what Jamo elements still need to be fitted
    const missing = [];
    if (!arcadeState.s2Assembly.cho) missing.push({ char: arcadeState.s2Quiz.cho, zone: 'cho' });
    if (!arcadeState.s2Assembly.jung) missing.push({ char: arcadeState.s2Quiz.jung, zone: 'jung' });
    if (!arcadeState.s2Assembly.jong && arcadeState.s2Quiz.jong) missing.push({ char: arcadeState.s2Quiz.jong, zone: 'jong' });

    if (missing.length === 0) {
      // Syllable completed!
      arcadeState.score += 250 + arcadeState.combo * 20;
      arcadeState.combo++;
      updateHUD();
      playArcadeSound('perfect');
      playSentence(arcadeState.s2Quiz.word);

      // Trigger massive ripple
      if (fxEngine) {
        fxEngine.addRipple(fxEngine.width / 2, fxEngine.height / 2, 'hsl(180, 100%, 50%)');
      }

      setTimeout(() => {
        loadStage2();
      }, 1500);
      return;
    }

    // Pick one missing target OR a distractor Jamo
    let target = missing[Math.floor(Math.random() * missing.length)];
    // 25% chance of spawning a random distractor consonant/vowel
    if (Math.random() < 0.25) {
      const distractors = ['ㅁ', 'ㅂ', 'ㅅ', 'ㅇ', 'ㅈ', 'ㅊ', 'ㅋ', 'ㅌ', 'ㅗ', 'ㅜ', 'ㅡ', 'ㅣ'];
      const randChar = distractors[Math.floor(Math.random() * distractors.length)];
      // Check if it matches any of the target zones, if not, it is a true distractor
      let matchingZone: any = null;
      if (randChar === arcadeState.s2Quiz.cho && !arcadeState.s2Assembly.cho) matchingZone = 'cho';
      else if (randChar === arcadeState.s2Quiz.jung && !arcadeState.s2Assembly.jung) matchingZone = 'jung';
      else if (randChar === arcadeState.s2Quiz.jong && !arcadeState.s2Assembly.jong) matchingZone = 'jong';
      
      target = { char: randChar, zone: matchingZone || 'cho' }; // fallback zone
    }

    const dropZone = document.getElementById('stage2-drop-zone');
    if (dropZone) {
      const el = document.createElement('div');
      el.className = 'stage2-node glass';
      el.textContent = target.char;
      dropZone.appendChild(el);

      const zoneWidth = dropZone.clientWidth;
      const xPos = Math.random() * (zoneWidth - 60) + 10;
      el.style.left = `${xPos}px`;
      el.style.top = '0px';

      arcadeState.s2FallingNode = {
        char: target.char,
        zone: target.zone as any,
        x: xPos,
        y: 0,
        speed: Math.random() * 0.8 + 1.2, // falling speed pixels per frame
        el
      };
    }
  }

  function stage2PhysicsLoop() {
    if (!arcadeState.isPlaying || arcadeState.currentStage !== 2) return;

    const node = arcadeState.s2FallingNode;
    if (node) {
      node.y += node.speed;
      node.el.style.top = `${node.y}px`;

      const limit = 260; // baseline height inside CSS height limits
      if (node.y >= limit) {
        // Crash / Ground hit
        node.el.classList.add('explode-out');
        playArcadeSound('bad');
        arcadeState.combo = 0;
        updateHUD();
        
        if (fxEngine) {
          fxEngine.addExplosion(node.x + 25, node.y + 25, 'hsl(0, 80%, 50%)', 10);
        }

        setTimeout(() => {
          node.el.remove();
          arcadeState.s2FallingNode = null;
          spawnFallingJamo();
        }, 300);
      }
    }

    arcadeState.s2LoopId = requestAnimationFrame(stage2PhysicsLoop);
  }

  function launchFallingNode(zone: 'cho' | 'jung' | 'jong') {
    const node = arcadeState.s2FallingNode;
    if (!node || !arcadeState.isPlaying) return;

    // Check if the node is correct for this zone
    let isCorrect = false;
    if (zone === 'cho' && node.char === arcadeState.s2Quiz.cho && !arcadeState.s2Assembly.cho) isCorrect = true;
    else if (zone === 'jung' && node.char === arcadeState.s2Quiz.jung && !arcadeState.s2Assembly.jung) isCorrect = true;
    else if (zone === 'jong' && node.char === arcadeState.s2Quiz.jong && !arcadeState.s2Assembly.jong) isCorrect = true;

    if (isCorrect) {
      // Fit in target cell
      arcadeState.s2Assembly[zone] = node.char;
      const targetCell = document.getElementById(`stage2-cell-${zone}`);
      if (targetCell) {
        targetCell.querySelector('.cell-val')!.textContent = node.char;
        targetCell.classList.add('pulse-active');
        setTimeout(() => targetCell.classList.remove('pulse-active'), 500);
      }

      // Draw particle trails snapping it in
      if (fxEngine) {
        const r1 = node.el.getBoundingClientRect();
        const r2 = targetCell?.getBoundingClientRect();
        const pRect = fxEngine.canvas.parentElement?.getBoundingClientRect();
        if (r1 && r2 && pRect) {
          const x1 = r1.left + r1.width / 2 - pRect.left;
          const y1 = r1.top + r1.height / 2 - pRect.top;
          const x2 = r2.left + r2.width / 2 - pRect.left;
          const y2 = r2.top + r2.height / 2 - pRect.top;
          fxEngine.addLaser(x1, y1, x2, y2, 'hsl(120, 100%, 40%)');
          fxEngine.addExplosion(x2, y2, 'hsl(120, 100%, 60%)', 12);
        }
      }

      playArcadeSound('good');
      node.el.remove();
      arcadeState.s2FallingNode = null;

      // Spawn next
      setTimeout(() => {
        spawnFallingJamo();
      }, 300);
    } else {
      // Wrong placement / Deflect away
      playArcadeSound('wrong');
      arcadeState.combo = 0;
      updateHUD();

      // Bounce/Slide out FX
      node.speed = -3.0; // reverse motion
      if (fxEngine) {
        fxEngine.addRipple(node.x + 25, node.y + 25, 'hsl(340, 100%, 50%)');
      }

      node.el.classList.add('deflected');
      setTimeout(() => {
        node.el.remove();
        arcadeState.s2FallingNode = null;
        spawnFallingJamo();
      }, 500);
    }
  }

  // Stage 2 Click binding
  const stage2Btns = document.querySelectorAll('.stage2-launch-btn');
  stage2Btns.forEach(btn => {
    btn.addEventListener('click', () => {
      const z = btn.getAttribute('data-zone') as any;
      launchFallingNode(z);
    });
  });

  // 9. Stage 3 Logics (천지인의 우주)
  function loadStage3() {
    const idx = Math.floor(Math.random() * STAGE3_QUIZZES.length);
    arcadeState.s3Quiz = STAGE3_QUIZZES[idx];
    arcadeState.s3RecipeIndex = 0;
    arcadeState.s3Assembly = [];

    const vowelLabel = document.getElementById('stage3-target-vowel');
    const recipeLabel = document.getElementById('stage3-vowel-recipe');
    const assemblyCore = document.getElementById('stage3-current-assembly');

    if (vowelLabel) vowelLabel.textContent = arcadeState.s3Quiz.vowel;
    if (recipeLabel) recipeLabel.textContent = arcadeState.s3Quiz.display;
    if (assemblyCore) assemblyCore.textContent = '—';

    // Clear old orbit items
    const orbitRing = document.getElementById('stage3-orbit-ring');
    if (orbitRing) orbitRing.innerHTML = '';

    // Create 3 rotating particles (Cheon •, Ji ㅡ, In ㅣ)
    const elements = [
      { char: '•', color: 'hsl(180, 100%, 65%)' },
      { char: 'ㅡ', color: 'hsl(280, 100%, 70%)' },
      { char: 'ㅣ', color: 'hsl(340, 100%, 65%)' }
    ];

    arcadeState.s3Particles = elements.map((el, i) => {
      const div = document.createElement('div');
      div.className = 'orbit-particle glass';
      div.textContent = el.char;
      div.style.borderColor = el.color;
      div.style.boxShadow = `0 0 10px ${el.color}`;
      orbitRing?.appendChild(div);

      return {
        char: el.char,
        angle: (i * (Math.PI * 2)) / 3, // evenly space out
        radius: 88, // orbit radius matching CSS layout
        speed: 0.035, // constant angular velocity
        el: div
      } as any;
    });

    if (arcadeState.s3LoopId) cancelAnimationFrame(arcadeState.s3LoopId);
    arcadeState.s3LoopId = requestAnimationFrame(stage3PhysicsLoop);
  }

  function stage3PhysicsLoop() {
    if (!arcadeState.isPlaying || arcadeState.currentStage !== 3) return;

    // Center coordinates
    const orbitRing = document.getElementById('stage3-orbit-ring');
    const cX = (orbitRing?.clientWidth || 220) / 2;
    const cY = (orbitRing?.clientHeight || 220) / 2;

    arcadeState.s3Particles.forEach((p: any) => {
      p.angle += p.speed;
      // Position calculation
      const x = cX + Math.cos(p.angle) * p.radius - 20; // 20 is half size
      const y = cY + Math.sin(p.angle) * p.radius - 20;
      
      p.el.style.left = `${x}px`;
      p.el.style.top = `${y}px`;

      // Visual highlight when crossing 12 o'clock ring (angle approx -Math.PI/2 or 1.5 * Math.PI)
      const normAngle = ((p.angle % (Math.PI * 2)) + (Math.PI * 2)) % (Math.PI * 2);
      const targetAngle = 1.5 * Math.PI; // 12 o'clock in Canvas coordinate (270 deg)
      const diff = Math.abs(normAngle - targetAngle);
      
      if (diff < 0.25 || diff > (Math.PI * 2 - 0.25)) {
        p.el.classList.add('in-hit-zone');
      } else {
        p.el.classList.remove('in-hit-zone');
      }
    });

    arcadeState.s3LoopId = requestAnimationFrame(stage3PhysicsLoop);
  }

  function triggerBeatTap() {
    if (!arcadeState.isPlaying || arcadeState.currentStage !== 3) return;

    const orbitRing = document.getElementById('stage3-orbit-ring');
    const cX = (orbitRing?.clientWidth || 220) / 2;
    const cY = (orbitRing?.clientHeight || 220) / 2;

    // 12 o'clock target angles (1.5 * Math.PI)
    const targetAngle = 1.5 * Math.PI;
    let bestMatch: any = null;
    let minDiff = Infinity;

    arcadeState.s3Particles.forEach((p: any) => {
      const normAngle = ((p.angle % (Math.PI * 2)) + (Math.PI * 2)) % (Math.PI * 2);
      let diff = Math.abs(normAngle - targetAngle);
      if (diff > Math.PI) diff = Math.PI * 2 - diff; // wrap around
      
      if (diff < minDiff) {
        minDiff = diff;
        bestMatch = p;
      }
    });

    const judgmentText = document.getElementById('stage3-judgment-text');
    const assemblyCore = document.getElementById('stage3-current-assembly');
    const expected = arcadeState.s3Quiz.recipe[arcadeState.s3RecipeIndex];

    if (!bestMatch) return;

    // Visual feedback ring glow
    const perfRing = document.getElementById('stage3-perfect-ring');
    if (perfRing) {
      perfRing.classList.add('hit-pulse');
      setTimeout(() => perfRing.classList.remove('hit-pulse'), 200);
    }

    // Determine timing category
    let rating = 'MISS';
    let timingColor = 'hsl(340, 100%, 50%)';

    if (minDiff < 0.25) {
      rating = 'PERFECT';
      timingColor = 'hsl(180, 100%, 55%)';
    } else if (minDiff < 0.48) {
      rating = 'GOOD';
      timingColor = 'hsl(120, 100%, 50%)';
    }

    if (rating === 'MISS') {
      // Beat miss
      playArcadeSound('bad');
      if (judgmentText) {
        judgmentText.textContent = 'BAD TIMING!';
        judgmentText.style.color = timingColor;
      }
      arcadeState.combo = 0;
      updateHUD();
      return;
    }

    // Timing is ok, check if the particle is the correct recipe element
    if (bestMatch.char === expected) {
      // Synthesized successfully!
      arcadeState.s3RecipeIndex++;
      arcadeState.s3Assembly.push(bestMatch.char);
      arcadeState.score += 80 + arcadeState.combo * 10;
      arcadeState.combo++;
      updateHUD();

      // Show in nucleus
      if (assemblyCore) assemblyCore.textContent = arcadeState.s3Assembly.join(' + ');

      if (judgmentText) {
        judgmentText.textContent = `${rating} SYNTHESIS!`;
        judgmentText.style.color = timingColor;
      }

      playArcadeSound(rating === 'PERFECT' ? 'perfect' : 'good');

      // Draw Laser fusion from particle to center core
      if (fxEngine) {
        const pRect = fxEngine.canvas.parentElement?.getBoundingClientRect();
        if (pRect) {
          const r1 = bestMatch.el.getBoundingClientRect();
          const r2 = document.getElementById('stage3-nucleus')?.getBoundingClientRect();
          if (r1 && r2) {
            const x1 = r1.left + r1.width / 2 - pRect.left;
            const y1 = r1.top + r1.height / 2 - pRect.top;
            const x2 = r2.left + r2.width / 2 - pRect.left;
            const y2 = r2.top + r2.height / 2 - pRect.top;
            fxEngine.addLaser(x1, y1, x2, y2, bestMatch.el.style.borderColor || 'cyan');
            fxEngine.addExplosion(x2, y2, 'cyan', 12);
          }
        }
      }

      // Check if vowel recipe is complete
      if (arcadeState.s3RecipeIndex >= arcadeState.s3Quiz.recipe.length) {
        // Synthesizer fully completed!
        playSentence(arcadeState.s3Quiz.vowel);
        
        if (assemblyCore) {
          assemblyCore.textContent = `★ ${arcadeState.s3Quiz.vowel} ★`;
          assemblyCore.classList.add('pulse-completed');
        }

        if (fxEngine) {
          fxEngine.addRipple(cX, cY, 'hsl(280, 100%, 65%)');
        }

        setTimeout(() => {
          if (assemblyCore) assemblyCore.classList.remove('pulse-completed');
          loadStage3();
        }, 1300);
      }
    } else {
      // Wrong particle tapped
      playArcadeSound('wrong');
      if (judgmentText) {
        judgmentText.textContent = `WRONG CHEMICAL! (Expected: ${expected})`;
        judgmentText.style.color = 'hsl(340, 100%, 50%)';
      }
      arcadeState.combo = 0;
      updateHUD();
      
      // Deflect animation
      bestMatch.el.classList.add('shake-danger');
      setTimeout(() => bestMatch.el.classList.remove('shake-danger'), 300);
    }
  }

  // Stage 3 Beat button bind
  const btnBeatTap = document.getElementById('btn-stage3-beat-tap');
  if (btnBeatTap) {
    btnBeatTap.addEventListener('click', triggerBeatTap);
  }

  // 10. Global Keyboard Shortcuts Handler
  window.addEventListener('keydown', (e) => {
    if (!arcadeState.isPlaying) return;

    // Spacebar triggers Beat Tap in Stage 3
    if (e.code === 'Space' || e.key === ' ') {
      if (arcadeState.currentStage === 3) {
        e.preventDefault();
        triggerBeatTap();
      }
    }

    // Keys 1, 2, 3 trigger Stage 2 directional launches
    if (arcadeState.currentStage === 2) {
      if (e.key === '1') {
        launchFallingNode('cho');
      } else if (e.key === '2') {
        launchFallingNode('jung');
      } else if (e.key === '3') {
        launchFallingNode('jong');
      }
    }
  });

  // Game over play again action
  const btnRestart = document.getElementById('btn-gameover-restart');
  const btnLobby = document.getElementById('btn-gameover-lobby');

  if (btnRestart) {
    btnRestart.addEventListener('click', () => {
      startArcadeGame();
    });
  }

  if (btnLobby) {
    btnLobby.addEventListener('click', () => {
      if (gameOverView) gameOverView.classList.remove('active');
      if (lobbyView) lobbyView.classList.add('active');
    });
  }

  // 구버전 모니터 뷰의 🚀 Game Start 버튼 클릭 시에도 신규 아케이드 오버레이 띄우기 연동
  const oldGameToggleBtn = document.getElementById('btn-game-toggle');
  if (oldGameToggleBtn) {
    oldGameToggleBtn.addEventListener('click', () => {
      const tabBtnGame = document.querySelector('.switcher-btn[data-mode="game"]') as HTMLButtonElement;
      if (tabBtnGame) {
        tabBtnGame.click();
      }
    });
  }

  // URL Query Parameter ?play=game 감지 시 자동 실행 연동
  const urlParams = new URLSearchParams(window.location.search);
  if (urlParams.get('play') === 'game') {
    setTimeout(() => {
      const tabBtnGame = document.querySelector('.switcher-btn[data-mode="game"]') as HTMLButtonElement;
      if (tabBtnGame) {
        tabBtnGame.click();
      }
    }, 150);
  }
</script>
