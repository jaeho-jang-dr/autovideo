  // 기계음의 발음 교정을 위해 대표 변음 단어들을 기계음에 전달하기 전 발음 텍스트로 치환하는 헬퍼 함수
  function getPhoneticSubstitute(text: string): string {
    let processed = text;
    // 발음 치환 테이블 정의 (기계음 SpeechSynthesis 오독 방지 및 연음 구현용)
    const SUBSTITUTE_MAP: Record<string, string> = {
      '값이': '갑시',
      '읽는다': '익는다',
      '굳이': '구지',
      '같이': '가치',
      '돋보기': '돋뽀기',
      '꽃이': '꼬치',
      '맛있어요': '마시써요',
      '합니다': '함미다',
      '국물': '궁물',
      '밥 먹어요': '밤머거요',
      '신라': '실라',
      '칼날': '칼랄',
      '독립': '동닙',
      '백마': '뱅마',
      '국민': '궁민',
      '낱낱이': '난나치',
      '맏이': '마지',
      '해돋이': '해도지',
      '끝이': '끄치',
      '붙여': '부쳐'
    };

    // 가장 긴 키를 먼저 치환하여 중복 치환 간섭 최소화
    const sortedKeys = Object.keys(SUBSTITUTE_MAP).sort((a, b) => b.length - a.length);
    for (const key of sortedKeys) {
      if (processed.includes(key)) {
        processed = processed.replace(new RegExp(key, 'g'), SUBSTITUTE_MAP[key]);
      }
    }
    return processed;
  }

  // 문장 전체를 일반 구어체 속도로 자연스럽게 연음 법칙을 살려 성우 목소리(gTTS)로 낭독하는 함수
  let currentSentenceAudio: HTMLAudioElement | null = null;
  async function speakSentenceNatural(text: string) {
    if (currentSentenceAudio) {
      currentSentenceAudio.pause();
      currentSentenceAudio = null;
    }

    if (!text.trim()) return;
    
    const phoneticText = getPhoneticSubstitute(text);
    const audioUrl = `/audio/jamo/${encodeURIComponent(phoneticText)}.mp3`;
    const audio = new Audio(audioUrl);
    
    currentSentenceAudio = audio;
    audio.volume = 0.85;

    let fallbackTriggered = false;

    audio.addEventListener('error', async () => {
      if (fallbackTriggered) return;
      fallbackTriggered = true;
      
      try {
        const response = await fetch('/api/generate-tts', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ text: phoneticText })
        });
        const result = await response.json();
        if (result.success) {
          DYNAMIC_AUDIO_CACHE.add(phoneticText);
          console.log(`[Sori Hangeul] Successfully generated dynamic gTTS for sentence: [${phoneticText}]`);
          const newAudio = new Audio(audioUrl);
          currentSentenceAudio = newAudio;
          newAudio.volume = 0.85;
          newAudio.play().catch(e => console.warn("Failed to play newly generated sentence:", e));
        }
      } catch (e) {
        console.error("Failed to dynamically generate sentence audio:", e);
      }
    });

    audio.play().catch(err => {
      if (!fallbackTriggered) {
        audio.dispatchEvent(new Event('error'));
      }
    });
  }

