  // ── 한글 아케이드 게임 엔진 (Arcade Engine Stage 1, 2, 3) ──

  // 1. Web Audio API SFX Synth
  function playArcadeSound(type: string) {
    if (!audioCtx) return;
    if (audioCtx.state === 'suspended') {
      audioCtx.resume();
    }
    const now = audioCtx.currentTime;

    if (type === 'perfect') {
      // Bright C-major arpeggio C5 -> E5 -> G5 -> C6
      const freqs = [523.25, 659.25, 783.99, 1046.50];
      freqs.forEach((freq, idx) => {
        const osc = audioCtx!.createOscillator();
        const gain = audioCtx!.createGain();
        osc.type = 'sine';
        osc.frequency.setValueAtTime(freq, now + idx * 0.07);
        
        gain.gain.setValueAtTime(0.15, now + idx * 0.07);
        gain.gain.exponentialRampToValueAtTime(0.001, now + idx * 0.07 + 0.25);
        
        osc.connect(gain);
        gain.connect(audioCtx!.destination);
        osc.start(now + idx * 0.07);
        osc.stop(now + idx * 0.07 + 0.25);
      });
    } else if (type === 'good') {
      // E5 -> G5
      const freqs = [659.25, 783.99];
      freqs.forEach((freq, idx) => {
        const osc = audioCtx!.createOscillator();
        const gain = audioCtx!.createGain();
        osc.type = 'sine';
        osc.frequency.setValueAtTime(freq, now + idx * 0.08);
        
        gain.gain.setValueAtTime(0.12, now + idx * 0.08);
        gain.gain.exponentialRampToValueAtTime(0.001, now + idx * 0.08 + 0.2);
        
        osc.connect(gain);
        gain.connect(audioCtx!.destination);
        osc.start(now + idx * 0.08);
        osc.stop(now + idx * 0.08 + 0.2);
      });
    } else if (type === 'bad' || type === 'wrong') {
      // Low synth fall (Sawtooth E2 -> C2)
      const osc = audioCtx.createOscillator();
      const gain = audioCtx.createGain();
      osc.type = 'sawtooth';
      osc.frequency.setValueAtTime(164.81, now);
      osc.frequency.linearRampToValueAtTime(65.41, now + 0.25);
      
      gain.gain.setValueAtTime(0.2, now);
      gain.gain.linearRampToValueAtTime(0.001, now + 0.25);
      
      osc.connect(gain);
      gain.connect(audioCtx.destination);
      osc.start(now);
      osc.stop(now + 0.25);
    } else if (type === 'tick') {
      // Clicking noise for typewriter
      const osc = audioCtx.createOscillator();
      const gain = audioCtx.createGain();
      osc.type = 'triangle';
      osc.frequency.setValueAtTime(1000, now);
      osc.frequency.exponentialRampToValueAtTime(150, now + 0.015);
      
      gain.gain.setValueAtTime(0.08, now);
      gain.gain.exponentialRampToValueAtTime(0.001, now + 0.015);
      
      osc.connect(gain);
      gain.connect(audioCtx.destination);
      osc.start(now);
      osc.stop(now + 0.015);
    }
  }

  // Global Canvas FX Engine Variable
  let fxEngine: CanvasFX | null = null;

  // 2. 2D Canvas FX Engine
  class CanvasFX {
    canvas: HTMLCanvasElement;
    ctx: CanvasRenderingContext2D;
    particles: Array<{ x: number, y: number, vx: number, vy: number, size: number, color: string, alpha: number, decay: number }> = [];
    beams: Array<{ x1: number, y1: number, x2: number, y2: number, color: string, alpha: number, width: number, decay: number }> = [];
    ripples: Array<{ x: number, y: number, radius: number, maxRadius: number, color: string, alpha: number, decay: number }> = [];
    width = 0;
    height = 0;
    active = false;
    animFrameId = 0;

    constructor() {
      this.canvas = document.getElementById('arcade-fx-canvas') as HTMLCanvasElement;
      this.ctx = this.canvas.getContext('2d')!;
      this.resize();
      window.addEventListener('resize', () => this.resize());
    }

    resize() {
      if (!this.canvas) return;
      const parent = this.canvas.parentElement;
      if (parent) {
        this.width = parent.clientWidth;
        this.height = parent.clientHeight;
        this.canvas.width = this.width;
        this.canvas.height = this.height;
      }
    }

    start() {
      this.active = true;
      this.particles = [];
      this.beams = [];
      this.ripples = [];
      this.resize();
      this.loop();
    }

    stop() {
      this.active = false;
      if (this.animFrameId) {
        cancelAnimationFrame(this.animFrameId);
      }
      this.ctx.clearRect(0, 0, this.width, this.height);
    }

    addExplosion(x: number, y: number, color: string, count = 18) {
      for (let i = 0; i < count; i++) {
        const angle = Math.random() * Math.PI * 2;
        const speed = Math.random() * 4 + 2;
        this.particles.push({
          x, y,
          vx: Math.cos(angle) * speed,
          vy: Math.sin(angle) * speed,
          size: Math.random() * 3 + 2,
          color,
          alpha: 1.0,
          decay: Math.random() * 0.04 + 0.015
        });
      }
    }

    addLaser(x1: number, y1: number, x2: number, y2: number, color: string) {
      this.beams.push({
        x1, y1, x2, y2,
        color,
        alpha: 1.0,
        width: 5,
        decay: 0.08
      });
    }

    addRipple(x: number, y: number, color: string) {
      this.ripples.push({
        x, y,
        radius: 6,
        maxRadius: 70,
        color,
        alpha: 1.0,
        decay: 0.04
      });
    }

    loop = () => {
      if (!this.active) return;
      this.ctx.clearRect(0, 0, this.width, this.height);

      // Render ripples
      this.ripples = this.ripples.filter(r => {
        r.radius += (r.maxRadius - r.radius) * 0.12;
        r.alpha -= r.decay;
        if (r.alpha <= 0) return false;
        this.ctx.strokeStyle = r.color;
        this.ctx.globalAlpha = r.alpha;
        this.ctx.lineWidth = 3;
        this.ctx.beginPath();
        this.ctx.arc(r.x, r.y, r.radius, 0, Math.PI * 2);
        this.ctx.stroke();
        return true;
      });

      // Render beams
      this.beams = this.beams.filter(b => {
        b.alpha -= b.decay;
        if (b.alpha <= 0) return false;
        this.ctx.strokeStyle = b.color;
        this.ctx.globalAlpha = b.alpha;
        this.ctx.lineWidth = b.width * b.alpha;
        this.ctx.beginPath();
        this.ctx.moveTo(b.x1, b.y1);
        this.ctx.lineTo(b.x2, b.y2);
        this.ctx.stroke();
        return true;
      });

      // Render particles
      this.particles = this.particles.filter(p => {
        p.x += p.vx;
        p.y += p.vy;
        p.vy += 0.08; // gravity
        p.alpha -= p.decay;
        if (p.alpha <= 0) return false;
        this.ctx.fillStyle = p.color;
        this.ctx.globalAlpha = p.alpha;
        this.ctx.beginPath();
        this.ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
        this.ctx.fill();
        return true;
      });

      this.ctx.globalAlpha = 1.0;
      this.animFrameId = requestAnimationFrame(this.loop);
    }
  }

