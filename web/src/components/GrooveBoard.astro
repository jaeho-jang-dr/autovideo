  // 자음 직접 선택 처리 (D-pad 팝업 메뉴용)
  async function selectConsonantDirectly(baseJamo: string, selectedJamo: string) {
    try {
      await ensureAudio();
    } catch (err) {
      console.warn("AudioContext init failed:", err);
    }
    
    const cycle = CONSONANT_CYCLES[baseJamo];
    if (!cycle) return;
    const targetIdx = cycle.indexOf(selectedJamo);
    if (targetIdx === -1) return;

    if (!state.jung) {
      // 초성(cho) 직접 지정
      state.cho = selectedJamo;
      state.jamoSeq = [];
      state.jung = null;
      state.jong = null;
      state.lastPadType = 'cho';
      state.lastPadValue = baseJamo;
      state.cycleIdx = targetIdx;
    } else {
      // 종성(jong) 직접 지정 및 복자음 합성
      state.jong = selectedJamo;
      state.lastPadType = 'jong';
      state.lastPadValue = baseJamo;
      state.cycleIdx = targetIdx;
    }

    speakKo(selectedJamo);
    showAnatomy(baseJamo);
    updateDisplay();
    scheduleCommit();
  }

  // 모음 직접 선택 처리 (Cheon-Ji-In 팝업 메뉴용)
  async function selectVowelDirectly(vowelChar: string) {
    try {
      await ensureAudio();
    } catch (err) {
      console.warn("AudioContext init failed:", err);
    }

    if (state.cho && state.jong) {
      // 종성에서 모음으로 연음 전환
      const prevJong = state.jong;
      if (DECOMPOSE_JONG_MAP[prevJong]) {
        const [first, second] = DECOMPOSE_JONG_MAP[prevJong];
        state.word += String.fromCharCode(
          0xAC00 + (CHO_LIST.indexOf(state.cho) * 21 + JUNG_LIST.indexOf(state.jung!)) * 28 + JONG_LIST.indexOf(first)
        );
        state.cho = second;
      } else {
        const text = renderSyllable();
        if (text !== '—') state.word += text;
        state.cho = prevJong;
      }
      state.jamoSeq = VOWEL_TO_SEQ_MAP[vowelChar] ? [...VOWEL_TO_SEQ_MAP[vowelChar]] : [vowelChar];
      state.jung = vowelChar;
      state.jong = null;
      state.lastPadType = 'jung';
      state.lastPadValue = vowelChar;
      state.cycleIdx = 0;
    } else if (state.cho) {
      state.jamoSeq = VOWEL_TO_SEQ_MAP[vowelChar] ? [...VOWEL_TO_SEQ_MAP[vowelChar]] : [vowelChar];
      state.jung = vowelChar;
      state.lastPadType = 'jung';
      state.lastPadValue = vowelChar;
      state.cycleIdx = 0;
    } else {
      state.cho = 'ㅇ';
      state.jamoSeq = VOWEL_TO_SEQ_MAP[vowelChar] ? [...VOWEL_TO_SEQ_MAP[vowelChar]] : [vowelChar];
      state.jung = vowelChar;
      state.jong = null;
      state.lastPadType = 'jung';
      state.lastPadValue = vowelChar;
      state.cycleIdx = 0;
    }

    speakKo(vowelChar);
    updateDisplay();
    scheduleCommit();
  }

  // 팝업은 길게 눌렀을 때만 활성화 (호버 리스너 제거 완료)

  // 팝업 내부 개별 자소 아이템 클릭 시 처리
  const popupItems = document.querySelectorAll('.popup-item');
  popupItems.forEach(item => {
    // 롱프레스 텍스트 복사/선택 및 컨텍스트 메뉴 차단
    item.addEventListener('contextmenu', (e) => e.preventDefault());
    item.addEventListener('selectstart', (e) => e.preventDefault());

    item.addEventListener('click', (e) => {
      e.stopPropagation(); // 부모 패드의 일반 순환 클릭 동작 방지
      const value = item.getAttribute('data-value') || '';
      const parentPad = item.closest('.pad-wrapper')?.querySelector('.pad') as HTMLButtonElement | null;
      if (!parentPad) return;

      const isCho = parentPad.classList.contains('cho');
      const baseJamo = parentPad.getAttribute('data-jamo') || '';

      if (isCho) {
        selectConsonantDirectly(baseJamo, value);
      } else {
        selectVowelDirectly(value);
      }

      // 선택 후 팝업 닫기 및 롱프레스 상태 속성 초기화
      parentPad.removeAttribute('data-long-pressed');
      item.closest('.pad-popup')?.classList.remove('active');
    });
  });

  // 팝업 컨테이너 자체도 복사/선택 및 컨텍스트 메뉴 차단
  document.querySelectorAll('.pad-popup').forEach(popup => {
    popup.addEventListener('contextmenu', (e) => e.preventDefault());
    popup.addEventListener('selectstart', (e) => e.preventDefault());
  });

  // 화면 외부 클릭 시 모든 팝업 일괄 닫기 및 롱프레스 락 초기화
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (!target.closest('.pad-wrapper')) {
      document.querySelectorAll('.pad-popup').forEach(p => p.classList.remove('active'));
      document.querySelectorAll('.pad').forEach(p => p.removeAttribute('data-long-pressed'));
    }
  });

  // 패드 이벤트 바인딩 (Pointerdown 롱프레스 + Click/더블탭 순환 오토마타)
  const pads = document.querySelectorAll('.pad');
  pads.forEach(p => {
    const btn = p as HTMLButtonElement;

    // 롱프레스 텍스트 복사/선택 및 컨텍스트 메뉴 차단
    btn.addEventListener('contextmenu', (e) => e.preventDefault());
    btn.addEventListener('selectstart', (e) => e.preventDefault());

    // Pointerdown: 롱프레스 1초 감지 작동
    btn.addEventListener('pointerdown', (e) => {
      // 마우스 우클릭 제외
      if (e.pointerType === 'mouse' && e.button !== 0) return;

      btn.removeAttribute('data-long-pressed');
      isLongPressed = false;

      const wrapper = btn.closest('.pad-wrapper');
      const popup = wrapper?.querySelector('.pad-popup');

      if (longPressTimeout) {
        clearTimeout(longPressTimeout);
      }

      longPressTimeout = window.setTimeout(() => {
        isLongPressed = true;
        btn.setAttribute('data-long-pressed', 'true');

        // 모든 팝업을 닫고 이 팝업을 활성화 고정
        document.querySelectorAll('.pad-popup').forEach(p => p.classList.remove('active'));
        if (popup) {
          popup.classList.add('active');
        }
      }, 1000); // 1.0초 누르고 있을 때
    });

    // Pointerup/Pointerleave/Pointercancel 시 롱프레스 타이머 해제
    const clearLongPress = () => {
      if (longPressTimeout) {
        clearTimeout(longPressTimeout);
        longPressTimeout = null;
      }
    };

    btn.addEventListener('pointerup', clearLongPress);
    btn.addEventListener('pointerleave', clearLongPress);
    btn.addEventListener('pointercancel', clearLongPress);

    // Click: 입력 및 더블 탭 순환 처리
    btn.addEventListener('click', async (e) => {
      // 일반 클릭 시에는 팝업이 활성화되지 않도록 보장하며, 혹시 롱프레스로 열려 있던 팝업이 있다면 즉시 닫음
      document.querySelectorAll('.pad-popup').forEach(p => p.classList.remove('active'));
      document.querySelectorAll('.pad').forEach(p => p.removeAttribute('data-long-pressed'));

      // 롱프레스로 팝업이 고정 열기 처리된 경우, 이번 손떼기 클릭은 입력하지 않고 리턴
      if (btn.getAttribute('data-long-pressed') === 'true' || isLongPressed) {
        isLongPressed = false;
        e.preventDefault();
        e.stopPropagation();
        return;
      }

      const jamo = btn.getAttribute('data-jamo') || '';
      const isCho = btn.classList.contains('cho');
      const currentTime = Date.now();

      try {
        await ensureAudio();
      } catch (err) {
        console.warn("AudioContext init failed, proceeding without sound:", err);
      }

      // 햅틱 효과 클래스 트리거
      btn.classList.add('hit');
      setTimeout(() => btn.classList.remove('hit'), 100);

      // 더블 탭 감지 (850ms 미만 & 동일 버튼 연속 클릭)
      const isDoubleTap = (lastTapPad === btn && (currentTime - lastTapTime) < 850);
      lastTapPad = btn;
      lastTapTime = currentTime;

      if (isCho) {
        // 자음 입력 및 순환 오토마타
        const cycle = CONSONANT_CYCLES[jamo];
        if (!cycle) return;

        if (!state.jung) {
          // 초성(cho) 단계 순환
          if (isDoubleTap && state.lastPadType === 'cho' && state.lastPadValue === jamo) {
            state.cycleIdx = (state.cycleIdx + 1) % cycle.length;
            state.cho = cycle[state.cycleIdx];
          } else {
            state.cho = jamo;
            state.jamoSeq = [];
            state.jung = null;
            state.jong = null;
            state.lastPadType = 'cho';
            state.lastPadValue = jamo;
            state.cycleIdx = 0;
          }
        } else {
          // 종성(jong) 단계 순환 및 겹받침 합성
          if (isDoubleTap && state.lastPadType === 'jong' && state.lastPadValue === jamo) {
            state.cycleIdx = (state.cycleIdx + 1) % cycle.length;
            state.jong = cycle[state.cycleIdx];
          } else {
            // 이미 종성이 존재하고 복자음 합성이 가능한 경우
            if (state.jong && COMPLEX_JONG_MAP[state.jong + jamo]) {
              state.jong = COMPLEX_JONG_MAP[state.jong + jamo];
              state.lastPadType = 'jong';
              state.lastPadValue = jamo;
              state.cycleIdx = 0;
            } else {
              state.jong = jamo;
              state.lastPadType = 'jong';
              state.lastPadValue = jamo;
              state.cycleIdx = 0;
            }
          }
        }

        // 기계음 대신 성우 목소리로 명칭 재생
        const currentJamo = (!state.jung) ? state.cho! : state.jong!;
        speakKo(currentJamo);
        showAnatomy(jamo);
      } else {
        // 모음 입력 및 순환
        const cycle = VOWEL_CYCLES[jamo];
        if (!cycle) return;

        if (state.cho && state.jong) {
          // 연음 법칙: 겹받침(복자음)이 있을 경우 마지막 자음만 초성으로 넘김
          const prevJong = state.jong;
          if (DECOMPOSE_JONG_MAP[prevJong]) {
            const [first, second] = DECOMPOSE_JONG_MAP[prevJong];
            state.word += String.fromCharCode(
              0xAC00 + (CHO_LIST.indexOf(state.cho) * 21 + JUNG_LIST.indexOf(state.jung!)) * 28 + JONG_LIST.indexOf(first)
            );
            state.cho = second; // 겹받침 중 두 번째 자음이 다음 글자의 초성으로 넘어감
          } else {
            const text = renderSyllable();
            if (text !== '—') {
              state.word += text;
            }
            state.cho = prevJong;
          }
          state.jamoSeq = [jamo];
          state.jung = composeVowel(state.jamoSeq);
          state.jong = null;
          state.lastPadType = 'jung';
          state.lastPadValue = jamo;
          state.cycleIdx = 0;
        } else if (state.cho) {
          if (isDoubleTap && state.lastPadType === 'jung' && state.lastPadValue === jamo) {
            // 더블 탭 순환: 팝업 순환 후보 중 다음 문자로 순환하며, 그에 매핑되는 천지인 시퀀스를 덮어씀
            state.cycleIdx = (state.cycleIdx + 1) % cycle.length;
            const targetVowel = cycle[state.cycleIdx];
            state.jamoSeq = VOWEL_TO_SEQ_MAP[targetVowel] ? [...VOWEL_TO_SEQ_MAP[targetVowel]] : [targetVowel];
            state.jung = composeVowel(state.jamoSeq);
          } else {
            // 단일 클릭: 기존 입력 시퀀스에 순수하게 덧붙임 (원래 천지인 합성 흐름 복구)
            state.jamoSeq.push(jamo);
            state.jung = composeVowel(state.jamoSeq);
            state.lastPadType = 'jung';
            state.lastPadValue = jamo;
            state.cycleIdx = 0;
          }
        } else {
          // 초성이 없는 경우 'ㅇ' 자동 부여
          state.cho = 'ㅇ';
          state.jamoSeq = [jamo];
          state.jung = composeVowel(state.jamoSeq);
          state.jong = null;
          state.lastPadType = 'jung';
          state.lastPadValue = jamo;
          state.cycleIdx = 0;
        }

        // 현재 구성된 모음 소리 성우 목소리로 재생
        if (state.jung) {
          speakKo(state.jung);
        }
      }

      updateDisplay();
      scheduleCommit();
    });
  });

  // 단어 입력 제어 버튼들 이벤트 바인딩
  const btnReset = document.getElementById('btn-reset');
  const btnBackspace = document.getElementById('btn-backspace');
  const btnSpace = document.getElementById('btn-space');
  const btnEnter = document.getElementById('btn-enter');
  const btnSpeakWord = document.getElementById('btn-speak-word');

  if (btnReset) {
    btnReset.addEventListener('click', () => {
      state.cho = null;
      state.jung = null;
      state.jong = null;
      state.jamoSeq = [];
      state.currentSyllable = '';
      state.word = '';
      state.english = ''; // 영어 클리어
      state.lastPadType = null;
      state.lastPadValue = null;
      state.cycleIdx = 0;
      
      const engInput = document.getElementById('input-english') as HTMLInputElement;
      if (engInput) engInput.value = ''; // 인풋 클리어
      
      updateDisplay();
      updateWordDisplay();
      
      const coachBubble = document.getElementById('coach-bubble');
      if (coachBubble) {
        coachBubble.textContent = "조립판이 초기화되었습니다. 패드를 눌러 새로운 단어를 만들어 보세요!";
      }
    });
  }

  // 단어 조립판 한꺼번에 지우기(×) 버튼
  const btnClearAll = document.getElementById('btn-clear-all');
  if (btnClearAll) {
    btnClearAll.addEventListener('click', () => {
      state.word = '';
      state.english = '';
      state.cho = null;
      state.jung = null;
      state.jong = null;
      state.jamoSeq = [];
      state.currentSyllable = '';
      state.lastPadType = null;
      state.lastPadValue = null;
      state.cycleIdx = 0;

      const engInput = document.getElementById('input-english') as HTMLInputElement;
      if (engInput) engInput.value = '';

      updateDisplay();
      updateWordDisplay();

      const coachBubble = document.getElementById('coach-bubble');
      if (coachBubble) {
        coachBubble.textContent = "조립판이 한꺼번에 지워졌습니다.";
      }
    });
  }

  // 단어 조립판 KOR input 박스: 직접 타이핑/외부 한글 복사-붙여넣기(Paste) 실시간 동기화
  const wordTextEl = document.getElementById('word-text') as HTMLInputElement | null;
  if (wordTextEl) {
    const syncInput = () => {
      state.word = wordTextEl.value;
      updatePhonetics();
      checkGameAnswer();

      // 붙여넣은 텍스트가 있으면 한꺼번에 지우기(×) 버튼 즉시 노출
      const btnClearAll = document.getElementById('btn-clear-all');
      if (btnClearAll) {
        btnClearAll.style.display = state.word ? 'flex' : 'none';
      }
    };

    wordTextEl.addEventListener('input', syncInput);
    wordTextEl.addEventListener('paste', () => {
      setTimeout(syncInput, 50); // 클립보드 텍스트가 입력창에 안착된 후 스캔하도록 딜레이
    });
  }

  if (btnBackspace) {
    btnBackspace.addEventListener('click', () => {
      // 1. 현재 조립 중인 한글이 있을 때
      if (state.cho) {
        if (state.jong) {
          // 겹받침(복자음)이면 앞의 자음만 남김
          if (DECOMPOSE_JONG_MAP[state.jong]) {
            state.jong = DECOMPOSE_JONG_MAP[state.jong][0];
            state.lastPadType = 'jong';
            state.lastPadValue = state.jong;
          } else {
            state.jong = null;
            state.lastPadType = 'jung';
          }
        } else if (state.jung) {
          state.jamoSeq.pop();
          state.jung = composeVowel(state.jamoSeq);
          if (!state.jung) {
            state.lastPadType = 'cho';
          }
        } else {
          state.cho = null;
          state.lastPadType = null;
        }
      } 
      // 2. 조립 중인 한글이 없고 조립판 단어가 있을 때
      else if (state.word) {
        // 단어의 마지막 글자가 겹받침을 가지고 있는지 확인하고 쪼갤 수 있다면 쪼개기
        const lastChar = state.word.slice(-1);
        const code = lastChar.charCodeAt(0);
        if (code >= 0xAC00 && code <= 0xD7A3) {
          const offset = code - 0xAC00;
          const jongIdx = offset % 28;
          const jungIdx = Math.floor((offset % 588) / 28);
          const choIdx = Math.floor(offset / 588);
          
          if (jongIdx > 0) {
            const currentJong = JONG_LIST[jongIdx];
            if (DECOMPOSE_JONG_MAP[currentJong]) {
              // 마지막 완성형 글자의 겹받침을 분해하여 뒤쪽만 제거
              const firstJong = DECOMPOSE_JONG_MAP[currentJong][0];
              const newChar = String.fromCharCode(
                0xAC00 + (choIdx * 21 + jungIdx) * 28 + JONG_LIST.indexOf(firstJong)
              );
              state.word = state.word.slice(0, -1) + newChar;
            } else {
              // 단일 받침이면 받침만 제거
              const newChar = String.fromCharCode(
                0xAC00 + (choIdx * 21 + jungIdx) * 28
              );
              state.word = state.word.slice(0, -1) + newChar;
            }
          } else {
            // 받침이 없으면 글자 전체 삭제
            state.word = state.word.slice(0, -1);
          }
        } else {
          // 완성형 한글이 아니면 그냥 한 자 지우기
          state.word = state.word.slice(0, -1);
        }
      }
      
      updateDisplay();
      updateWordDisplay();
    });
  }

  if (btnSpace) {
    btnSpace.addEventListener('click', () => {
      const text = renderSyllable();
      if (text !== '—') {
        state.word += text;
      }
      state.word += ' ';
      
      state.cho = null;
      state.jung = null;
      state.jong = null;
      state.jamoSeq = [];
      state.lastPadType = null;
      state.lastPadValue = null;
      state.cycleIdx = 0;
      
      updateDisplay();
      updateWordDisplay();
    });
  }

  if (btnEnter) {
    btnEnter.addEventListener('click', () => {
      const text = renderSyllable();
      if (text !== '—') {
        state.word += text;
        speakKo(text); // 확정된 글자 성우 음성으로 들려주기
      }
      
      state.cho = null;
      state.jung = null;
      state.jong = null;
      state.jamoSeq = [];
      state.lastPadType = null;
      state.lastPadValue = null;
      state.cycleIdx = 0;
      
      updateDisplay();
      updateWordDisplay();
    });
  }

  if (btnSpeakWord) {
    btnSpeakWord.addEventListener('click', () => {
      const currentText = renderSyllable();
      const finalSyllable = (currentText !== '—') ? currentText : '';
      const fullText = state.word + finalSyllable;

      if (fullText.trim()) {
        // 기계음(SpeechSynthesis) 전체 읽기를 제거하고, 한글 발음 법칙으로 연음화한 뒤
        // 로컬 gTTS 성우 음원(/audio/jamo/*.mp3)을 낱자 단위로 순차 결합 재생한다.
        const phoneticText = getPhoneticSubstitute(fullText);
        playSentence(phoneticText);
      }
    });
  }

  // BGM 재생 버튼
  const bgmBtn = document.getElementById('btn-toggle-bgm');
  const statusText = document.getElementById('playback-status');
  const discIcon = document.getElementById('disc-icon');
  const eqAnim = document.getElementById('eq-animation');

  if (bgmBtn && statusText) {
    bgmBtn.addEventListener('click', async () => {
      await ensureAudio();
      
      const playIcon = bgmBtn.querySelector('.play-icon');
      
      if (isBgmPlaying) {
        // 정지
        if (songSource) {
          songSource.stop();
          songSource = null;
        }
        isBgmPlaying = false;
        
        if (playIcon) playIcon.textContent = '▶';
        if (discIcon) discIcon.classList.remove('spinning');
        if (eqAnim) eqAnim.classList.remove('active');
        
        statusText.textContent = 'Stopped';
        statusText.style.color = '';
      } else {
        // 재생
        statusText.textContent = 'Loading...';
        try {
          const buf = await loadSong('/audio/kpop_song_1.wav');
          if (buf && audioCtx && bgmGain) {
            songSource = audioCtx.createBufferSource();
            songSource.buffer = buf;
            songSource.loop = true;
            songSource.connect(bgmGain);
            songSource.start(0);
            
            isBgmPlaying = true;
            
            if (playIcon) playIcon.textContent = '⏸';
            if (discIcon) discIcon.classList.add('spinning');
            if (eqAnim) eqAnim.classList.add('active');
            
            statusText.textContent = 'Looping';
            statusText.style.color = '#00F0FF';
          }
        } catch (err) {
          statusText.textContent = 'Error';
          if (discIcon) discIcon.classList.remove('spinning');
          if (eqAnim) eqAnim.classList.remove('active');
          console.error('Audio load failed:', err);
        }
      }
    });
  }

  // 마이크 코치 버튼
  const micBtn = document.getElementById('btn-mic') as HTMLButtonElement;
  const coachBubble = document.getElementById('coach-bubble');
  if (micBtn && coachBubble) {
    const micIcon = micBtn.querySelector('.mic-icon');
    const micText = document.getElementById('mic-text');

    // SpeechRecognition 인스턴스 생성 여부 파악하여 안내문구
    if (!SR) {
      micBtn.style.display = 'none';
      coachBubble.innerHTML += '<br><small style="color:hsl(350, 100%, 65%);">(음성 인식이 지원되지 않는 브라우저입니다. Chrome을 사용해 주세요.)</small>';
    } else {
      micBtn.addEventListener('click', async () => {
        // 1. 현재 활성화된 콕핏 모드 탐색
        const activeTab = document.querySelector('.switcher-btn.active');
        const activeMode = activeTab ? activeTab.getAttribute('data-mode') : 'launchpad';

        // 2. 모드 및 언어에 따른 타겟 텍스트(targetText) 결정
        let targetText = '';
        if (state.langMode === 'ko') {
          if (activeMode === 'launchpad') {
            targetText = state.currentSyllable;
          } else {
            targetText = state.word;
          }
          // 한국어 발음 연습인데 타겟 텍스트가 없으면 녹음 미작동
          if (!targetText) return;
        }

        await ensureAudio();
        
        // 이미 녹음 중이면 리턴
        if (micBtn.classList.contains('recording')) return;



        if (!recognizer) {
          recognizer = new SR();
          recognizer.interimResults = false;
          recognizer.maxAlternatives = 1;
          recognizer.continuous = false;
        }
        
        // 언어 모드 동적 할당
        recognizer.lang = (state.langMode === 'en') ? 'en-US' : 'ko-KR';
        // 인식기에 타겟 텍스트 동적 바인딩
        recognizer.targetText = targetText;

        // BGM 완전 음소거 (배경 소음으로 인한 마이크 인식 장애 원천 차단)
        if (bgmGain && isBgmPlaying) {
          bgmGain.gain.setValueAtTime(0.0, audioCtx!.currentTime);
        }

        recognizer.onstart = () => {
          micBtn.classList.add('recording');
          if (micIcon) micIcon.textContent = '🛑';
          if (micText) micText.textContent = 'Listening...';
          
          if (state.langMode === 'en') {
            coachBubble.textContent = "영어로 말씀해 보세요... (Speak in English...)";
          } else {
            coachBubble.textContent = `"${targetText}" 발음을 또박또박 말씀해 보세요...`;
          }
        };

        recognizer.onresult = (e: any) => {
          const heard = e.results[0][0].transcript.trim();
          
          if (state.langMode === 'en') {
            // 영어 음성 인식 완료
            state.english = heard;
            updateWordDisplay();
            translateSentence(heard);
          } else {
            // 한글 발음 평가 (인식기에 바인딩된 targetText 대조)
            const evaluationTarget = (e && e.currentTarget && e.currentTarget.targetText) || targetText || state.currentSyllable || state.word || '';
            const score = scorePronunciation(heard, evaluationTarget);
            
            let comment = '';
            if (score >= 90) {
              comment = '완벽한 발음입니다! 🎉 Sori Hangeul 그루브가 느껴져요!';
              state.combo++;
            } else if (score >= 60) {
              comment = '거의 비슷합니다! 조금 더 또박또박 발음해볼까요?';
            } else {
              comment = '입모양을 조금 더 크게 벌리고 소리를 내 보세요. 다시 도전!';
              state.combo = 0;
            }

            coachBubble.innerHTML = `인식된 발음: <strong>"${heard}"</strong> (일치율 ${score}점)<br>${comment}`;
            
            // 정답 재생 (단음절이면 speakKo, 문장이면 playSentence 호출)
            setTimeout(() => {
              if (evaluationTarget.length === 1) {
                speakKo(evaluationTarget);
              } else {
                playSentence(evaluationTarget);
              }
            }, 500);
          }
        };

        recognizer.onerror = (e: any) => {
          coachBubble.textContent = `다시 말해볼까요? (에러: ${e.error})`;
        };

        recognizer.onend = () => {
          micBtn.classList.remove('recording');
          if (micIcon) micIcon.textContent = '🎤';
          if (micText) micText.textContent = 'Coach';
          
          // BGM 음량 복구
          if (bgmGain && isBgmPlaying) {
            bgmGain.gain.setValueAtTime(0.15, audioCtx!.currentTime);
          }
        };

        recognizer.start();
      });
    }
  }

