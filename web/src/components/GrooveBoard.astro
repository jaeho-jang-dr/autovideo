}

.stage-number-badge {
  position: absolute;
  top: 12px;
  left: 12px;
  background: rgba(0, 0, 0, 0.75);
  border: 1px solid var(--gv-border);
  color: var(--gv-text-1);
  padding: 4px 10px;
  border-radius: 6px;
  font-family: 'Outfit', sans-serif;
