</style>

<script>
  // ── SSOT 상태 ──
  const state = {
    cho: null as string | null,
    jamoSeq: [] as string[],
    jung: null as string | null,
    jong: null as string | null,
    combo: 0,
    currentSyllable: '',
    word: '',
    english: '',
    langMode: 'ko' as 'ko' | 'en',
    // 오토마타 순환 제어용 추가 필드
    lastPadType: null as 'cho' | 'jong' | 'jung' | null,
    lastPadValue: null as string | null,
    cycleIdx: 0
  };

  // 자음/모음 데이터 맵
  const CHO_LIST = ['ㄱ','ㄲ','ㄴ','ㄷ','ㄸ','ㄹ','ㅁ','ㅂ','ㅃ','ㅅ','ㅆ','ㅇ','ㅈ','ㅉ','ㅊ','ㅋ','ㅌ','ㅍ','ㅎ'];
  const JUNG_LIST = ['ㅏ','ㅐ','ㅑ','ㅒ','ㅓ','ㅔ','ㅕ','ㅖ','ㅗ','ㅘ','ㅙ','ㅚ','요','ㅜ','ㅝ','ㅞ','ㅟ','ㅠ','ㅡ','ㅢ','ㅣ'];
  const JONG_LIST = ['', 'ㄱ', 'ㄲ', 'ㄳ', 'ㄴ', 'ㅈ', 'ㄶ', 'ㄷ', 'ㄹ', 'ㄺ', 'ㄻ', 'ㄼ', 'ㄽ', 'ㄾ', 'ㄿ', 'ㅀ', 'ㅁ', 'ㅂ', 'ㅄ', 'ㅅ', 'ㅆ', 'ㅇ', 'ㅈ', 'ㅊ', 'ㅋ', 'ㅌ', 'ㅍ', 'ㅎ'];

  // 자음 순환 사이클 정의
  const CONSONANT_CYCLES: Record<string, string[]> = {
    'ㄱ': ['ㄱ', 'ㄲ', 'ㅋ'],
    'ㄴ': ['ㄴ', 'ㄷ', 'ㄸ', 'ㅌ', 'ㄹ'],
    'ㅁ': ['ㅁ', 'ㅂ', 'ㅃ', 'ㅍ'],
    'ㅅ': ['ㅅ', 'ㅆ', 'ㅈ', 'ㅉ', 'ㅊ'],
    'ㅇ': ['ㅇ', 'ㅎ']
  };

  const ANATOMY_MAP: Record<string, { title: string; desc: string; emoji: string }> = {
    'ㄱ': { title: 'ㄱ (G/K - Velar)', desc: '舌근閉喉 (Tongue root blocks throat)', emoji: '👅' },
    'ㄴ': { title: 'ㄴ (N - Alveolar)', desc: '舌尖抵齒 (Tongue tip taps upper gums)', emoji: '🦷' },
    'ㅁ': { title: 'ㅁ (M - Bilabial)', desc: '口形상형 (Outline of meeting lips)', emoji: '👄' },
    'ㅅ': { title: 'ㅅ (S - Dental)', desc: '齒形상형 (Sharp teeth creating friction)', emoji: '🦷' },
    'ㅇ': { title: 'ㅇ (Ng - Glottal)', desc: '喉形상형 (Circular outline of open throat)', emoji: '⭕' }
  };

  // 천지인 모음 조합 결정표 (jamoSeq.join('') -> 완성 중성)
  const VOWEL_COMBINATIONS: Record<string, string> = {
    'ㅣ•': 'ㅏ',
    'ㅣ••': 'ㅑ',
    '•ㅣ': 'ㅓ',
    '••ㅣ': 'ㅕ',
    '•ㅡ': 'ㅗ',
    '••ㅡ': '요',
    'ㅡ•': 'ㅜ',
    'ㅡ••': 'ㅠ',
    'ㅡ': 'ㅡ',
    'ㅣ': 'ㅣ',
    'ㅡㅣ': 'ㅢ',
    'ㅏㅣ': 'ㅐ',
    'ㅓㅣ': 'ㅔ'
  };

  // ── Web Audio API ──
  let audioCtx: AudioContext | null = null;
  let songBuffer: AudioBuffer | null = null;
  let songSource: AudioBufferSourceNode | null = null;
  let bgmGain: GainNode | null = null;
  let isBgmPlaying = false;

  async function ensureAudio() {
    if (!audioCtx) {
      audioCtx = new (window.AudioContext || (window as any).webkitAudioContext)();
      bgmGain = audioCtx.createGain();
      bgmGain.gain.setValueAtTime(0.15, audioCtx.currentTime); // BGM 볼륨
      bgmGain.connect(audioCtx.destination);
    }
    if (audioCtx.state === 'suspended') {
      await audioCtx.resume();
    }
  }

  async function loadSong(url: string) {
    if (songBuffer) return songBuffer;
    const res = await fetch(url);
    const arr = await res.arrayBuffer();
    if (!audioCtx) return null;
    songBuffer = await audioCtx.decodeAudioData(arr);
    return songBuffer;
  }

  // ── 한글 합자 렌더링 ──
  function renderSyllable() {
    if (!state.cho) return '—';
    if (!state.jung) return state.cho; // 자음 단독
    
    const ci = CHO_LIST.indexOf(state.cho);
    const ji = JUNG_LIST.indexOf(state.jung);
    
    if (ci < 0 || ji < 0) return state.cho;
    
    const jongIdx = state.jong ? JONG_LIST.indexOf(state.jong) : 0;
    const finalJongIdx = jongIdx < 0 ? 0 : jongIdx;
    
    return String.fromCharCode(0xAC00 + (ci * 21 + ji) * 28 + finalJongIdx);
  }

  function updateDisplay() {
    const displayEl = document.getElementById('display-syllable');
    if (!displayEl) return;
    
    const text = renderSyllable();
    displayEl.textContent = text;
    state.currentSyllable = text !== '—' && text.length === 1 && text !== state.cho ? text : '';

    // 모핑 팝 애니메이션
    displayEl.classList.add('pop');
    setTimeout(() => {
      displayEl.classList.remove('pop');
    }, 150);

    // AI 에이전트 마이크 버튼 제어 (EN 모드일 때는 항상 활성화)
    const micBtn = document.getElementById('btn-mic') as HTMLButtonElement;
    if (micBtn) {
      micBtn.disabled = (state.langMode === 'ko' && !state.currentSyllable);
    }
  }

  function updateWordDisplay() {
    const wordTextEl = document.getElementById('word-text');
    if (wordTextEl) {
      wordTextEl.textContent = state.word || '—';
    }

    const englishTextEl = document.getElementById('english-text');
    const englishRow = document.getElementById('english-row');
    if (englishTextEl && englishRow) {
      if (state.english) {
        englishTextEl.textContent = state.english;
        englishRow.style.display = 'flex';
      } else {
        englishRow.style.display = 'none';
      }
    }

    // 게임 정답 실시간 스캔 채점 호출
    checkGameAnswer();
  }

  // 모음 상태 처리기
  function composeVowel(seq: string[]) {
    // 1단계: 빌딩 블록 조합
    let combined = seq.join('');
    if (VOWEL_COMBINATIONS[combined]) {
      return VOWEL_COMBINATIONS[combined];
    }
    
    // 2단계: 복합 매칭 (예: ㅣ + • = ㅏ 이고, 여기에 ㅣ 추가 시 ㅐ)
    let base = '';
    for (let char of seq) {
      if (!base) {
        base = char;
      } else {
        const next = base + char;
        if (VOWEL_COMBINATIONS[next]) {
          base = VOWEL_COMBINATIONS[next];
        } else {
          base += char;
        }
      }
    }
    
    const result = VOWEL_COMBINATIONS[base] || null;
    
    // 안전 장치: 조합이 성립되지 않고 천지인 입력 갯수가 3개 이상 쌓이면, 
    // 마지막에 누른 천지인 하나만 남겨서 조어가 끊기지 않도록 방어
    if (!result && seq.length >= 3) {
      const last = seq[seq.length - 1];
      state.jamoSeq = [last];
      return VOWEL_COMBINATIONS[last] || null;
    }
    
    return result;
  }

  // 조음 상형 팝업 제어
  let popupTimeout: number | null = null;
  function showAnatomy(jamo: string) {
    const popup = document.getElementById('articulatory-popup');
    const title = document.getElementById('anatomy-title');
    const desc = document.getElementById('anatomy-desc');
    const emoji = document.getElementById('anatomy-emoji');
    if (!popup || !title || !desc || !emoji) return;

    if (popupTimeout) {
      clearTimeout(popupTimeout);
    }

    const data = ANATOMY_MAP[jamo];
    if (data) {
      title.textContent = data.title;
      desc.textContent = data.desc;
      emoji.textContent = data.emoji;
      popup.classList.remove('hidden');

      popupTimeout = window.setTimeout(() => {
        popup.classList.add('hidden');
      }, 1200);
    } else {
      popup.classList.add('hidden');
    }
  }

  // 1.5초 확정 타이머
  let commitTimeout: number | null = null;
  function scheduleCommit() {
    if (commitTimeout) {
      clearTimeout(commitTimeout);
    }
    commitTimeout = window.setTimeout(() => {
      const text = renderSyllable();
      if (text !== '—' && text !== state.cho) {
        speakKo(text); // 확정 시 가볍게 읽어주기
      }
    }, 1500);
  }

  // ── Web Speech API 코치 ──
  const SR = (window as any).SpeechRecognition || (window as any).webkitSpeechRecognition;
  let recognizer: any = null;

  // 자모 기호 및 특수조합에 대한 MP3 파일명 맵핑 테이블 (19개 자음 전체로 확장)
  const JAMO_AUDIO_MAP: Record<string, string> = {
    // 19개 자음 기호 -> 파일명
    'ㄱ': '기역', 'ㄲ': '쌍기역', 'ㅋ': '키읔',
    'ㄴ': '니은', 'ㄷ': '디귿', 'ㄸ': '쌍디귿', 'ㅌ': '티읔', 'ㄹ': '리을',
    'ㅁ': '미음', 'ㅂ': '비읍', 'ㅃ': '쌍비읍', 'ㅍ': '피읔',
    'ㅅ': '시옷', 'ㅆ': '쌍시옷', 'ㅈ': '지읒', 'ㅉ': '쌍지읒', 'ㅊ': '치읓',
    'ㅇ': '이응', 'ㅎ': '히읗',
    // 모음 기호 -> 파일명
    'ㅏ': '아', 'ㅐ': '애', 'ㅑ': '야', 'ㅓ': '어', 'ㅔ': '에', 'ㅕ': '여', 
    'ㅗ': '오', '요': '요', 'ㅜ': '우', 'ㅠ': '유', 'ㅡ': '으', 'ㅢ': '의', 'ㅣ': '이',
    '•': '아래아'
  };

  function speakKo(text: string) {
    // 낱자 기호가 입력된 경우 맵핑 테이블을 통해 한글 명칭 파일명으로 변환
    const filename = JAMO_AUDIO_MAP[text] || text;
    
    // 로컬의 고품질 gTTS MP3 발음 파일 우선 재생 시도
    const audioUrl = `/audio/jamo/${encodeURIComponent(filename)}.mp3`;
    const audio = new Audio(audioUrl);
    
    audio.volume = 0.85;
    
    audio.addEventListener('error', () => {
      // 로컬 파일이 없거나 오류 시 내장 SpeechSynthesis로 안전하게 백업 폴백
      fallbackSpeak(text);
    });
    
    audio.play().catch(err => {
      console.warn("Audio auto-play blocked or error, falling back:", err);
      fallbackSpeak(text);
    });
  }

  // 폴백용 브라우저 음성 합성 함수 (띄어쓰기 등 문장 전체는 무조건 SpeechSynthesis 사용)
  function fallbackSpeak(text: string) {
    if ('speechSynthesis' in window) {
      window.speechSynthesis.cancel();
      const utterance = new SpeechSynthesisUtterance(text);
      utterance.lang = 'ko-KR';
      utterance.rate = 0.92;
      window.speechSynthesis.speak(utterance);
    }
  }

  // 영어-한글 로컬 번역 캐시 사전
  const LOCAL_TRANSLATION_MAP: Record<string, string> = {
    'water please': '물 주세요',
    'please give me water': '물 주세요',
    'give me water': '물 주세요',
    'rice please': '밥 주세요',
    'please give me rice': '밥 주세요',
    'give me rice': '밥 주세요',
    'it is delicious': '맛있어요',
    'delicious': '맛있어요',
    'where is the restroom': '화장실 어디에요',
    'where is the toilet': '화장실 어디에요',
    'restroom please': '화장실 어디에요',
    'toilet paper please': '휴지 주세요',
    'please give me toilet paper': '휴지 주세요',
    'here is my passport': '여권 여기 있어요',
    'passport please': '여권 여기 있어요',
    'where is the airplane': '비행기 어디에요',
    'where is the plane': '비행기 어디에요',
    'ticket please': '표 주세요',
    'please give me a ticket': '표 주세요',
    'where is the train': '기차 어디에요',
    'train please': '기차 어디에요'
  };

  async function translateSentence(englishText: string) {
    const coachBubble = document.getElementById('coach-bubble');
    if (coachBubble) coachBubble.textContent = "번역 중... (Translating...)";

    // 1. 소문자 정규화 후 로컬 매핑 사전 조회
    const cleanText = englishText.toLowerCase().replace(/[.,\/#!$%\^&\*;:{}=\-_`~()?]/g, "").trim();
    if (LOCAL_TRANSLATION_MAP[cleanText]) {
      const translated = LOCAL_TRANSLATION_MAP[cleanText];
      state.word = translated;
      updateWordDisplay();
      
      if (coachBubble) {
        coachBubble.innerHTML = `인식: <strong>"${englishText}"</strong><br>번역: <strong>"${translated}"</strong> (로컬 매치)`;
      }

      // 성우 음성 큐 재생
      playSentence(translated);
      return;
    }

    // 2. 사전에 없으면 실시간 무료 번역 API 호출
    try {
      const url = `https://api.mymemory.translated.net/get?q=${encodeURIComponent(englishText)}&langpair=en|ko`;
      const res = await fetch(url);
      const data = await res.json();
      
      const translated = data?.responseData?.translatedText || '';
      if (translated) {
        state.word = translated;
        updateWordDisplay();
        
        if (coachBubble) {
          coachBubble.innerHTML = `인식: <strong>"${englishText}"</strong><br>번역: <strong>"${translated}"</strong> (실시간 번역)`;
        }

        // 성우 음성 큐 재생
        playSentence(translated);
      } else {
        throw new Error("Empty translation result");
      }
    } catch (err) {
      console.warn("Translation API failed, fallback to raw input:", err);
      if (coachBubble) {
        coachBubble.textContent = `번역 실패: 네트워크 연결을 확인하세요. ("${englishText}")`;
      }
    }
  }

  // 문장/단어 내 각 글자를 성우 발음 MP3로 순차 재생하는 큐 엔진
  let audioQueue: string[] = [];
  let currentQueueIndex = 0;
  let activeAudio: HTMLAudioElement | null = null;
  let isPlayingQueue = false;

  function stopSentenceQueue() {
    isPlayingQueue = false;
    audioQueue = [];
    currentQueueIndex = 0;
    if (activeAudio) {
      activeAudio.pause();
      activeAudio = null;
    }
  }

  function playSentence(text: string) {
    stopSentenceQueue(); // 기존 재생 중이던 것 중단

    if (!text.trim()) return;

    // 문자를 글자 하나하나 단위로 쪼개기 (공백 및 특수문자 유지)
    audioQueue = Array.from(text);
    isPlayingQueue = true;
    currentQueueIndex = 0;
    
    playNextInQueue();
  }

  async function playNextInQueue() {
    if (!isPlayingQueue || currentQueueIndex >= audioQueue.length) {
      isPlayingQueue = false;
      return;
    }

    const char = audioQueue[currentQueueIndex];
    currentQueueIndex++;

    // 공백(띄어쓰기)인 경우 일정 시간 딜레이 후 다음 문자 진행
    if (char === ' ') {
      setTimeout(() => {
        playNextInQueue();
      }, 350); // 띄어쓰기는 350ms 무음 딜레이
      return;
    }

    // 자모 오디오 맵 상 기호 이름 매핑 적용
    const filename = JAMO_AUDIO_MAP[char] || char;
    const audioUrl = `/audio/jamo/${encodeURIComponent(filename)}.mp3`;
    
    activeAudio = new Audio(audioUrl);
    activeAudio.volume = 0.85;

    let fallbackTriggered = false;

    const handleNext = () => {
      if (fallbackTriggered) return;
      // 다음 글자 재생 전 약간의 글자 간 간격(80ms)을 주어 자연스럽게 연결
      setTimeout(() => {
        playNextInQueue();
      }, 80);
    };

    activeAudio.addEventListener('ended', handleNext);

    activeAudio.addEventListener('error', () => {
      fallbackTriggered = true;
      // 로컬 파일이 없으면 브라우저 TTS로 이 글자만 읽어주고 다음 글자로 넘어감
      fallbackSpeak(char);
      // TTS 발음 시간에 맞추어 일정 시간 후 다음 글자 재생 진행
      setTimeout(() => {
        playNextInQueue();
      }, 500);
    });

    try {
      await ensureAudio();
      await activeAudio.play();
    } catch (err) {
      console.warn("Audio queue play failed, fallback to TTS:", err);
      fallbackTriggered = true;
      fallbackSpeak(char);
      setTimeout(() => {
        playNextInQueue();
      }, 500);
    }
  }

  function levenshtein(a: string, b: string): number {
    const tmp: number[][] = [];
    const alen = a.length, blen = b.length;
    if (alen === 0) return blen;
    if (blen === 0) return alen;
    for (let i = 0; i <= alen; i++) tmp[i] = [i];
    for (let j = 0; j <= blen; j++) tmp[0][j] = j;
    for (let i = 1; i <= alen; i++) {
      for (let j = 1; j <= blen; j++) {
        tmp[i][j] = Math.min(
          tmp[i - 1][j] + 1,
          tmp[i][j - 1] + 1,
          tmp[i - 1][j - 1] + (a[i - 1] === b[j - 1] ? 0 : 1)
        );
      }
    }
    return tmp[alen][blen];
  }

  function scorePronunciation(heard: string, target: string): number {
    if (heard.includes(target)) return 100;
    const dist = levenshtein(heard, target);
    const maxLen = Math.max(heard.length, target.length);
    return Math.max(0, Math.round((1 - dist / maxLen) * 90));
  }

