  function speakKo(text: string) {
    // 조어된 글자 중 오디오 데이터베이스에 없는 글자는 읽지 않고 즉시 스킵
    const isComposite = text !== '—' && !JAMO_AUDIO_MAP[text] && text !== '•';
    if (isComposite && !hasAudio(text)) {
      console.warn("Audio asset unavailable for syllable, skipping playback:", text);
      return;
    }

    // 낱자 기호가 입력된 경우 맵핑 테이블을 통해 한글 명칭 파일명으로 변환
    const filename = JAMO_AUDIO_MAP[text] || text;
    
    // 로컬의 고품질 gTTS MP3 발음 파일 우선 재생 시도
    const audioUrl = `/audio/jamo/${encodeURIComponent(filename)}.mp3`;
    const audio = new Audio(audioUrl);
    
    audio.volume = 0.85;
    
    audio.addEventListener('error', () => {
      // 로컬 파일이 없거나 오류 시 내장 SpeechSynthesis로 안전하게 백업 폴백
      fallbackSpeak(text);
    });
    
    audio.play().catch(err => {
      console.warn("Audio auto-play blocked or error, falling back:", err);
      fallbackSpeak(text);
    });
  }

  // 폴백용 브라우저 음성 합성 함수 (띄어쓰기 등 문장 전체는 무조건 SpeechSynthesis 사용)
  function fallbackSpeak(text: string) {
    if ('speechSynthesis' in window) {
      window.speechSynthesis.cancel();
      const utterance = new SpeechSynthesisUtterance(text);
      utterance.lang = 'ko-KR';
      utterance.rate = 1.0; // 사람이 대화할 때의 자연스러운 표준 속도로 낭독
      window.speechSynthesis.speak(utterance);
    }
  }

  // 기계음의 발음 교정을 위해 대표 변음 단어들을 기계음에 전달하기 전 발음 텍스트로 치환하는 헬퍼 함수
  function getPhoneticSubstitute(text: string): string {
    let processed = text;
    // 발음 치환 테이블 정의 (기계음 SpeechSynthesis 오독 방지 및 연음 구현용)
    const SUBSTITUTE_MAP: Record<string, string> = {
      '값이': '갑시',
      '읽는다': '익는다',
      '굳이': '구지',
      '같이': '가치',
      '돋보기': '돋뽀기',
      '꽃이': '꼬치',
      '맛있어요': '마시써요',
      '합니다': '함니다',
      '국물': '궁물',
      '밥 먹어요': '밤머거요',
      '신라': '실라',
      '칼날': '칼랄',
      '독립': '동닙',
      '백마': '뱅마',
      '국민': '궁민',
      '낱낱이': '난나치',
      '맏이': '마지',
      '해돋이': '해도지',
      '끝이': '끄치',
      '붙여': '부쳐'
    };

    // 가장 긴 키를 먼저 치환하여 중복 치환 간섭 최소화
    const sortedKeys = Object.keys(SUBSTITUTE_MAP).sort((a, b) => b.length - a.length);
    for (const key of sortedKeys) {
      if (processed.includes(key)) {
        processed = processed.replace(new RegExp(key, 'g'), SUBSTITUTE_MAP[key]);
      }
    }
    return processed;
  }

  // 문장 전체를 일반 구어체 속도로 자연스럽게 연음 법칙을 살려 낭독하는 함수
  function speakSentenceNatural(text: string) {
    if ('speechSynthesis' in window) {
      window.speechSynthesis.cancel();
      const phoneticText = getPhoneticSubstitute(text);
      const utterance = new SpeechSynthesisUtterance(phoneticText);
      utterance.lang = 'ko-KR';
      utterance.rate = 1.0; // 사람이 대화할 때의 자연스러운 표준 속도로 낭독
      utterance.pitch = 1.0;
      window.speechSynthesis.speak(utterance);
    }
  }

