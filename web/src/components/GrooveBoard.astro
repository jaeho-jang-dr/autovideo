  async function translateSentence(englishText: string) {
    const coachBubble = document.getElementById('coach-bubble');
    if (coachBubble) coachBubble.textContent = "번역 중... (Translating...)";

    // 1. 소문자 정규화 후 로컬 매핑 사전 조회
    const cleanText = englishText.toLowerCase().replace(/[.,\/#!$%\^&\*;:{}=\-_`~()?]/g, "").trim();
    if (LOCAL_TRANSLATION_MAP[cleanText]) {
      const translated = LOCAL_TRANSLATION_MAP[cleanText];
      state.word = translated;
      updateWordDisplay();
      
      if (coachBubble) {
        coachBubble.innerHTML = `인식: <strong>"${englishText}"</strong><br>번역: <strong>"${translated}"</strong> (로컬 매치)`;
      }

      // 성우 음성 큐 재생
      playSentence(translated);
      return;
    }

    // 2. 사전에 없으면 실시간 무료 번역 API 호출
    try {
      const url = `https://api.mymemory.translated.net/get?q=${encodeURIComponent(englishText)}&langpair=en|ko`;
      const res = await fetch(url);
      const data = await res.json();
      
      const translated = data?.responseData?.translatedText || '';
      if (translated) {
        state.word = translated;
        updateWordDisplay();
        
        if (coachBubble) {
          coachBubble.innerHTML = `인식: <strong>"${englishText}"</strong><br>번역: <strong>"${translated}"</strong> (실시간 번역)`;
        }

        // 성우 음성 큐 재생
        playSentence(translated);
      } else {
        throw new Error("Empty translation result");
      }
    } catch (err) {
      console.warn("Translation API failed, fallback to raw input:", err);
      if (coachBubble) {
        coachBubble.textContent = `번역 실패: 네트워크 연결을 확인하세요. ("${englishText}")`;
      }
    }
  }

  // 문장/단어 내 각 글자를 성우 발음 MP3로 순차 재생하는 큐 엔진
  let audioQueue: string[] = [];
  let currentQueueIndex = 0;
  let activeAudio: HTMLAudioElement | null = null;
  let isPlayingQueue = false;

  function stopSentenceQueue() {
    isPlayingQueue = false;
    audioQueue = [];
    currentQueueIndex = 0;
    if (activeAudio) {
      activeAudio.pause();
      activeAudio = null;
    }
  }

  function shouldFallbackToNatural(text: string): boolean {
    for (const char of text) {
      // 일반적인 문장 부호 및 공백, 특수문자 무시
      if (/[\s.,\/#!$%\^&\*;:{}=\-_`~()?"'’“•—\[\]\+\<\>\@\|\\`]/g.test(char)) {
        continue;
      }
      // 로컬 성우 음원이 없는 실질적 글자가 하나라도 존재하면 폴백
      if (!hasAudio(char)) {
        return true;
      }
    }
    return false;
  }

  function playSentence(text: string) {
    stopSentenceQueue(); // 기존 재생 중이던 것 중단

    if (!text.trim()) return;

    // 만약 데이터베이스에 없는 글자가 포함되어 있다면, 낱자 단위 재생을 피하고 문장 통낭독으로 자동 우회
    if (shouldFallbackToNatural(text)) {
      speakSentenceNatural(text);
      return;
    }

    // 문자를 글자 하나하나 단위로 쪼개기 (공백 및 특수문자 유지)
    audioQueue = Array.from(text);
    isPlayingQueue = true;
    currentQueueIndex = 0;
    
    playNextInQueue();
  }

  async function playNextInQueue() {
    if (!isPlayingQueue || currentQueueIndex >= audioQueue.length) {
      isPlayingQueue = false;
      return;
    }

    const char = audioQueue[currentQueueIndex];
    currentQueueIndex++;

    // 공백(띄어쓰기)인 경우 일정 시간 딜레이 후 다음 문자 진행
    if (char === ' ') {
      setTimeout(() => {
        playNextInQueue();
      }, 350); // 띄어쓰기 무음 딜레이 (사람이 이야기할 때의 자연스러운 간격 350ms)
      return;
    }

    // 자모 오디오 맵 상 기호 이름 매핑 적용
    const filename = JAMO_AUDIO_MAP[char] || char;
    const audioUrl = `/audio/jamo/${encodeURIComponent(filename)}.mp3`;
    
    activeAudio = new Audio(audioUrl);
    activeAudio.volume = 0.85;
    activeAudio.playbackRate = 1.0; // 사람이 이야기할 때의 자연스러운 표준 속도 (1.0배속)

    let fallbackTriggered = false;

    const handleNext = () => {
      if (fallbackTriggered) return;
      // 다음 글자 재생 전 글자 간 간격 (사람이 이야기할 때의 자연스러운 연결 80ms)
      setTimeout(() => {
        playNextInQueue();
      }, 80);
    };

    activeAudio.addEventListener('ended', handleNext);

    activeAudio.addEventListener('error', () => {
      fallbackTriggered = true;
      // 로컬 파일이 없으면 브라우저 TTS로 이 글자만 읽어주고 다음 글자로 넘어감
      fallbackSpeak(char);
      // TTS 발음 시간에 맞추어 일정 시간 후 다음 글자 재생 진행
      setTimeout(() => {
        playNextInQueue();
      }, 500);
    });

    try {
      await ensureAudio();
      await activeAudio.play();
    } catch (err) {
      console.warn("Audio queue play failed, fallback to TTS:", err);
      fallbackTriggered = true;
      fallbackSpeak(char);
      setTimeout(() => {
        playNextInQueue();
      }, 500);
    }
  }

  function levenshtein(a: string, b: string): number {
    const tmp: number[][] = [];
    const alen = a.length, blen = b.length;
    if (alen === 0) return blen;
    if (blen === 0) return alen;
    for (let i = 0; i <= alen; i++) tmp[i] = [i];
    for (let j = 0; j <= blen; j++) tmp[0][j] = j;
    for (let i = 1; i <= alen; i++) {
      for (let j = 1; j <= blen; j++) {
        tmp[i][j] = Math.min(
          tmp[i - 1][j] + 1,
          tmp[i][j - 1] + 1,
          tmp[i - 1][j - 1] + (a[i - 1] === b[j - 1] ? 0 : 1)
        );
      }
    }
    return tmp[alen][blen];
  }

  function scorePronunciation(heard: string, target: string): number {
    if (heard.includes(target)) return 100;
    const dist = levenshtein(heard, target);
    const maxLen = Math.max(heard.length, target.length);
    return Math.max(0, Math.round((1 - dist / maxLen) * 90));
  }

