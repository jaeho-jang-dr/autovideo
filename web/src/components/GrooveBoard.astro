<script>
  // ── SSOT 상태 ──
  const state = {
    cho: null as string | null,
    jamoSeq: [] as string[],
    jung: null as string | null,
    jong: null as string | null,
    combo: 0,
    currentSyllable: '',
    word: '',
    english: '',
    langMode: 'ko' as 'ko' | 'en',
    // 오토마타 순환 제어용 추가 필드
    lastPadType: null as 'cho' | 'jong' | 'jung' | null,
    lastPadValue: null as string | null,
    cycleIdx: 0
  };

  // 자음/모음 데이터 맵
  const CHO_LIST = ['ㄱ','ㄲ','ㄴ','ㄷ','ㄸ','ㄹ','ㅁ','ㅂ','ㅃ','ㅅ','ㅆ','ㅇ','ㅈ','ㅉ','ㅊ','ㅋ','ㅌ','ㅍ','ㅎ'];
  const JUNG_LIST = ['ㅏ','ㅐ','ㅑ','ㅒ','ㅓ','ㅔ','ㅕ','ㅖ','ㅗ','ㅘ','ㅙ','ㅚ','ㅛ','ㅜ','ㅝ','ㅞ','ㅟ','ㅠ','ㅡ','ㅢ','ㅣ'];
  const JONG_LIST = ['', 'ㄱ', 'ㄲ', 'ㄳ', 'ㄴ', 'ㅈ', 'ㄶ', 'ㄷ', 'ㄹ', 'ㄺ', 'ㄻ', 'ㄼ', 'ㄽ', 'ㄾ', 'ㄿ', 'ㅀ', 'ㅁ', 'ㅂ', 'ㅄ', 'ㅅ', 'ㅆ', 'ㅇ', 'ㅈ', 'ㅊ', 'ㅋ', 'ㅌ', 'ㅍ', 'ㅎ'];

  // 자음 순환 사이클 정의
  const CONSONANT_CYCLES: Record<string, string[]> = {
    'ㄱ': ['ㄱ', 'ㄲ', 'ㅋ'],
    'ㄴ': ['ㄴ', 'ㄷ', 'ㄸ', 'ㅌ', 'ㄹ'],
    'ㅁ': ['ㅁ', 'ㅂ', 'ㅃ', 'ㅍ'],
    'ㅅ': ['ㅅ', 'ㅆ', 'ㅈ', 'ㅉ', 'ㅊ'],
    'ㅇ': ['ㅇ', 'ㅎ']
  };

  const ANATOMY_MAP: Record<string, { title: string; desc: string; emoji: string }> = {
    'ㄱ': { title: 'ㄱ (G/K - Velar)', desc: '舌근閉喉 (Tongue root blocks throat)', emoji: '👅' },
    'ㄴ': { title: 'ㄴ (N - Alveolar)', desc: '舌尖抵齒 (Tongue tip taps upper gums)', emoji: '🦷' },
    'ㅁ': { title: 'ㅁ (M - Bilabial)', desc: '口形상형 (Outline of meeting lips)', emoji: '👄' },
    'ㅅ': { title: 'ㅅ (S - Dental)', desc: '齒形상형 (Sharp teeth creating friction)', emoji: '🦷' },
    'ㅇ': { title: 'ㅇ (Ng - Glottal)', desc: '喉形상형 (Circular outline of open throat)', emoji: '⭕' }
  };

  // 천지인 모음 조합 결정표 (jamoSeq.join('') -> 완성 중성)
  const VOWEL_COMBINATIONS: Record<string, string> = {
    // 기본 단모음
    'ㅣ': 'ㅣ',
    'ㅡ': 'ㅡ',
    '•': '•',
    
    // ㅣ, • 조합 (ㅏ, ㅐ, ㅑ, ㅒ, ㅓ, ㅔ, ㅕ, ㅖ)
    'ㅣ•': 'ㅏ',
    'ㅣ••': 'ㅑ',
    '•ㅣ': 'ㅓ',
    '••ㅣ': 'ㅕ',
    'ㅣ•ㅣ': 'ㅐ',
    'ㅣ••ㅣ': 'ㅒ',
    '•ㅣㅣ': 'ㅔ',
    '••ㅣㅣ': 'ㅖ',
    
    // ㅡ, • 조합 (ㅗ, ㅛ, ㅜ, ㅠ)
    '•ㅡ': 'ㅗ',
    '••ㅡ': 'ㅛ',
    'ㅡ•': 'ㅜ',
    'ㅡ••': 'ㅠ',
    
    // 이중 모음 결합 (와, 왜, 외, 워, 웨, 위, 의)
    '•ㅡㅣ•': 'ㅘ',
    '•ㅡㅣ•ㅣ': 'ㅙ',
    '•ㅡㅣ': 'ㅚ',
    'ㅡ••ㅣ': 'ㅝ',
    'ㅡ••ㅣㅣ': 'ㅞ',
    'ㅡ•ㅣ': 'ㅟ',
    'ㅡㅣ': 'ㅢ'
  };

  // 겹받침 합성 매핑 테이블
  const COMPLEX_JONG_MAP: Record<string, string> = {
    'ㄱㅅ': 'ㄳ',
    'ㄴㅈ': 'ㄵ',
    'ㄴㅎ': 'ㄶ',
    'ㄹㄱ': 'ㄺ',
    'ㄹㅁ': 'ㄻ',
    'ㄹㅂ': 'ㄼ',
    'ㄹㅅ': 'ㄽ',
    'ㄹㅌ': 'ㄾ',
    'ㄹㅍ': 'ㄿ',
    'ㄹㅎ': 'ㅀ',
    'ㅂㅅ': 'ㅄ'
  };

  // 겹받침 분해 매핑 테이블
  const DECOMPOSE_JONG_MAP: Record<string, [string, string]> = {
    'ㄳ': ['ㄱ', 'ㅅ'],
    'ㄵ': ['ㄴ', 'ㅈ'],
    'ㄶ': ['ㄴ', 'ㅎ'],
    'ㄺ': ['ㄹ', 'ㄱ'],
    'ㄻ': ['ㄹ', 'ㅁ'],
    'ㄼ': ['ㄹ', 'ㅂ'],
    'ㄽ': ['ㄹ', 'ㅅ'],
    'ㄾ': ['ㄹ', 'ㅌ'],
    'ㄿ': ['ㄹ', 'ㅍ'],
    'ㅀ': ['ㄹ', 'ㅎ'],
    'ㅄ': ['ㅂ', 'ㅅ']
  };

  let audioCtx: AudioContext | null = null;
  let songBuffer: AudioBuffer | null = null;
  let songSource: AudioBufferSourceNode | null = null;
  let bgmGain: GainNode | null = null;
  let isBgmPlaying = false;

  async function ensureAudio() {
    if (!audioCtx) {
      audioCtx = new (window.AudioContext || (window as any).webkitAudioContext)();
      bgmGain = audioCtx.createGain();
      bgmGain.gain.setValueAtTime(0.15, audioCtx.currentTime); // BGM 볼륨
      bgmGain.connect(audioCtx.destination);
    }
    if (audioCtx.state === 'suspended') {
      await audioCtx.resume();
    }
  }

  async function loadSong(url: string) {
    if (songBuffer) return songBuffer;
    const res = await fetch(url);
    const arr = await res.arrayBuffer();
    if (!audioCtx) return null;
    songBuffer = await audioCtx.decodeAudioData(arr);
    return songBuffer;
  }

  // ── 한글 합자 렌더링 ──
  function renderSyllable() {
    if (!state.cho) return '—';
    if (!state.jung) return state.cho; // 자음 단독
    
    const ci = CHO_LIST.indexOf(state.cho);
    const ji = JUNG_LIST.indexOf(state.jung);
    
    if (ci < 0 || ji < 0) return state.cho;
    
    const jongIdx = state.jong ? JONG_LIST.indexOf(state.jong) : 0;
    const finalJongIdx = jongIdx < 0 ? 0 : jongIdx;
    
    return String.fromCharCode(0xAC00 + (ci * 21 + ji) * 28 + finalJongIdx);
  }

  // 970개 음원 데이터베이스 존재 여부 체크 함수
  function hasAudio(char: string): boolean {
    if (!char || char === '—') return false;
    
    // 1. 단독 자음/모음 에셋 확인
    if (JAMO_AUDIO_MAP[char]) return true;
    if (char === '•') return true;
    
    // 2. 1글자 완성형 음절 분해 분석
    if (char.length === 1) {
      const code = char.charCodeAt(0);
      if (code >= 0xAC00 && code <= 0xD7A3) {
        const offset = code - 0xAC00;
        const jongIdx = offset % 28;
        const jungIdx = Math.floor(offset / 28) % 21;
        const choIdx = Math.floor(Math.floor(offset / 28) / 21);
        
        const cho = CHO_LIST[choIdx];
        const jung = JUNG_LIST[jungIdx];
        const jong = JONG_LIST[jongIdx];
        
        // 필수 추가 상용 음절 목록
        const extraSyllables = new Set([
          '물', '주', '세', '요', '밥', '맛', '있', '어', '화', '장', '실', '디', '에', '휴', '지', '여', '권', '기', '비', '행', '표', '차',
          '없', '닭', '앉', '않', '읽', '잃', '짧', '넓', '밟', '맑', '젊', '읊', '끓', '굶', '값', '몫', '넋', '삯', '핥', '흙'
        ]);
        if (extraSyllables.has(char)) return true;
        
        // 규칙 1: 초성 5개(ㄱ,ㄴ,ㅁ,ㅅ,ㅇ) 기반 조합 + 종성 6개(없음, ㄱ, ㄴ, ㅁ, ㅅ, ㅇ)
        const choseongsBase = new Set(['ㄱ', 'ㄴ', 'ㅁ', 'ㅅ', 'ㅇ']);
        const jongseongsBase = new Set(['', 'ㄱ', 'ㄴ', 'ㅁ', 'ㅅ', 'ㅇ']);
        if (choseongsBase.has(cho) && jongseongsBase.has(jong)) {
          return true;
        }
        
        // 규칙 2: 19개 전체 자음 * 21개 모음 * 받침 없음
        if (jong === '') {
          return true;
        }
      }
    }
    return false;
  }

  function updateDisplay() {
    const displayEl = document.getElementById('display-syllable');
    const badgeEl = document.getElementById('no-audio-badge');
    if (!displayEl) return;
    
    const text = renderSyllable();
    displayEl.textContent = text;
    state.currentSyllable = text !== '—' && text.length === 1 && text !== state.cho ? text : '';

    // 소리 지원 여부 실시간 스캔 및 배지 제어
    const isComposite = text !== '—' && text !== state.cho; // 단순 단독자음 입력이 아닌 조어 상태
    if (isComposite && !hasAudio(text)) {
      displayEl.classList.add('no-audio');
      if (badgeEl) badgeEl.classList.remove('hidden');
    } else {
      displayEl.classList.remove('no-audio');
      if (badgeEl) badgeEl.classList.add('hidden');
    }

    // 모핑 팝 애니메이션
    displayEl.classList.add('pop');
    setTimeout(() => {
      displayEl.classList.remove('pop');
    }, 150);

    // AI 에이전트 마이크 버튼 제어 (EN 모드일 때는 항상 활성화)
    const micBtn = document.getElementById('btn-mic') as HTMLButtonElement;
    if (micBtn) {
      micBtn.disabled = (state.langMode === 'ko' && !state.currentSyllable);
    }

    // 발음 설명 실시간 체크
    updatePhonetics();
  }

  interface PhoneticInfo {
    pron: string;
    ruleKo: string;
    ruleEn: string;
  }

  // 한글 발음 법칙 실시간 표기 및 설명 사전
  const LOCAL_PHONETIC_MAP: Record<string, PhoneticInfo> = {
    '굳이': { pron: '[구지]', ruleKo: '구개음화: 받침 ㄷ이 조사/접미사 이와 만나 [ㅈ]로 발음', ruleEn: 'Palatalization: ㄷ sound changes to [ㅈ] before 이' },
    '같이': { pron: '[가치]', ruleKo: '구개음화: 받침 ㅌ이 조사/접미사 이와 만나 [ㅊ]로 발음', ruleEn: 'Palatalization: ㅌ sound changes to [ㅊ] before 이' },
    '돋보기': { pron: '[돋뽀기]', ruleKo: '경음화: 받침 ㄷ 뒤에 연결되는 ㅂ이 된소리 [ㅃ]로 발음', ruleEn: 'Tensification: ㅂ changes to double consonant [ㅃ] after ㄷ' },
    '꽃이': { pron: '[꼬치]', ruleKo: '연음 법칙: 받침 ㅊ이 모음 이와 만나 뒷글자 초성으로 연음', ruleEn: 'Linking Rule: ㅊ sound carries over to the next syllable' },
    '맛있어요': { pron: '[마시써요]', ruleKo: '연음 법칙: 받침 ㅅ들이 모음으로 시작하는 어미와 만나 연음', ruleEn: 'Linking Rule: 받침 ㅅ carries over to the next vowel sounds' },
    '합니다': { pron: '[함니다]', ruleKo: '비음화: 받침 ㅂ이 ㄴ을 만나 비음 [ㅁ]으로 발음', ruleEn: 'Nasalization: ㅂ sound nasalizes to [ㅁ] before ㄴ' },
    '국물': { pron: '[궁물]', ruleKo: '비음화: 받침 ㄱ이 ㅁ을 만나 비음 [ㅇ]으로 발음', ruleEn: 'Nasalization: ㄱ sound nasalizes to [ㅇ] before ㅁ' },
    '밥 먹어요': { pron: '[밤머거요]', ruleKo: '비음화 및 연음: 받침 ㅂ이 머를 만나 [ㅁ]이 되고, 먹의 받침 ㄱ이 어와 만나 [거]로 연음', ruleEn: 'Nasalization & Linking: ㅂ changes to [ㅁ], and ㄱ links with 어' },
    '신라': { pron: '[실라]', ruleKo: '유음화: 받침 ㄴ이 ㄹ을 만나 [ㄹ]로 발음', ruleEn: 'Lateralization: ㄴ changes to [ㄹ] before/after ㄹ' },
    '칼날': { pron: '[칼랄]', ruleKo: '유음화: ㄹ 뒤의 ㄴ이 [ㄹ]로 발음', ruleEn: 'Lateralization: ㄴ changes to [ㄹ] after ㄹ' },
    '독립': { pron: '[동닙]', ruleKo: '상호비음화: 받침 ㄱ과 ㄹ이 서로 만나 [ㅇ]과 [ㄴ]으로 발음', ruleEn: 'Mutual Nasalization: ㄱ and ㄹ nasalize to [ㅇ] and [ㄴ]' },
    '백마': { pron: '[뱅마]', ruleKo: '비음화: 받침 ㄱ이 ㅁ을 만나 비음 [ㅇ]으로 발음', ruleEn: 'Nasalization: ㄱ sound nasalizes to [ㅇ] before ㅁ' },
    '국민': { pron: '[궁민]', ruleKo: '비음화: 받침 ㄱ이 ㅁ을 만나 비음 [ㅇ]으로 발음', ruleEn: 'Nasalization: ㄱ sound nasalizes to [ㅇ] before ㅁ' },
    '낱낱이': { pron: '[난나치]', ruleKo: '비음화 및 구개음화: ㅌ이 ㄴ 앞에서 [ㄴ]이 되고, 뒤의 ㅌ이 이와 만나 [ㅊ]로 발음', ruleEn: 'Nasalization & Palatalization: ㅌ becomes [ㄴ], and ㅌ palatalizes to [ㅊ]' },
    '맏이': { pron: '[마지]', ruleKo: '구개음화: 받침 ㄷ이 이와 만나 [ㅈ]로 발음', ruleEn: 'Palatalization: ㄷ sound changes to [ㅈ] before 이' },
    '해돋이': { pron: '[해도지]', ruleKo: '구개음화: 받침 ㄷ이 이와 만나 [ㅈ]로 발음', ruleEn: 'Palatalization: ㄷ sound changes to [ㅈ] before 이' },
    '끝이': { pron: '[끄치]', ruleKo: '구개음화: 받침 ㅌ이 이와 만나 [ㅊ]로 발음', ruleEn: 'Palatalization: ㅌ sound changes to [ㅊ] before 이' },
    '붙여': { pron: '[부쳐]', ruleKo: '구개음화: 받침 ㅌ이 여와 만나 [쳐]로 발음', ruleEn: 'Palatalization: ㅌ sound changes to [ㅊ] before 여' },
    '값이 싸다': { pron: '[갑시 싸다]', ruleKo: '연음 법칙: 겹받침 ㅄ에서 ㅅ이 뒤의 이로 연음되어 [갑시]로 발음되고, 싸다와 연결됩니다.', ruleEn: 'Linking Rule: The second consonant ㅅ in ㅄ carries over to 이, pronounced [gap-si ssada]' },
    '값이': { pron: '[갑시]', ruleKo: '연음 법칙: 겹받침 ㅄ 뒤에 모음 이가 오면, 뒷자음 ㅅ이 다음 첫소리로 넘어가 [갑시]로 발음됩니다.', ruleEn: 'Linking Rule: When 이 follows the cluster ㅄ, the second consonant ㅅ carries over to the next syllable, pronounced [gap-si]' },
    '읽는다': { pron: '[익는다]', ruleKo: '자음 단순화 및 비음화: 겹받침 ㄺ 뒤에 ㄴ이 오면 ㄹ이 탈락하고, ㄱ이 ㄴ을 만나 비음 [ㅇ]으로 변하여 최종적으로 [익는다] 또는 [잉는다]로 발음됩니다.', ruleEn: 'Cluster simplification & nasalization: before ㄴ the cluster ㄺ drops ㄹ, and ㄱ nasalizes to [ㅇ], yielding [ik-neunda] / [ing-neunda]' }
  };

  // 발음 법칙 실시간 갱신 함수
  function updatePhonetics() {
    const currentText = renderSyllable();
    const finalSyllable = (currentText !== '—' && currentText !== state.cho) ? currentText : '';
    const fullText = (state.word + finalSyllable).trim();

    const phoneticRow = document.getElementById('phonetic-row');
    const phoneticPron = document.getElementById('phonetic-pron');
    const phoneticRule = document.getElementById('phonetic-rule');

    if (!phoneticRow || !phoneticPron || !phoneticRule) return;

    if (!fullText) {
      phoneticRow.classList.add('hidden');
      return;
    }

    // LOCAL_PHONETIC_MAP에서 매칭되는 단어가 있는지 찾기 (가장 긴 매치 우선)
    let matchedKey = '';
    for (const key in LOCAL_PHONETIC_MAP) {
      if (fullText.includes(key)) {
        if (!matchedKey || key.length > matchedKey.length) {
          matchedKey = key;
        }
      }
    }

    if (matchedKey) {
      const match = LOCAL_PHONETIC_MAP[matchedKey];
      phoneticPron.textContent = match.pron;
      phoneticRule.textContent = state.langMode === 'en' ? match.ruleEn : match.ruleKo;
      phoneticRow.classList.remove('hidden');
    } else {
      phoneticRow.classList.add('hidden');
    }
  }

  function updateWordDisplay() {
    const wordTextEl = document.getElementById('word-text') as HTMLInputElement | null;
    if (wordTextEl) {
      // input 박스이므로 value로 동기화 (비었을 땐 빈 문자열을 셋해 placeholder가 보이도록)
      wordTextEl.value = state.word;
    }

    // 단어가 있으면 한꺼번에 지우기(×) 버튼 노출, 비어 있으면 숨김
    const clearAllEl = document.getElementById('btn-clear-all');
    if (clearAllEl) {
      clearAllEl.style.display = state.word ? 'flex' : 'none';
    }

    const englishTextEl = document.getElementById('english-text');
    const englishRow = document.getElementById('english-row');
    if (englishTextEl && englishRow) {
      if (state.english) {
        englishTextEl.textContent = state.english;
        englishRow.style.display = 'flex';
      } else {
        englishRow.style.display = 'none';
      }
    }

    // 게임 정답 실시간 스캔 채점 호출
    checkGameAnswer();

    // 발음 설명 실시간 체크
    updatePhonetics();
  }

  // 천지인 입력 가능한 모든 유효 접두사 집합 생성
  const VALID_VOWEL_PREFIXES = new Set<string>();
  for (const key in VOWEL_COMBINATIONS) {
    for (let i = 1; i <= key.length; i++) {
      VALID_VOWEL_PREFIXES.add(key.slice(0, i));
    }
  }

  // 모음 상태 처리기
  function composeVowel(seq: string[]) {
    const combined = seq.join('');
    
    // 1. 완벽히 매칭되는 모음이 있으면 그것을 반환
    if (VOWEL_COMBINATIONS[combined]) {
      return VOWEL_COMBINATIONS[combined];
    }
    
    // 2. 만약 현재 입력 시퀀스가 유효한 모음의 접두사 중 하나라면,
    // 매칭되는 도중이므로 임시로 빈 모음이나 이전 단계 모음을 유지
    if (VALID_VOWEL_PREFIXES.has(combined)) {
      // 최대한 매칭 가능한 이전 단계 모음이라도 찾아서 반환 (예: "•ㅡㅣ" 까지 쳤을 때 "ㅚ" 반환)
      for (let len = combined.length - 1; len > 0; len--) {
        const sub = combined.slice(0, len);
        if (VOWEL_COMBINATIONS[sub]) {
          return VOWEL_COMBINATIONS[sub];
        }
      }
      return null;
    }
    
    // 3. 만약 유효하지 않은 조합 시퀀스가 쌓였다면 안전하게 마지막 입력만 남김
    if (seq.length > 0) {
      const last = seq[seq.length - 1];
      state.jamoSeq = [last];
      return VOWEL_COMBINATIONS[last] || null;
    }
    
    return null;
  }

