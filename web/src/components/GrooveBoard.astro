}

.stage-help-container {
  margin: 10px 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  z-index: 100;
  width: 100%;
}

.stage-help-trigger-btn {
  background: var(--gv-surface);
  border: 1px solid var(--gv-border);
  color: var(--gv-text-1);
  padding: 6px 12px;
  border-radius: 20px;
  font-size: 0.75rem;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.2s ease;
}

.stage-help-trigger-btn:hover {
  background: var(--gv-surface-2);
  border-color: var(--gv-neon-cho);
  box-shadow: 0 0 8px hsl(325 100% 64% / 0.3);
  transform: scale(1.05);
}

.stage-help-box {
  position: absolute;
  top: 36px;
  background: hsl(245 35% 8% / 0.95);
  border: 1px solid var(--gv-neon-cho);
  border-radius: 8px;
  padding: 12px 14px;
  font-size: 0.75rem;
  line-height: 1.5;
  color: var(--gv-text-1);
  width: 280px;
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.8), 0 0 15px hsl(325 100% 64% / 0.15);
  text-align: left;
  z-index: 200;
  backdrop-filter: blur(8px);
}

.stage-help-box.hidden {
  display: none;
}

/* 🎹 Hangeul Keyboard Hover/Touch Popup Styles */
.pad-wrapper {
  position: relative;
  display: inline-flex;
}

.pad-popup {
  position: absolute;
  bottom: 115%; /* Float above the key */
  left: 50%;
  transform: translateX(-50%) translateY(6px);
  display: flex;
  flex-direction: row;
  gap: 6px;
  padding: 6px;
  background: hsl(245 40% 6% / 0.95);
  border: 1.5px solid var(--gv-border-active);
  border-radius: 8px;
  box-shadow: 0 12px 30px rgb(0 0 0 / 0.7), 0 0 15px hsl(325 100% 64% / 0.2);
  z-index: 250;
  pointer-events: none;
  opacity: 0;
  transition: all 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.2);
  backdrop-filter: blur(8px);
  white-space: nowrap;
  
  /* 길게 누를 때 브라우저 텍스트 선택/복사 및 컨텍스트 방지 */
  -webkit-user-select: none;
  -moz-user-select: none;
  -ms-user-select: none;
  user-select: none;
  -webkit-touch-callout: none;
}

.pad-popup.active {
  pointer-events: auto;
  opacity: 1;
  transform: translateX(-50%) translateY(0);
}

/* ㄴ 패드처럼 화면 왼쪽에 치우친 경우 팝업을 오른쪽으로 시프팅 */
.pad-popup.shift-right {
  left: 60%;
  transform: translateX(0) translateY(6px);
}
.pad-popup.shift-right.active {
  transform: translateX(0) translateY(0);
}
.pad-popup.shift-right::after {
  left: 15px;
  transform: translateX(-50%);
}

/* ㅣ 패드처럼 화면 오른쪽에 치우친 경우 팝업을 왼쪽으로 시프팅 */
.pad-popup.shift-left {
  left: auto;
  right: 100%;
  transform: translateX(0) translateY(6px);
}
.pad-popup.shift-left.active {
  transform: translateX(0) translateY(0);
}
.pad-popup.shift-left::after {
  left: auto;
  right: -17px;
  transform: translateX(50%);
}

/* Arrow pointer for popup */
.pad-popup::after {
  content: '';
  position: absolute;
  top: 100%;
  left: 50%;
  transform: translateX(-50%);
  border-width: 6px;
  border-style: solid;
  border-color: var(--gv-border-active) transparent transparent transparent;
}

.popup-item {
  background: var(--gv-surface);
  border: 1px solid var(--gv-border);
  color: var(--gv-text-1);
  width: 34px;
  height: 34px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.15rem;
  font-weight: 800;
  border-radius: 6px;
  cursor: pointer;
  transition: all 0.15s ease;
  box-sizing: border-box;

  /* 길게 누를 때 브라우저 텍스트 선택/복사 및 컨텍스트 방지 */
  -webkit-user-select: none;
  -moz-user-select: none;
  -ms-user-select: none;
  user-select: none;
  -webkit-touch-callout: none;
}

.popup-item:hover {
  background: var(--gv-neon-cho);
  color: #fff;
  border-color: var(--gv-neon-cho);
  box-shadow: 0 0 8px var(--gv-neon-cho);
  transform: scale(1.1);
}

/* Vowel specific neon hover (green neon) */
.pad-wrapper:nth-child(n+6) .popup-item:hover,
.vowels .popup-item:hover {
  background: var(--gv-neon-jung, #39ff14);
  border-color: var(--gv-neon-jung, #39ff14);
  box-shadow: 0 0 8px var(--gv-neon-jung, #39ff14);
}

.stage-instruction-box {
  margin-top: 14px;
  padding: 10px 12px;
  font-size: 0.74rem;
  line-height: 1.45;
  color: var(--gv-text-1);
  text-align: left;
  border-radius: var(--gv-radius-sm);
  background: var(--gv-surface);
  border: 1px solid var(--gv-border);
