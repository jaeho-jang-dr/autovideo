---
import { youtubeId, type Lang } from '../lib/content';
import { t } from '../lib/i18n';

interface Props { value: string | null; title: string; lang: Lang; }
const { value, title, lang } = Astro.props;
const tr = t(lang);
const id = youtubeId(value);
const src = id ? `https://www.youtube-nocookie.com/embed/${id}` : null;
---
<div class="player glass neon">
  {src ? (
    <iframe
      src={src}
      title={title}
      loading="lazy"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
      referrerpolicy="strict-origin-when-cross-origin"
      allowfullscreen
    ></iframe>
  ) : (
    <div class="player-fallback">
      <span class="play" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="#fff"><path d="M8 5v14l11-7z" /></svg>
      </span>
      <span class="cs-title">{tr.coming_soon}</span>
      <span class="cs-desc">{tr.coming_soon_desc}</span>
    </div>
  )}
</div>
