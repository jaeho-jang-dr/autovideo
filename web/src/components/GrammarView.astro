<script>
  // ---- 조음 기관 및 카드 호버/포커스 연동 ----
  const cards = document.querySelectorAll('.grammar-card');
  const badges = document.querySelectorAll('.legend-badge');

  // 부위 → 움직일 구조물 레이어(들). 그 부위만 움직임.
  const ZONE_PARTS = {
    lips: ['vp-lip_lower', 'vp-lip_upper'],
    teeth: ['vp-teeth'],
    tongue: ['vp-tongue'],
    palate: ['vp-palate'],
    throat: ['vp-throat'],
  };

  function highlightZone(zoneName) {
    // 모든 강조/동작 해제
    document.querySelectorAll('.organ-zone').forEach(z => z.classList.remove('highlighted'));
    document.querySelectorAll('.vpart').forEach(p => p.classList.remove('playing'));
    badges.forEach(b => b.classList.remove('active'));

    if (!zoneName) return;

    // 위치 표시(은은한 원) + 범례 활성
    const zone = document.getElementById(`zone-${zoneName}`);
    if (zone) zone.classList.add('highlighted');
    const badge = document.querySelector(`.legend-badge[data-zone="${zoneName}"]`);
    if (badge) badge.classList.add('active');

    // ★ 그 부위 구조물만 직접 움직임
    (ZONE_PARTS[zoneName] || []).forEach(id => {
      const p = document.getElementById(id);
      if (p) p.classList.add('playing');
    });
  }

  // 부위별 대표 발음 (이름 클릭 시 소리 낼 때처럼 움직이며 소리도 재생)
  const ZONE_SOUND = { lips: '므', teeth: '스', tongue: '느', palate: '그', throat: '흐' };
  function playZoneSound(zone) {
    const s = ZONE_SOUND[zone];
    if (!s) return;
    const a = new Audio(`/audio/jamo/${encodeURIComponent(s)}.mp3`);
    a.play().catch(() => {});
  }

  // ---- 클릭(고정) + 호버(미리보기): 터치기기에서도 작동 ----
  let lockedZone = null;
  function setLocked(zone) {
    lockedZone = (lockedZone === zone) ? null : zone;   // 같은 걸 다시 누르면 해제
    highlightZone(lockedZone);
    if (lockedZone) playZoneSound(lockedZone);          // 이름 누르면 대표 소리도 재생
  }
  cards.forEach(card => {
    const zone = card.getAttribute('data-highlight');
    if (!zone) return;
    card.style.cursor = 'pointer';
    card.addEventListener('mouseenter', () => { if (!lockedZone) highlightZone(zone); });
    card.addEventListener('mouseleave', () => { highlightZone(lockedZone); });
    card.addEventListener('click', (e) => {
      if (e.target.closest('.play-btn')) return;        // 소리 버튼 클릭은 제외
      setLocked(zone);
    });
  });

  badges.forEach(badge => {
    const zone = badge.getAttribute('data-zone');
    badge.addEventListener('mouseenter', () => { if (!lockedZone) highlightZone(zone); });
    badge.addEventListener('mouseleave', () => { highlightZone(lockedZone); });
    badge.addEventListener('click', () => setLocked(zone));
  });

  // 다이어그램 자리 자체에서도 안내 — 로드 시 5개 부위를 순서대로 깜빡여 인터랙티브임을 알림
  const zoneOrder = ['lips', 'teeth', 'tongue', 'palate', 'throat'];
  let hintI = 0;
  const hintTimer = setInterval(() => {
    if (lockedZone) { clearInterval(hintTimer); highlightZone(lockedZone); return; }
    highlightZone(zoneOrder[hintI % zoneOrder.length]);
    hintI++;
    if (hintI > zoneOrder.length) { clearInterval(hintTimer); highlightZone(null); }
  }, 700);

  // ---- 탭 제어 ----
  const tabs = document.querySelectorAll('.tab-btn');
  const contents = document.querySelectorAll('.tab-content');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const target = tab.getAttribute('data-target');
      
      // 탭 토글
      tabs.forEach(t => {
        const on = t === tab;
        t.classList.toggle('active', on);
        t.setAttribute('aria-selected', on ? 'true' : 'false');
      });

      // 콘텐츠 토글
      contents.forEach(c => {
        c.classList.toggle('hidden', c.getAttribute('id') !== `content-${target}`);
      });
    });
  });

  // ---- 사전 생성된 성우(gTTS) 음성 파일 재생 (기계음 100% 제거) ----
  const playButtons = document.querySelectorAll('.play-btn');

  function playTTS(text) {
    const audioUrl = `/audio/jamo/${encodeURIComponent(text)}.mp3`;
    const audio = new Audio(audioUrl);
    audio.play().catch(err => {
      console.warn('Pre-generated voice audio not found on server for text:', text, err);
    });
  }

  playButtons.forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const sound = btn.getAttribute('data-sound');
      if (sound) playTTS(sound);
    });
  });
</script>

