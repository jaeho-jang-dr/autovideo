  }
  .wc-top { display: flex; align-items: center; justify-content: space-between; }
  .wc-week {
    font-family: var(--font-display, 'Outfit', sans-serif); font-weight: 700; font-size: 0.78rem;
    letter-spacing: 0.03em; text-transform: uppercase; color: var(--c-gold);
    padding: 3px 9px; border-radius: 7px; background: var(--c-gold-soft);
  }
  .wc-lock { font-size: 0.9rem; opacity: 0; transition: opacity 0.2s; }
  .wc-title { font-size: 1.04rem; font-weight: 700; line-height: 1.3; color: var(--c-ink); }
  .wc-target { font-size: 0.82rem; color: var(--c-ink-3); line-height: 1.5; word-break: keep-all; }
  /* 1주차: 영상 썸네일 카드 */
  .week-card.has-thumb { padding-top: 0; overflow: hidden; }
  .wc-thumb {
    width: calc(100% + 40px); margin: 0 -20px 12px; aspect-ratio: 16 / 9; object-fit: cover;
    display: block; border-bottom: 1px solid var(--c-line);
  }
  .wc-play {
    font-size: 0.78rem; color: #fff; background: var(--c-gold); width: 24px; height: 24px;
    border-radius: 50%; display: grid; place-items: center; padding-left: 2px;
    box-shadow: 0 2px 8px var(--c-glow);
  }
  .week-card.has-thumb:hover .wc-thumb { filter: brightness(1.04); }

  /* 잠긴 카드 */
  .week-card.locked {
    opacity: 0.5; cursor: not-allowed; filter: grayscale(0.3);
  }
  .week-card.locked:hover { transform: none; border-color: var(--c-line); box-shadow: 0 3px 12px rgba(60,48,30,0.06); }
  .week-card.locked .wc-lock { opacity: 0.7; }
  .week-card.locked .wc-week { color: var(--c-ink-3); background: rgba(28,24,19,0.06); }

  /* --- 모달 --- */
  .cur-modal { position: fixed; inset: 0; z-index: 200; display: none; }
  .cur-modal.open { display: grid; place-items: center; padding: 22px; }
