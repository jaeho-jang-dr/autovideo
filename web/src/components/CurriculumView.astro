        <div class="mcomp-video-wrap">
          <video class="mcomp-video-player" id="lesson-video" controls playsinline preload="metadata" poster="${posterUrl}" src="${srcUrl}"></video>
          <button class="mcomp-fs-btn" type="button" aria-label="${fsLabel}" title="${fsLabel}">⛶</button>
        </div>
        <div class="mcomp-vctrl">
          <button data-act="restart">↺ ${isKo ? '처음' : 'Start'}</button>
          <button data-act="back">⏪ 10s</button>
          <button data-act="play">⏯ ${isKo ? '재생/정지' : 'Play'}</button>
          <button data-act="fwd">10s ⏩</button>
          <button data-act="full">⛶ ${fsLabel}</button>
        </div>`;
      const _v = el.querySelector('#lesson-video');
      const goFull = () => { const fn = _v.requestFullscreen || _v.webkitRequestFullscreen || _v.webkitEnterFullscreen || _v.msRequestFullscreen; if (fn) { try { fn.call(_v); } catch (e) { _v.play(); } } else { _v.play(); } };
      el.querySelector('.mcomp-fs-btn').addEventListener('click', goFull);
      el.querySelectorAll('.mcomp-vctrl button').forEach((b) => b.addEventListener('click', () => {
        const a = b.dataset.act;
        if (a === 'restart') { _v.currentTime = 0; _v.play(); }
        else if (a === 'back') { _v.currentTime = Math.max(0, _v.currentTime - 10); }
        else if (a === 'fwd') { _v.currentTime = Math.min(_v.duration || 1e9, _v.currentTime + 10); }
        else if (a === 'play') { _v.paused ? _v.play() : _v.pause(); }
        else if (a === 'full') { goFull(); }
      }));
      if (autoplay) _v.play().catch(() => {});
    }

    // (0) 이번 주 7일 강의 (월~일) — 요일별 7패턴 썸네일 + 제목. Day1=핵심영상(앵커), 영상 있는 날은 ▶.
    const week7El = $('mcomp-week7-content');
    if (week7El) {
      const days = (DATA.lessonsByWeek && DATA.lessonsByWeek[wk]) || [];
      const dn = DATA.dayNames || ['월', '화', '수', '목', '금', '토', '일'];
      const newLbl = 'NEW';
      const vidLbl = isKo ? '▶ 영상' : '▶ Video';
      week7El.innerHTML = days.map((d) => {
        const hv = hasDayVideo(d);
        return `
        <button type="button" class="w7-card${d.anchor ? ' w7-anchor' : ''}" data-day="${d.day}" data-anchor="${d.anchor ? 1 : 0}">
          <img class="w7-thumb" src="/docs/lesson_thumbs/w${wk}_d${d.day}_${vsfx}.png" alt="" loading="lazy" />
          <span class="w7-badge ${hv ? 'w7-b-v' : 'w7-b-n'}">${hv ? vidLbl : newLbl}</span>
          <span class="w7-meta"><b>${wk}-${d.day} · ${d.skill}</b><i>${d.title}</i></span>
        </button>`; }).join('');
      // 클릭: 영상 있는 날 → 영상 섹션에 로드+재생+스크롤. 영상 없는 날 → 카드 강조(순차 개방).
      week7El.querySelectorAll('.w7-card').forEach((c) => c.addEventListener('click', () => {
        const day = +c.getAttribute('data-day');
        week7El.querySelectorAll('.w7-card').forEach((x) => x.classList.remove('w7-on'));
        c.classList.add('w7-on');
        if (c.getAttribute('data-anchor') === '1') {
          if (mediaOf(lv, wk).video) buildVideoPlayer(`${R2}/docs/hangeul_w${wk}_stickman_${vsfx}.mp4`, `/docs/hangeul_w${wk}_thumbnail_${vsfx}.png`, true);
          scrollToVideo();
        } else if (DAILY_VIDEOS[`${wk}-${day}`]) {
          buildVideoPlayer(`${R2}/docs/${DAILY_VIDEOS[`${wk}-${day}`]}_${vsfx}.mp4`, `/docs/lesson_thumbs/w${wk}_d${day}_${vsfx}.png`, true);
          scrollToVideo();
        }
      }));
    }

    // 5 Components Dynamic Content Binding
    const isWeek1 = lv === 'beginner' && wk === 1;
    const media = mediaOf(lv, wk);                                          // 주차별 보유 미디어
    const wkNum = media.video ? wk : 0;                                     // 영상 있는 주차
    const pdfSfx = DATA.lang === 'ko' ? '' : '_en';                          // ko=_guide.pdf, en=_guide_en.pdf

    // (1) Video Content — 기본=핵심영상(월). 7일 스트립에서 다른 요일 영상으로 교체된다.
    if (wkNum) {
      buildVideoPlayer(`${R2}/docs/hangeul_w${wkNum}_stickman_${vsfx}.mp4`, `/docs/hangeul_w${wkNum}_thumbnail_${vsfx}.png`, false);
    } else {
      $('mcomp-video-content').innerHTML = `<div class="mcomp-placeholder">${LABELS.prepLabel}</div>`;
    }

    // (2) Podcast Content (NotebookLM 오디오 개요 — 보유 주차만)
    const podcastContentEl = $('mcomp-podcast-content');
    if (media.podcast) {
      const psfx = DATA.lang === 'ko' ? '' : '_en';
      podcastContentEl.innerHTML = `<audio class="mcomp-audio-player" controls preload="none" src="${R2}/audio/podcasts/hangeul_week_${wk}_podcast${psfx}.m4a"></audio>`;
    } else {
      podcastContentEl.innerHTML = `<div class="mcomp-placeholder">${LABELS.prepLabel}</div>`;
    }

    // (3) PDF Content (스터디 가이드 PDF — 보유 주차만, 언어별)
    const pdfContentEl = $('mcomp-pdf-content');
    if (media.pdf) {
      pdfContentEl.innerHTML = `<a class="mcomp-link-btn" href="/docs/hangeul_week_${wk}_guide${pdfSfx}.pdf" target="_blank" rel="noopener">📄 ${LABELS.downloadPdf}</a>`;
    } else {
      pdfContentEl.innerHTML = `<div class="mcomp-placeholder">${LABELS.prepLabel}</div>`;
    }

    // (4) Study Notes (Steps)
    let steps = [];
    if (isWeek1) {
      steps = WEEK1_NOTES[DATA.lang] || [];
    } else {
      steps = [
        { n: 1, label: LABELS.step1, body: `<p>${w.concept}</p>`, time: '20' + LABELS.mins },
        { n: 2, label: LABELS.step2, body: `<p>${w.practice}</p>`, time: '20' + LABELS.mins },
        { n: 3, label: LABELS.step3, body: `<p>${w.application}</p>`, time: '20' + LABELS.mins },
      ];
    }
    $('modal-steps').innerHTML = steps.map((s) =>
      `<li class="mstep"><span class="ms-no">${s.n}</span>` +
      `<div class="ms-body"><div class="ms-head"><b>${s.label}</b><span class="ms-time">${s.time}</span></div>` +
      `<div class="ms-body-desc">${s.body}</div></div></li>`
    ).join('') + (media.notes
      ? `<li class="mstep mstep-dl"><a class="mcomp-link-btn" href="/docs/hangeul_week_${wk}_notes_${langSuffix}.md" target="_blank" rel="noopener">📝 ${DATA.lang === 'ko' ? '전체 요약 노트' : 'Full study notes'}</a></li>`
      : '');

    // (5) Game Content
    const gameContentEl = $('mcomp-game-content');
    gameContentEl.innerHTML = `<a class="mcomp-link-btn" href="${DATA.lang === 'ko' ? '/ko/groove' : '/groove'}">🎮 ${LABELS.playGame}</a>`;

    $('modal-reward').innerHTML =
      `<span class="mr-label">🎁 ${LABELS.rewardTitle}</span><span class="mr-text">${REWARDS[lv] || ''}</span>`;
    modal.classList.add('open');
    modal.setAttribute('aria-hidden', 'false');
    const _mc = modal.querySelector('.modal-card');
    if (_mc) _mc.scrollTop = 0;   // 영상이 맨 위에 보이도록
  }

  // 모달 내 오디오 칩 클릭 이벤트 위임 리스너 추가
  if (modal) {
    modal.addEventListener('click', (e) => {
      const chip = e.target.closest('.audio-chip');
      if (chip) {
        const sound = chip.getAttribute('data-sound');
        if (sound) {
          const audioUrl = `/audio/jamo/${encodeURIComponent(sound)}.mp3`;
          const audio = new Audio(audioUrl);
          audio.play().catch(err => {
            console.warn('Pre-generated voice audio not found on server for text:', sound, err);
          });
        }
      }
    });
  }
  function closeModal() {
    modal.classList.remove('open');
    modal.setAttribute('aria-hidden', 'true');
  }

  // ---- 드래그 가능한 대형 영상 창 ----
  const VW_R2 = 'https://pub-a8312324e7b445f8a1985f759cddeff7.r2.dev';
  function openVidWin(lv, wk, title) {
    const vsfx = DATA.lang === 'ko' ? 'ko' : 'en';
    const ko = DATA.lang === 'ko';
    const m = mediaOf(lv, wk);
    $('vidwin-title').textContent = `${LABELS.week} ${wk} · ${title || ''}`;
    $('vidwin-body').innerHTML = `<video id="vw-video" controls autoplay playsinline preload="metadata"
      poster="/docs/hangeul_w${wk}_thumbnail_${vsfx}.png" src="${VW_R2}/docs/hangeul_w${wk}_stickman_${vsfx}.mp4"></video>`;
    $('vidwin-foot').innerHTML =
      (m.podcast ? `<button type="button" data-vf="pod">🎧 ${ko ? '팟캐스트' : 'Podcast'}</button>` : '') +
      (m.pdf ? `<a href="/docs/hangeul_week_${wk}_guide${ko ? '' : '_en'}.pdf" target="_blank" rel="noopener">📄 ${ko ? '가이드 PDF' : 'Guide PDF'}</a>` : '') +
      `<button type="button" data-vf="lesson">📚 ${ko ? '연습·학습' : 'Practice'}</button>`;
    const podBtn = $('vidwin-foot').querySelector('[data-vf="pod"]');
    if (podBtn) podBtn.addEventListener('click', function () {
      if (this.dataset.on) return; this.dataset.on = '1'; this.textContent = '🎧 ▶';
      const a = document.createElement('audio'); a.controls = true; a.autoplay = true;
      a.src = `${VW_R2}/audio/podcasts/hangeul_week_${wk}_podcast${ko ? '' : '_en'}.m4a`; $('vidwin-foot').appendChild(a);
    });
    $('vidwin-foot').querySelector('[data-vf="lesson"]').addEventListener('click', () => openModal(lv, wk));
    const win = $('vidwin');
    if (window.matchMedia('(max-width: 640px)').matches) {   // 모바일: 화면 꽉 차게 고정
      win.style.left = '2vw'; win.style.top = '7vh'; win.style.transform = 'none'; win.style.width = '96vw';
    } else {                                                 // PC: 중앙, 이동 가능
      win.style.left = '50%'; win.style.top = '6vh'; win.style.transform = 'translateX(-50%)'; win.style.width = '';
    }
    win.classList.add('open'); win.setAttribute('aria-hidden', 'false');
  }
  function closeVidWin() {
    const w = $('vidwin'); w.classList.remove('open'); w.setAttribute('aria-hidden', 'true'); $('vidwin-body').innerHTML = '';
  }
  $('vidwin-close').addEventListener('click', closeVidWin);
  $('vidwin-full').addEventListener('click', () => {
    const v = document.getElementById('vw-video'); if (!v) return;
    const fn = v.requestFullscreen || v.webkitRequestFullscreen || v.webkitEnterFullscreen || v.msRequestFullscreen;
    if (fn) { try { fn.call(v); } catch (e) {} }
  });
  (function dragify() {
    const win = $('vidwin'), bar = $('vidwin-bar'); let dx = 0, dy = 0, on = false;
    function start(cx, cy) { const r = win.getBoundingClientRect(); win.style.transform = 'none'; win.style.left = r.left + 'px'; win.style.top = r.top + 'px'; dx = cx - r.left; dy = cy - r.top; on = true; }
    function move(cx, cy) { if (!on) return; win.style.left = (cx - dx) + 'px'; win.style.top = Math.max(0, cy - dy) + 'px'; }
    bar.addEventListener('mousedown', (e) => { if (e.target.closest('button')) return; start(e.clientX, e.clientY); e.preventDefault(); });
    window.addEventListener('mousemove', (e) => move(e.clientX, e.clientY));
    window.addEventListener('mouseup', () => { on = false; });
    bar.addEventListener('touchstart', (e) => {
      if (window.matchMedia('(max-width: 640px)').matches) return;   // 모바일은 드래그 안 함
      if (e.target.closest('button')) return; const t = e.touches[0]; start(t.clientX, t.clientY);
    }, { passive: true });
    window.addEventListener('touchmove', (e) => { if (!on) return; const t = e.touches[0]; move(t.clientX, t.clientY); }, { passive: true });
    window.addEventListener('touchend', () => { on = false; });
  })();

  // ---- 이벤트 바인딩 ----
  studySlider.addEventListener('input', refreshReadout);
  scoreSlider.addEventListener('input', refreshReadout);
  $('eval-btn').addEventListener('click', evaluateAndUnlock);
  $('manual-btn').addEventListener('click', manualUnlock);
  $('reset-btn').addEventListener('click', resetProgress);

  document.querySelectorAll('.tab').forEach((t) =>
    t.addEventListener('click', () => selectLevel(t.getAttribute('data-level')))
  );

  document.querySelectorAll('.week-card').forEach((card) =>
    card.addEventListener('click', () => {
      if (card.classList.contains('locked')) return;
      const lv = card.getAttribute('data-level');
      const wk = parseInt(card.getAttribute('data-week'), 10);
      const title = (card.querySelector('.wc-title') || {}).textContent || '';
      if (mediaOf(lv, wk).video) openVidWin(lv, wk, title);   // 영상 있는 주차 → 드래그 영상 창
      else openModal(lv, wk);
    })
  );

  modal.querySelectorAll('[data-close]').forEach((b) => b.addEventListener('click', closeModal));
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

  // ---- 초기 렌더 ----
  refreshReadout();
  renderLocks();
  selectLevel(currentLevel);
  refreshSummary();
</script>

