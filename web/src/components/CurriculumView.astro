---
import type { Lang } from '../lib/content';
import {
  LEVELS, weeksByLevel, levelName, rewardText,
  weekTitle, weekConcept, weekPractice, weekApplication,
} from '../lib/curriculum';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const isEn = lang === 'en';

// UI 라벨 (페이지가 언어별이므로 서버에서 해당 언어로 확정)
const L = {
  title: isEn ? 'Hunminjeongeum' : '훈민정음',
  subtitle: isEn
    ? '24 weeks (6 Months) · 3 levels · daily 1 hour = Concept (20m) + Interactive Practice (20m) + Real-life Application (20m).'
    : '24주(6개월) · 3단계 · 하루 1시간 = 개념 이해(20분) + 시청각·놀이 연습(20분) + 실생활 적용(20분).',
  panelTitle: isEn ? 'Progress Simulator' : '진도 시뮬레이터',
  panelDesc: isEn
    ? 'Adjust the sliders to see whether the next week unlocks.'
    : '슬라이더를 움직여 다음 주차가 해금되는지 확인하세요.',
  studyLabel: isEn ? 'Study Time Completion' : '학습 시간 달성률',
  scoreLabel: isEn ? 'Weekly Game Score' : '주간 게임 점수',
  weighted: isEn ? 'Weighted Pass Score' : '가중 통과 점수',
  status: isEn ? 'Status' : '판정',
  evalBtn: isEn ? 'Evaluate & Unlock Next Week' : '평가하고 다음 주 해금',
  manualBtn: isEn ? 'Manual Unlock (sandbox)' : '수동 해금 (샌드박스)',
  resetBtn: isEn ? 'Reset Progress' : '진도 초기화',
  streak: isEn ? 'Free-pass streak' : '연속 프리패스',
  unlockedUpTo: isEn ? 'Unlocked up to week' : '해금된 주차',
  cooldownOn: isEn ? 'Cooldown lockout active' : '쿨다운 잠금 중',
  rules: isEn
    ? 'Regular Pass ≥ 70%  ·  Excellent Free-Pass: score ≥ 900  ·  Perfect Free-Pass: score = 1000  ·  5 free-passes in a row → 48h cooldown'
    : '일반 통과 ≥ 70%  ·  우수 프리패스: 점수 ≥ 900  ·  완벽 프리패스: 점수 = 1000  ·  프리패스 5회 연속 → 48시간 쿨다운',
  step1: isEn ? 'Concept Study' : '개념 이해',
  step2: isEn ? 'Interactive Practice' : '시청각·놀이 연습',
  step3: isEn ? 'Real-life Application' : '실생활 적용',
  rewardTitle: isEn ? 'Level Reward' : '레벨 보상',
  target: isEn ? 'Target' : '학습 대상',
  week: isEn ? 'Week' : '주차',
  locked: isEn ? 'Locked' : '잠김',
  close: isEn ? 'Close' : '닫기',
  
  // 5 Components Labels
  videoLabel: isEn ? '1. Lecture Video (7-8 mins)' : '1. 강의 동영상 (7-8분)',
  podcastLabel: isEn ? '2. Audio Podcast (20 mins)' : '2. 오디오 팟캐스트 (20분)',
  pdfLabel: isEn ? '3. Study Guide PDF (15 pages)' : '3. 학습 가이드 PDF (15페이지)',
  notesLabel: isEn ? '4. Lecture & Study Notes' : '4. 강의 및 학습 노트',
  gameLabel: isEn ? '5. Interactive Hangeul Game' : '5. 아케이드 한글 게임',
  downloadPdf: isEn ? 'Download Study Guide PDF' : '학습 가이드 PDF 다운로드',
  playGame: isEn ? 'Launch Hangeul Game Cockpit' : '한글 게임 콕핏 실행',
  prepLabel: isEn ? 'Coming Soon / Under Preparation' : '준비 중 / 순차 개방 예정',
};

// 클라이언트 스크립트로 넘길 데이터 (현재 언어로 확정)
const payload = {
  lang,
  levels: LEVELS,
  levelNames: Object.fromEntries(LEVELS.map((lv) => [lv, levelName(lv, lang)])),
  rewards: Object.fromEntries(LEVELS.map((lv) => [lv, rewardText(lv, lang)])),
  weeks: LEVELS.flatMap((lv) =>
    weeksByLevel(lv).map((w) => ({
      level: w.level,
      week: w.week,
      title: weekTitle(w, lang),
      target: w.target_letters,
      concept: weekConcept(w, lang),
      practice: weekPractice(w, lang),
      application: weekApplication(w, lang),
    }))
  ),
  labels: {
    step1: L.step1, step2: L.step2, step3: L.step3,
    rewardTitle: L.rewardTitle, target: L.target, week: L.week,
    locked: L.locked, unlockedUpTo: L.unlockedUpTo, cooldownOn: L.cooldownOn,
    streak: L.streak, status: L.status,
    passRegular: isEn ? 'Regular Pass ✓' : '일반 통과 ✓',
    passExcellent: isEn ? 'Excellent Free-Pass ★' : '우수 프리패스 ★',
    passPerfect: isEn ? 'Perfect Free-Pass ☀' : '완벽 프리패스 ☀',
    fail: isEn ? 'Not enough — keep studying' : '미달 — 조금 더 학습하세요',
    cooldownMsg: isEn ? 'Cooldown active. Try again after' : '쿨다운 잠금 중. 다음 시각 이후 재시도',
    unlockedMsg: isEn ? 'Unlocked week' : '해금됨 — 주차',
    maxedMsg: isEn ? 'All weeks already unlocked' : '모든 주차가 이미 해금됨',
    needPass: isEn ? 'Pass condition not met — cannot unlock' : '통과 조건 미달 — 해금 불가',
    hours: isEn ? 'h' : '시간', mins: isEn ? 'm' : '분',
    
    // 5 Components
    videoLabel: L.videoLabel,
    podcastLabel: L.podcastLabel,
    pdfLabel: L.pdfLabel,
    notesLabel: L.notesLabel,
    gameLabel: L.gameLabel,
    downloadPdf: L.downloadPdf,
    playGame: L.playGame,
    prepLabel: L.prepLabel,
  },
};
---
<section class="curriculum">
  <div class="container">
    <header class="cur-head">
      <span class="cur-eyebrow">{isEn ? 'Sori Hangeul · Learn Korean' : '소리 한글 · 한국어 배우기'}</span>
      <h1>{L.title}</h1>
      <p class="cur-lead">{L.subtitle}</p>
    </header>

    <!-- 게이미피케이션 시뮬레이션 패널 -->
    <div class="cur-panel" id="sim-panel">
      <div class="panel-head">
        <h2>{L.panelTitle}</h2>
        <p>{L.panelDesc}</p>
      </div>

      <div class="sliders">
        <div class="slider-row">
          <label for="study-slider">{L.studyLabel}: <b id="study-val">60</b>%</label>
          <input type="range" id="study-slider" min="0" max="100" step="1" value="60" />
        </div>
        <div class="slider-row">
          <label for="score-slider">{L.scoreLabel}: <b id="score-val">500</b> / 1000</label>
          <input type="range" id="score-slider" min="0" max="1000" step="10" value="500" />
        </div>
      </div>

      <div class="readout">
        <div class="ro-item">
          <span class="ro-label">{L.weighted}</span>
          <span class="ro-num"><b id="weighted-val">55.0</b>%</span>
        </div>
        <div class="ro-item">
          <span class="ro-label">{L.status}</span>
          <span class="ro-status" id="status-pill">—</span>
        </div>
        <div class="ro-item">
          <span class="ro-label">{L.streak}</span>
          <span class="ro-num"><b id="streak-val">0</b> / 4</span>
        </div>
      </div>

      <div class="panel-actions">
        <button class="cbtn cbtn-primary" id="eval-btn" type="button">{L.evalBtn}</button>
        <button class="cbtn cbtn-ghost" id="manual-btn" type="button">{L.manualBtn}</button>
        <button class="cbtn cbtn-ghost" id="reset-btn" type="button">{L.resetBtn}</button>
      </div>

      <p class="panel-msg" id="panel-msg" role="status" aria-live="polite"></p>
      <p class="panel-rules">{L.rules}</p>
    </div>

    <!-- 레벨 탭 -->
    <div class="cur-tabs" role="tablist" aria-label="curriculum levels">
      {LEVELS.map((lv, i) => (
        <button
          class:list={["tab", { active: i === 0 }]}
          role="tab"
          data-level={lv}
          aria-selected={i === 0 ? 'true' : 'false'}
          type="button"
        >
          {levelName(lv, lang)}{isEn ? '' : ` (${{ beginner: 'Beginner', intermediate: 'Intermediate', advanced: 'Advanced' }[lv]})`}
        </button>
      ))}
    </div>

    <p class="level-summary" id="level-summary"></p>

    <!-- 레벨별 12카드 그리드 -->
    {LEVELS.map((lv, i) => (
      <div class:list={["week-grid", { hidden: i !== 0 }]} data-grid={lv}>
        {weeksByLevel(lv).map((w) => (
          <button class={`week-card${lv === 'beginner' && (w.week === 1 || w.week === 2) ? ' has-thumb' : ''}`} type="button" data-level={lv} data-week={w.week}>
            {lv === 'beginner' && (w.week === 1 || w.week === 2) && (
              <img class="wc-thumb" src={`/docs/hangeul_w${w.week}_thumbnail_${lang}.png`} alt={weekTitle(w, lang)} loading="lazy" />
            )}
            <div class="wc-top">
              <span class="wc-week">{L.week} {w.week}</span>
              {lv === 'beginner' && (w.week === 1 || w.week === 2)
                ? <span class="wc-play" aria-hidden="true">▶</span>
                : <span class="wc-lock" aria-hidden="true">🔒</span>}
            </div>
            <h3 class="wc-title">{weekTitle(w, lang)}</h3>
            <p class="wc-target">{w.target_letters}</p>
          </button>
        ))}
      </div>
    ))}
  </div>

  <!-- 상세 모달 -->
  <div class="cur-modal" id="cur-modal" aria-hidden="true">
    <div class="modal-backdrop" data-close></div>
    <div class="modal-card" role="dialog" aria-modal="true" aria-labelledby="modal-title">
      <button class="modal-x" data-close aria-label={L.close} type="button">✕</button>
      <span class="modal-week" id="modal-week"></span>
      <h2 class="modal-title" id="modal-title"></h2>
      <p class="modal-target" id="modal-target"></p>
      
      <!-- 5 Components Sequential Structure -->
      <div class="modal-components">
        <!-- 1. Video Section -->
        <div class="mcomp-section" id="mcomp-video-sec">
          <h4 class="mcomp-title">{L.videoLabel}</h4>
          <div class="mcomp-content" id="mcomp-video-content"></div>
        </div>

        <!-- 2. Podcast Section -->
        <div class="mcomp-section" id="mcomp-podcast-sec">
          <h4 class="mcomp-title">{L.podcastLabel}</h4>
          <div class="mcomp-content" id="mcomp-podcast-content"></div>
        </div>

        <!-- 3. PDF Section -->
        <div class="mcomp-section" id="mcomp-pdf-sec">
          <h4 class="mcomp-title">{L.pdfLabel}</h4>
          <div class="mcomp-content" id="mcomp-pdf-content"></div>
        </div>

        <!-- 4. Study Notes Section -->
        <div class="mcomp-section" id="mcomp-notes-sec">
          <h4 class="mcomp-title">{L.notesLabel}</h4>
          <div class="mcomp-content">
            <ol class="modal-steps" id="modal-steps"></ol>
          </div>
        </div>

        <!-- 5. Game Section -->
        <div class="mcomp-section" id="mcomp-game-sec">
          <h4 class="mcomp-title">{L.gameLabel}</h4>
          <div class="mcomp-content" id="mcomp-game-content"></div>
        </div>
      </div>

      <div class="modal-reward" id="modal-reward"></div>
    </div>
  </div>

  <script type="application/json" id="curr-data" set:html={JSON.stringify(payload)}></script>
</section>

<script>
  // ---- 데이터 로드 ----
  const el = document.getElementById('curr-data');
  const DATA = JSON.parse(el ? el.textContent || '{}' : '{}');
  const LABELS = DATA.labels || {};
  const LEVELS = DATA.levels || [];
  const WEEKS = DATA.weeks || [];
  const REWARDS = DATA.rewards || {};

  // ---- 1주차 상세 공부 노트 (Bilingual) ----
  const WEEK1_NOTES = {
    ko: [
      {
        n: 1,
        label: LABELS.step1,
        time: '20' + LABELS.mins,
        body: `
          <div class="notes-detail">
            <h5>1. 한글의 창제 배경</h5>
            <p>한글(훈민정음)은 1443년 세종대왕에 의해 창제되었습니다. 당시 백성들은 한자가 너무 복잡하여 글을 읽고 쓰지 못했고, 이로 인해 억울한 일을 겪었습니다. 세종대왕은 백성들을 가엾게 여겨 누구나 쉽게 배울 수 있는 새로운 문자 28자를 만들었습니다.</p>
            <h5>2. 모음의 천지인(天地人) 창제 원리</h5>
            <p>한글 모음은 우주의 세 가지 기본 요소인 하늘(•), 땅(ㅡ), 사람(ㅣ)을 본떠서 만들었습니다.</p>
            <ul>
              <li><strong>하늘 (•)</strong>: 둥근 하늘을 상징하는 점.</li>
              <li><strong>땅 (ㅡ)</strong>: 평평한 땅을 상징하는 가로선.</li>
              <li><strong>사람 (ㅣ)</strong>: 서 있는 사람을 상징하는 세로선.</li>
            </ul>
            <h5>3. 모음 조화와 8개 단모음</h5>
            <p>천지인이 결합하여 다양한 단모음(ㅏ, ㅓ, ㅗ, ㅜ 등)을 형성하며, 양성 모음(ㅏ, ㅗ)과 음성 모음(ㅓ, ㅜ)이 어울리는 자연스러운 모음 조화 규칙을 가집니다.</p>
          </div>
        `
      },
      {
        n: 2,
        label: LABELS.step2,
        time: '20' + LABELS.mins,
        body: `
          <div class="notes-detail">
            <h5>1. 단모음 8개 발음의 핵심 법칙</h5>
            <p>한국어 단모음(ㅏ, ㅓ, ㅗ, ㅜ, ㅡ, ㅣ, ㅐ, ㅔ)을 발음할 때는 소리를 내는 도중에 입술이나 혀가 흔들리지 않고 고정되어 있어야 합니다. (영어의 이중모음화 현상과 다름)</p>
            <h5>2. 입모양 집중 트레이닝</h5>
            <ul>
              <li><strong>'ㅓ' vs 'ㅗ'</strong>: 'ㅓ'는 턱을 아래로 떨어뜨리며 입을 세로로 크게 벌리고 입술은 평평하게 유지합니다. 반대로 'ㅗ'는 빨대를 문 것처럼 입술을 동그랗게 모아야 합니다.</li>
              <li><strong>'ㅜ' vs 'ㅡ'</strong>: 'ㅜ'는 입술을 동그랗게 모아 앞으로 쭉 내밀고, 'ㅡ'는 양옆으로 납작하게 벌려 억지 미소를 짓듯이 발음합니다.</li>
            </ul>
            <h5>3. 자석 블록을 이용한 모아쓰기</h5>
            <p>초성(자음), 중성(모음)의 결합을 음절 상자(Elkonin Box) 속에서 시각화하여 단모음의 위치를 체득합니다.</p>
          </div>
        `
      },
      {
        n: 3,
        label: LABELS.step3,
        time: '20' + LABELS.mins,
        body: `
          <div class="notes-detail">
            <h5>1. 거울 보고 입모양 자가점검</h5>
            <p>거울 앞에서 단모음들을 발음하며 스스로 입 모양을 점검합니다. 특히 'ㅗ, ㅜ' 발음 시에만 입술이 둥글려지고, 'ㅓ, ㅡ' 발음 시에는 입술이 납작하고 평평하게 유지되는지 눈으로 확인합니다.</p>
            <h5>2. 일상 속 소리한글 콕핏 연계</h5>
            <p>소리한글 게임 콕핏에 접속하여 3D 기계식 네온 키보드로 단모음의 음질을 듣고 직접 따라 하며 마이크 평가를 받아 봅니다.</p>
            <h5>3. 나의 첫 단어 매칭</h5>
            <p>'아이, 오이, 우유, 여우'와 같이 단모음만으로 구성된 실생활 기초 단어를 정확한 발음으로 또박또박 읽는 연습을 기록해 봅니다.</p>
          </div>
        `
      }
    ],
    en: [
      {
        n: 1,
        label: LABELS.step1,
        time: '20' + LABELS.mins,
        body: `
          <div class="notes-detail">
            <h5>1. Background of Hangeul's Creation</h5>
            <p>Hangeul (originally called Hunminjeongeum) was created in 1443 by King Sejong the Great. At that time, commoners suffered because they couldn't read or write the complex Chinese characters. Pitying his people, King Sejong created 28 new letters that anyone could easily learn.</p>
            <h5>2. The Cheon-Ji-In (Heaven-Earth-Human) Vowel Principle</h5>
            <p>Hangeul vowels were modeled after the three fundamental elements of the universe:</p>
            <ul>
              <li><strong>Heaven (•)</strong>: A round dot symbolizing the circular sky.</li>
              <li><strong>Earth (ㅡ)</strong>: A horizontal line symbolizing the flat ground.</li>
              <li><strong>Human (ㅣ)</strong>: A vertical line symbolizing a standing person.</li>
            </ul>
            <h5>3. Vowel Harmony & the 8 Simple Vowels</h5>
            <p>Combining these shapes creates the basic vowels (ㅏ, ㅓ, ㅗ, ㅜ, etc.). They follow the rule of Vowel Harmony, where bright vowels (ㅏ, ㅗ) and dark vowels (ㅓ, ㅜ) naturally cluster together.</p>
          </div>
        `
      },
      {
        n: 2,
        label: LABELS.step2,
        time: '20' + LABELS.mins,
        body: `
          <div class="notes-detail">
            <h5>1. Core Principle of the 8 Simple Vowels</h5>
            <p>When pronouncing Korean monophthongs (ㅏ, ㅓ, ㅗ, ㅜ, ㅡ, ㅣ, ㅐ, ㅔ), your mouth and tongue shapes must remain perfectly static and stable throughout the sound.</p>
            <h5>2. Targeted Mouth Shape Training</h5>
            <ul>
              <li><strong>'ㅓ' vs 'ㅗ'</strong>: For 'ㅓ', drop your jaw vertically to open wide while keeping your lips flat. For 'ㅗ', round your lips tightly as if holding a straw.</li>
              <li><strong>'ㅜ' vs 'ㅡ'</strong>: For 'ㅜ', purse your lips tightly and push them forward. For 'ㅡ', stretch your lips flat horizontally as if forcing a smile.</li>
            </ul>
            <h5>3. Syllable Assembling (Elkonin Box)</h5>
            <p>Practice visualizing and placing vowel blocks alongside consonant blocks inside the Elkonin box to master syllable structures.</p>
          </div>
        `
      },
      {
        n: 3,
        label: LABELS.step3,
        time: '20' + LABELS.mins,
        body: `
          <div class="notes-detail">
            <h5>1. Mirror Self-Check</h5>
            <p>Say the simple vowels in front of a mirror. Ensure your lips are round ONLY for 'ㅗ' and 'ㅜ', and remain completely flat for 'ㅓ' and 'ㅡ'.</p>
            <h5>2. Practice with Sori Hangeul Cockpit</h5>
            <p>Access the arcade game cockpit, press the 3D mechanical neon keys to hear the native pronunciation, and record your voice to receive real-time pronunciation feedback.</p>
            <h5>3. My First Word Matching</h5>
            <p>Practice reading basic, real-life words composed solely of simple vowels (e.g., 아이 [child], 오이 [cucumber], 우유 [milk], 여우 [fox]) with clear, accurate vocalization.</p>
          </div>
        `
      }
    ]
  };


  // ---- localStorage 진도 상태 ----
  const KEY_UNLOCK = 'hangeul_unlocked_week';
  const KEY_STREAK = 'hangeul_freepass_streak';
  const KEY_COOLDOWN = 'hangeul_cooldown_until';
  const COOLDOWN_MS = 48 * 60 * 60 * 1000;

  const getUnlocked = () => {
    const v = parseInt(localStorage.getItem(KEY_UNLOCK) || '1', 10);
    return isNaN(v) ? 1 : Math.min(Math.max(v, 1), 24);
  };
  const setUnlocked = (n) => localStorage.setItem(KEY_UNLOCK, String(Math.min(Math.max(n, 1), 24)));
  const getStreak = () => parseInt(localStorage.getItem(KEY_STREAK) || '0', 10) || 0;
  const setStreak = (n) => localStorage.setItem(KEY_STREAK, String(Math.max(0, n)));
  const getCooldown = () => parseInt(localStorage.getItem(KEY_COOLDOWN) || '0', 10) || 0;
  const setCooldown = (t) => localStorage.setItem(KEY_COOLDOWN, String(t));
  const inCooldown = () => Date.now() < getCooldown();

  let currentLevel = LEVELS[0] || 'beginner';

  // ---- 통과 계산 ----
  function compute(study, score) {
    const weighted = study * 0.5 + (score / 1000) * 100 * 0.5;
    const perfect = score === 1000;
    const excellent = score >= 900;
    const regular = weighted >= 70;
    return { weighted, perfect, excellent, regular, anyPass: perfect || excellent || regular };
  }

  // ---- DOM refs ----
  const $ = (id) => document.getElementById(id);
  const studySlider = $('study-slider'), scoreSlider = $('score-slider');
  const studyVal = $('study-val'), scoreVal = $('score-val'), weightedVal = $('weighted-val');
  const statusPill = $('status-pill'), streakVal = $('streak-val');
  const panelMsg = $('panel-msg'), levelSummary = $('level-summary');

  // ---- 슬라이더/상태 갱신 ----
  function refreshReadout() {
    const study = parseInt(studySlider.value, 10);
    const score = parseInt(scoreSlider.value, 10);
    studyVal.textContent = String(study);
    scoreVal.textContent = String(score);
    const r = compute(study, score);
    weightedVal.textContent = r.weighted.toFixed(1);
    statusPill.className = 'ro-status';
    if (r.perfect) { statusPill.textContent = LABELS.passPerfect; statusPill.classList.add('s-perfect'); }
    else if (r.excellent) { statusPill.textContent = LABELS.passExcellent; statusPill.classList.add('s-excellent'); }
    else if (r.regular) { statusPill.textContent = LABELS.passRegular; statusPill.classList.add('s-pass'); }
    else { statusPill.textContent = LABELS.fail; statusPill.classList.add('s-fail'); }
    streakVal.textContent = String(getStreak());
  }

  function fmtRemain(ms) {
    const totalMin = Math.max(0, Math.ceil(ms / 60000));
    const h = Math.floor(totalMin / 60), m = totalMin % 60;
    return `${h}${LABELS.hours} ${m}${LABELS.mins}`;
  }

  function setMsg(text, kind) {
    panelMsg.textContent = text || '';
    panelMsg.className = 'panel-msg' + (kind ? ' ' + kind : '');
  }

  // ---- 레벨 요약/쿨다운 표시 ----
  let cooldownTimer = null;
  function refreshSummary() {
    const up = getUnlocked();
    let txt = `${LABELS.unlockedUpTo} ${up} / 24`;
    if (inCooldown()) {
      txt += `  ·  ${LABELS.cooldownOn} (${fmtRemain(getCooldown() - Date.now())})`;
      levelSummary.classList.add('cooldown');
    } else {
      levelSummary.classList.remove('cooldown');
    }
    levelSummary.textContent = txt;

    if (cooldownTimer) { clearInterval(cooldownTimer); cooldownTimer = null; }
    if (inCooldown()) {
      cooldownTimer = setInterval(() => {
        if (!inCooldown()) { clearInterval(cooldownTimer); cooldownTimer = null; }
        refreshSummary();
      }, 30000);
    }
  }

  // ---- 카드 잠금 렌더 ----
  function renderLocks() {
    const up = getUnlocked();
    document.querySelectorAll('.week-card').forEach((card) => {
      const wk = parseInt(card.getAttribute('data-week'), 10);
      const locked = wk > up;
      card.classList.toggle('locked', locked);
      card.setAttribute('aria-disabled', locked ? 'true' : 'false');
    });
  }

  // ---- 탭 전환 ----
  function selectLevel(lv) {
    currentLevel = lv;
    document.querySelectorAll('.tab').forEach((t) => {
      const on = t.getAttribute('data-level') === lv;
      t.classList.toggle('active', on);
      t.setAttribute('aria-selected', on ? 'true' : 'false');
    });
    document.querySelectorAll('.week-grid').forEach((g) => {
      g.classList.toggle('hidden', g.getAttribute('data-grid') !== lv);
    });
    refreshSummary();
  }

  // ---- 다음 주 해금 ----
  function unlockNext() {
    const up = getUnlocked();
    if (up >= 24) return { ok: false, maxed: true, week: up };
    setUnlocked(up + 1);
    renderLocks();
    refreshSummary();
    return { ok: true, week: up + 1 };
  }

  // 평가 후 해금 (게이미피케이션 규칙 적용)
  function evaluateAndUnlock() {
    if (inCooldown()) {
      const when = new Date(getCooldown());
      setMsg(`${LABELS.cooldownMsg} ${when.toLocaleString()}`, 'err');
      return;
    }
    const r = compute(parseInt(studySlider.value, 10), parseInt(scoreSlider.value, 10));
    if (!r.anyPass) { setMsg(LABELS.needPass, 'err'); return; }

    const isFreePass = r.excellent || r.perfect; // 900↑ 또는 1000
    const res = unlockNext();
    if (!res.ok && res.maxed) { setMsg(LABELS.maxedMsg, 'warn'); return; }

    if (isFreePass) {
      const s = getStreak() + 1;
      if (s > 4) {
        // 5회째 연속 프리패스 → 48h 쿨다운, 스트릭 리셋
        setCooldown(Date.now() + COOLDOWN_MS);
        setStreak(0);
        setMsg(`${LABELS.unlockedMsg} ${res.week}. ${LABELS.cooldownOn} (${fmtRemain(COOLDOWN_MS)})`, 'warn');
      } else {
        setStreak(s);
        setMsg(`${LABELS.unlockedMsg} ${res.week} ★`, 'ok');
      }
    } else {
      setStreak(0); // 일반 통과는 스트릭 초기화
      setMsg(`${LABELS.unlockedMsg} ${res.week} ✓`, 'ok');
    }
    refreshReadout();
    refreshSummary();
  }

  // 수동 해금 (샌드박스 — 규칙 무시)
  function manualUnlock() {
    const res = unlockNext();
    if (!res.ok && res.maxed) { setMsg(LABELS.maxedMsg, 'warn'); return; }
    setMsg(`${LABELS.unlockedMsg} ${res.week}`, 'ok');
  }

  function resetProgress() {
    localStorage.removeItem(KEY_UNLOCK);
    localStorage.removeItem(KEY_STREAK);
    localStorage.removeItem(KEY_COOLDOWN);
    renderLocks(); refreshReadout(); refreshSummary();
    setMsg('', '');
  }

  // ---- 상세 모달 ----
  const modal = $('cur-modal');
  function openModal(lv, wk) {
    const w = WEEKS.find((x) => x.level === lv && x.week === wk);
    if (!w) return;
    $('modal-week').textContent = `${LABELS.week} ${w.week} · ${DATA.levelNames[lv]}`;
    $('modal-title').textContent = w.title;
    
    // target_letters 분할하여 clickable 칩으로 변경 (성우 음질 100% 매핑)
    const targetLabel = LABELS.target || 'Target';
    const targetLetters = w.target || '';
    const letters = targetLetters.split(',').map(l => l.trim()).filter(Boolean);
    
    let targetHtml = `${targetLabel}: `;
    letters.forEach(l => {
      let audioVal = l.replace(/[\[\]\~]/g, '').trim();
      if (audioVal.toLowerCase() === 'school') audioVal = '학교';
      if (audioVal.toLowerCase() === 'k-drama') audioVal = '케이드라마';
      if (audioVal.toLowerCase() === 'k-pop') audioVal = '케이팝';
      if (audioVal.startsWith("고 ")) audioVal = audioVal.replace("고 ", "");
      if (audioVal.startsWith("한 ")) audioVal = audioVal.replace("한 ", "");
      if (audioVal.includes("하나열")) audioVal = "하나";
      if (audioVal.includes("일십")) audioVal = "일";
      
      targetHtml += `<span class="audio-chip" data-sound="${audioVal}" title="발음 듣기">${l} 🔊</span> `;
    });
    $('modal-target').innerHTML = targetHtml;

    // 5 Components Dynamic Content Binding
    const isWeek1 = lv === 'beginner' && wk === 1;
    const wkNum = (lv === 'beginner' && (wk === 1 || wk === 2)) ? wk : 0;   // 영상 있는 주차
    const langSuffix = DATA.lang === 'ko' ? 'ko' : 'en';

    // (1) Video Content
    const videoContentEl = $('mcomp-video-content');
    if (wkNum) {
      const vsfx = DATA.lang === 'ko' ? 'ko' : 'en';
      const fsLabel = DATA.lang === 'ko' ? '전체화면' : 'Fullscreen';
      videoContentEl.innerHTML = `
        <div class="mcomp-video-wrap">
          <video class="mcomp-video-player" id="lesson-video" controls playsinline preload="metadata"
                 poster="/docs/hangeul_w${wkNum}_thumbnail_${vsfx}.png" src="/docs/hangeul_w${wkNum}_stickman_${vsfx}.mp4"></video>
          <button class="mcomp-fs-btn" type="button" aria-label="${fsLabel}" title="${fsLabel}">⛶</button>
        </div>`;
      const _v = videoContentEl.querySelector('#lesson-video');
      const _fs = videoContentEl.querySelector('.mcomp-fs-btn');
      if (_fs && _v) _fs.addEventListener('click', () => {
        const fn = _v.requestFullscreen || _v.webkitRequestFullscreen || _v.webkitEnterFullscreen || _v.msRequestFullscreen;
        if (fn) { try { fn.call(_v); } catch (e) { _v.play(); } } else { _v.play(); }
      });
    } else {
      videoContentEl.innerHTML = `<div class="mcomp-placeholder">${LABELS.prepLabel}</div>`;
    }

    // (2) Podcast Content
    const podcastContentEl = $('mcomp-podcast-content');
    if (isWeek1) {
      const podcastFileSuffix = DATA.lang === 'ko' ? '' : '_en';
      podcastContentEl.innerHTML = `<audio class="mcomp-audio-player" controls src="/audio/podcasts/hangeul_week_1_podcast${podcastFileSuffix}.m4a"></audio>`;
    } else {
      podcastContentEl.innerHTML = `<div class="mcomp-placeholder">${LABELS.prepLabel}</div>`;
    }

    // (3) PDF Content
    const pdfContentEl = $('mcomp-pdf-content');
    if (isWeek1) {
      const pdfFileSuffix = DATA.lang === 'ko' ? '' : '_en';
      pdfContentEl.innerHTML = `<a class="mcomp-link-btn" href="/docs/hangeul_week_1_guide${pdfFileSuffix}.pdf" download>📁 ${LABELS.downloadPdf}</a>`;
    } else {
      pdfContentEl.innerHTML = `<div class="mcomp-placeholder">${LABELS.prepLabel}</div>`;
    }

    // (4) Study Notes (Steps)
    let steps = [];
    if (isWeek1) {
      steps = WEEK1_NOTES[DATA.lang] || [];
    } else {
      steps = [
        { n: 1, label: LABELS.step1, body: `<p>${w.concept}</p>`, time: '20' + LABELS.mins },
        { n: 2, label: LABELS.step2, body: `<p>${w.practice}</p>`, time: '20' + LABELS.mins },
        { n: 3, label: LABELS.step3, body: `<p>${w.application}</p>`, time: '20' + LABELS.mins },
      ];
    }
    $('modal-steps').innerHTML = steps.map((s) =>
      `<li class="mstep"><span class="ms-no">${s.n}</span>` +
      `<div class="ms-body"><div class="ms-head"><b>${s.label}</b><span class="ms-time">${s.time}</span></div>` +
      `<div class="ms-body-desc">${s.body}</div></div></li>`
    ).join('');

    // (5) Game Content
    const gameContentEl = $('mcomp-game-content');
    gameContentEl.innerHTML = `<a class="mcomp-link-btn" href="${DATA.lang === 'ko' ? '/ko/groove' : '/groove'}">🎮 ${LABELS.playGame}</a>`;

    $('modal-reward').innerHTML =
      `<span class="mr-label">🎁 ${LABELS.rewardTitle}</span><span class="mr-text">${REWARDS[lv] || ''}</span>`;
    modal.classList.add('open');
    modal.setAttribute('aria-hidden', 'false');
    const _mc = modal.querySelector('.modal-card');
    if (_mc) _mc.scrollTop = 0;   // 영상이 맨 위에 보이도록
  }

  // 모달 내 오디오 칩 클릭 이벤트 위임 리스너 추가
  if (modal) {
    modal.addEventListener('click', (e) => {
      const chip = e.target.closest('.audio-chip');
      if (chip) {
        const sound = chip.getAttribute('data-sound');
        if (sound) {
          const audioUrl = `/audio/jamo/${encodeURIComponent(sound)}.mp3`;
          const audio = new Audio(audioUrl);
          audio.play().catch(err => {
            console.warn('Pre-generated voice audio not found on server for text:', sound, err);
          });
        }
      }
    });
  }
  function closeModal() {
    modal.classList.remove('open');
    modal.setAttribute('aria-hidden', 'true');
  }

  // ---- 이벤트 바인딩 ----
  studySlider.addEventListener('input', refreshReadout);
  scoreSlider.addEventListener('input', refreshReadout);
  $('eval-btn').addEventListener('click', evaluateAndUnlock);
  $('manual-btn').addEventListener('click', manualUnlock);
  $('reset-btn').addEventListener('click', resetProgress);

  document.querySelectorAll('.tab').forEach((t) =>
    t.addEventListener('click', () => selectLevel(t.getAttribute('data-level')))
  );

  document.querySelectorAll('.week-card').forEach((card) =>
    card.addEventListener('click', () => {
      if (card.classList.contains('locked')) return;
      openModal(card.getAttribute('data-level'), parseInt(card.getAttribute('data-week'), 10));
    })
  );

  modal.querySelectorAll('[data-close]').forEach((b) => b.addEventListener('click', closeModal));
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

  // ---- 초기 렌더 ----
  refreshReadout();
  renderLocks();
  selectLevel(currentLevel);
  refreshSummary();
</script>

<style>
