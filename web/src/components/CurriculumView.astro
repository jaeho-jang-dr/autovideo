  function manualUnlock() {
    const res = unlockNext();
    if (!res.ok && res.maxed) { setMsg(LABELS.maxedMsg, 'warn'); return; }
    setMsg(`${LABELS.unlockedMsg} ${res.week}`, 'ok');
  }

