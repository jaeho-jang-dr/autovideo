---
import {
  epTitle, getCategory, catName, epYoutube, categoryUrl, homeUrl,
  type Episode, type Lang,
} from '../lib/content';
import { t, fmtRuntime } from '../lib/i18n';
import YouTubeEmbed from './YouTubeEmbed.astro';
import ScriptViewer from './ScriptViewer.astro';

interface Props { lang: Lang; episode: Episode; }
const { lang, episode } = Astro.props;
const tr = t(lang);
const cat = getCategory(episode.category);
const title = epTitle(episode, lang);
const sub = lang === 'en' ? '' : (episode.hook_kr ?? '');
const published = episode.status === 'published';
---
<section class="section container">
  <div class="lesson-head">
    <div class="crumbs">
      <a href={homeUrl(lang)}>{tr.nav_home}</a><span>/</span>
      <a href={categoryUrl(episode.category, lang)}>{cat ? catName(cat, lang) : episode.category}</a><span>/</span>
      <span>{episode.code}</span>
    </div>
    <h1>{title}</h1>
    {sub && <p class="sub">{sub}</p>}
    <div class="crumbs">
      <span class={`status-badge ${published ? 'published' : 'upcoming'}`}>
        {published ? tr.published_badge : tr.upcoming_badge}
      </span>
      {episode.runtime_sec ? <span>{tr.runtime}: {fmtRuntime(episode.runtime_sec, lang)}</span> : null}
      {episode.publish_date ? <span>· {episode.publish_date}</span> : null}
    </div>
  </div>

  <YouTubeEmbed value={epYoutube(episode, lang)} title={title} lang={lang} />

  <ScriptViewer scenes={episode.scenes} lang={lang} />
</section>
