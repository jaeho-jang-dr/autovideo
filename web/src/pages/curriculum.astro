---
import BaseLayout from '../layouts/BaseLayout.astro';
import CurriculumView from '../components/CurriculumView.astro';

const lang = 'en' as const;
---
<BaseLayout
  lang={lang}
  altUrl="/ko/curriculum/"
  active="curriculum"
  title="Hunminjeongeum · 12-Week Hangeul Roadmap · drjay-ed"
  description="A 12-week Hunminjeongeum (Hangeul) study course (Beginner/Intermediate/Advanced, 4 weeks each) with a daily 1-hour concept-practice-application structure and a progress simulator."
>
  <CurriculumView lang={lang} />
</BaseLayout>
