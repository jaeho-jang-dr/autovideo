---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HomeView from '../../components/HomeView.astro';
import { t } from '../../lib/i18n';

const lang = 'ko' as const;
const tr = t(lang);
---
<BaseLayout
  lang={lang}
  altUrl="/en/"
  active="home"
  heroVideo={true}
  title="drjay-ed · 의사의 시선으로 해부하는 세상"
  description={tr.tagline}
>
  <HomeView lang={lang} />
</BaseLayout>
