---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GrammarView from '../../components/GrammarView.astro';
import { t } from '../../lib/i18n';

const lang = 'ko' as const;
const tr = t(lang);
---

<BaseLayout
  lang={lang}
  altUrl="/grammar/"
  active="grammar"
  title={`${tr.nav_grammar} · 한글 발음과 쓰기 · drjay-ed`}
  description={tr.grammar_sub}
>
  <GrammarView lang={lang} />
</BaseLayout>
