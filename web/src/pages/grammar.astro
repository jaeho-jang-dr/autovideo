---
import BaseLayout from '../layouts/BaseLayout.astro';
import GrammarView from '../components/GrammarView.astro';
import { t } from '../lib/i18n';

const lang = 'en' as const;
const tr = t(lang);
---

<BaseLayout
  lang={lang}
  altUrl="/ko/grammar/"
  active="grammar"
  title={`${tr.nav_grammar} · Hangeul Pronunciation & Writing · drjay-ed`}
  description={tr.grammar_sub}
>
  <GrammarView lang={lang} />
</BaseLayout>
