---
import BaseLayout from '../layouts/BaseLayout.astro';
import GrooveBoard from '../components/GrooveBoard.astro';
import { t } from '../lib/i18n';

const lang = 'en' as const;
const tr = t(lang);
---

<BaseLayout
  lang={lang}
  altUrl="/ko/groove/"
  active="groove"
  title={`drjay-ed · ${tr.groove_title}`}
  description={tr.groove_sub}
  hideHeaderFooter={true}
>
  <div class="container" style="padding-top: 1rem; padding-bottom: 1rem;">
    <GrooveBoard lang={lang} />
  </div>
</BaseLayout>
