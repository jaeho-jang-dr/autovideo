---
import '../styles/global.css';
import { channel, homeUrl, categories, catName, categoryUrl, type Lang } from '../lib/content';
import { t } from '../lib/i18n';

interface Props {
  title: string;
  description?: string;
  lang: Lang;
  altUrl: string;       // 같은 페이지의 반대 언어 URL (언어 토글용)
  active?: 'home' | 'lessons';
  heroVideo?: boolean;  // 페이지 전체 배경에 졸라 왈츠 영상을 상영할지 여부
}

const { title, description = '', lang, altUrl, active, heroVideo = false } = Astro.props;
const tr = t(lang);
const koUrl = lang === 'ko' ? Astro.url.pathname : altUrl;
const enUrl = lang === 'en' ? Astro.url.pathname : altUrl;
const handle = channel.youtube_handle ?? '@drjay-ed';
---
<!doctype html>
<html lang={lang === 'en' ? 'en' : 'ko'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).href} />
    {import.meta.env.PUBLIC_NAVER_VERIFICATION && (
      <meta name="naver-site-verification" content={import.meta.env.PUBLIC_NAVER_VERIFICATION} />
    )}
    {import.meta.env.PUBLIC_GOOGLE_VERIFICATION && (
      <meta name="google-site-verification" content={import.meta.env.PUBLIC_GOOGLE_VERIFICATION} />
    )}
  </head>
  <body class={heroVideo ? 'has-bg-video' : ''}>
    {heroVideo && (
      <div class="bg-stage" aria-hidden="true">
        <video class="bg-video" autoplay muted loop playsinline preload="auto" poster="/zolla_waltz_poster.jpg">
          <source src="/zolla_waltz.mp4" type="video/mp4" />
        </video>
        <div class="bg-scrim"></div>
      </div>
    )}
    <header class="site-header">
      <div class="container bar">
        <a class="brand" href={homeUrl(lang)} aria-label="drjay-ed home">
          <span class="logo"><img src="/logo.png" alt="" width="28" height="28" /></span>
          <span>drjay<span class="grad-text">-ed</span></span>
        </a>
        <nav class="nav">
          <a href={homeUrl(lang)} class={active === 'home' ? 'active' : ''}>{tr.nav_home}</a>
          <a href={`${homeUrl(lang)}#lessons`} class={active === 'lessons' ? 'active' : ''}>{tr.nav_lessons}</a>
          <span class="lang-switch" role="group" aria-label="language">
            <a href={koUrl} class={lang === 'ko' ? 'active' : ''} hreflang="ko">KO</a>
            <a href={enUrl} class={lang === 'en' ? 'active' : ''} hreflang="en">EN</a>
          </span>
          <a class="admin-orb" href="/admin/" title={lang === 'en' ? 'Admin' : '관리자'} aria-label={lang === 'en' ? 'Admin page' : '관리자 페이지'}>
            <span class="uni">🦄</span>
          </a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-sitemap">
        <!-- Column 1: Brand / Concept -->
        <div class="footer-col">
          <h4>drjay-ed</h4>
          <p style="margin-bottom: 12px; font-weight: 500;">
            {lang === 'en' ? "Dissecting the world with a doctor's scalpel, stitching it back with a cartoonist's imagination." : "의사의 메스로 세상을 해부하고, 만화가의 상상력으로 꿰매다."}
          </p>
          <p style="font-size: 0.78rem;">
            Benchmark: TED-Ed Concept
          </p>
        </div>

        <!-- Column 2: Categories -->
        <div class="footer-col">
          <h4>{lang === 'en' ? 'Categories' : '주제 분류'}</h4>
          <ul>
            {categories.map((c) => (
              <li>
                <a href={categoryUrl(c.code, lang)}>{catName(c, lang)}</a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Column 3: Links & Utilities -->
        <div class="footer-col">
          <h4>{lang === 'en' ? 'Resources' : '바로가기'}</h4>
          <ul>
            <li><a href={homeUrl(lang)}>{tr.nav_home}</a></li>
            <li><a href={`${homeUrl(lang)}#lessons`}>{tr.nav_lessons}</a></li>
            <li>
              <span style="display: inline-block; margin-top: 4px;">
                <span class="lang-switch" role="group" aria-label="language">
                  <a href={koUrl} class={lang === 'ko' ? 'active' : ''} hreflang="ko">KO</a>
                  <a href={enUrl} class={lang === 'en' ? 'active' : ''} hreflang="en">EN</a>
                </span>
              </span>
            </li>
          </ul>
        </div>
      </div>

      <div class="container footer-bottom">
        <div class="copy">
          © {new Date().getFullYear()} drjay-ed · {handle}
        </div>
        <div class="meta-links">
          <a href={`https://youtube.com/${handle}`} target="_blank" rel="noopener noreferrer">YouTube Channel</a>
        </div>
      </div>
    </footer>
  </body>
</html>
