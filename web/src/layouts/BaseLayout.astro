---
import '../styles/global.css';
import { channel, homeUrl, categories, catName, categoryUrl, type Lang } from '../lib/content';
import { t } from '../lib/i18n';

interface Props {
  title: string;
  description?: string;
  lang: Lang;
  altUrl: string;       // 같은 페이지의 반대 언어 URL (언어 토글용)
  active?: 'home' | 'lessons' | 'groove' | 'curriculum' | 'grammar' | 'alllessons' | 'places';
  heroVideo?: boolean;  // 페이지 전체 배경에 졸라 왈츠 영상을 상영할지 여부
  hideHeaderFooter?: boolean; // 그루브 앱 단독 뷰 여부
}

const { title, description = '', lang, altUrl, active, heroVideo = false, hideHeaderFooter = false } = Astro.props;
const tr = t(lang);
const koUrl = lang === 'ko' ? Astro.url.pathname : altUrl;
const enUrl = lang === 'en' ? Astro.url.pathname : altUrl;
const handle = channel.youtube_handle ?? '@drjay-ed';
---
<!doctype html>
<html lang={lang === 'en' ? 'en' : 'ko'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).href} />
    {import.meta.env.PUBLIC_NAVER_VERIFICATION && (
      <meta name="naver-site-verification" content={import.meta.env.PUBLIC_NAVER_VERIFICATION} />
    )}
    {import.meta.env.PUBLIC_GOOGLE_VERIFICATION && (
      <meta name="google-site-verification" content={import.meta.env.PUBLIC_GOOGLE_VERIFICATION} />
    )}
  </head>
  <body class={heroVideo ? 'has-bg-video' : ''}>
    {heroVideo && (
      <div class="bg-stage" aria-hidden="true">
        <video class="bg-video" autoplay muted loop playsinline preload="auto" poster="/zolla_waltz_poster.jpg">
          <source src="/zolla_waltz.mp4" type="video/mp4" />
        </video>
        <div class="bg-scrim"></div>
      </div>
    )}
    {!hideHeaderFooter && (
      <header class="site-header">
        <div class="container bar">
          <a class="brand" href={homeUrl(lang)} aria-label="drjay-ed home">
            <span class="logo"><img src="/logo.png" alt="" width="36" height="36" /></span>
            <span>drjay<span class="grad-text">-ed</span></span>
          </a>
          
          <!-- 햄버거 메뉴 토글 버튼 -->
          <button id="menu-toggle" class="menu-toggle" aria-label="Toggle menu">
            <span class="icon-bar"></span>
            <span class="icon-bar"></span>
            <span class="icon-bar"></span>
          </button>
          
          <nav class="nav">
            <a href={homeUrl(lang)} class={active === 'home' ? 'active' : ''}>{tr.nav_home}</a>
            <a href={`${homeUrl(lang)}#lessons`} class={active === 'lessons' ? 'active' : ''}>{tr.nav_lessons}</a>
            <a href={lang === 'ko' ? '/ko/curriculum/' : '/curriculum/'} class={active === 'curriculum' ? 'active' : ''}>{tr.nav_curriculum}</a>
            <a href={lang === 'ko' ? '/ko/lessons-all/' : '/lessons-all/'} class={active === 'alllessons' ? 'active' : ''}>{lang === 'ko' ? '168강' : '168 Lessons'}</a>
            <a href={lang === 'ko' ? '/ko/grammar/' : '/grammar/'} class={active === 'grammar' ? 'active' : ''}>{tr.nav_grammar}</a>
            <a href={lang === 'ko' ? '/ko/places/' : '/places/'} class={active === 'places' ? 'active' : ''}>{lang === 'ko' ? '명소 168' : 'Korea 168'}</a>
            <a href={lang === 'ko' ? '/ko/groove/' : '/groove/'} class={active === 'groove' && !Astro.url.searchParams.has('play') ? 'active' : ''}>{tr.nav_groove}</a>
            <a href="javascript:void(0)" class="coming-soon-game" data-lang={lang}>🎮 {lang === 'ko' ? '한글 게임 (준비중)' : 'Game (Coming Soon)'}</a>
            <span class="lang-switch" role="group" aria-label="language">
              <a href={koUrl} class={lang === 'ko' ? 'active' : ''} hreflang="ko">KO</a>
              <a href={enUrl} class={lang === 'en' ? 'active' : ''} hreflang="en">EN</a>
            </span>
            <a class="admin-orb" href="/admin/" title={lang === 'en' ? 'Admin' : '관리자'} aria-label={lang === 'en' ? 'Admin page' : '관리자 페이지'}>
              <span class="uni">🦄</span>
            </a>
          </nav>
        </div>
      </header>
    )}

    <main class={hideHeaderFooter ? 'no-padding' : ''}>
      <slot />
    </main>

    {!hideHeaderFooter && (
      <footer class="pgt-footer">
        <div class="pgt-footer-inner">

          <!-- ── Brand column ── -->
          <div class="pgt-footer-brand">
            <img src="/logo.png" alt="drjay-ed Logo" class="pgt-logo-img" />
            <div class="brand-text">
              <h2>drjay-ed</h2>
              <div class="brand-developer">
                <span class="info-label">Developer</span>
                <span class="info-text">Created by <strong>Dr. Jay</strong></span>
              </div>
            </div>
          </div>

          <!-- ── Info column ── -->
          <div class="pgt-footer-info">
            <div class="info-block">
              <span class="info-icon">📍</span>
              <div>
                <span class="info-label">Headquarters</span>
                <span class="info-text">451 Jungang-ro, Miryang-si,<br>Gyeongsangnam-do, Republic of Korea</span>
              </div>
            </div>
            <div class="info-block">
              <span class="info-icon">🔗</span>
              <div>
                <span class="info-label">Official Website</span>
                <a href="https://drjayed.com">drjayed.com</a>
              </div>
            </div>
          </div>

        </div>

        <!-- ── Bottom bar ── -->
        <div class="pgt-footer-bottom">
          <div>© {new Date().getFullYear()} Jay's AI Company. All rights reserved.</div>
          <div>
            <a href={homeUrl(lang)}>{tr.nav_home}</a>
            <a href={`${homeUrl(lang)}#lessons`}>{tr.nav_lessons}</a>
            <a href={lang === 'ko' ? '/ko/curriculum/' : '/curriculum/'}>{tr.nav_curriculum}</a>
            <a href={lang === 'ko' ? '/ko/lessons-all/' : '/lessons-all/'}>{lang === 'ko' ? '168강' : '168 Lessons'}</a>
            <a href={lang === 'ko' ? '/ko/places/' : '/places/'}>{lang === 'ko' ? '명소 168' : 'Korea 168'}</a>
            <a href={lang === 'ko' ? '/ko/grammar/' : '/grammar/'}>{tr.nav_grammar}</a>
            <a href={lang === 'ko' ? '/ko/groove/' : '/groove/'}>{tr.nav_groove}</a>
          </div>
        </div>
      </footer>
    )}

    <!-- 햄버거 메뉴를 제어하는 공통 클라이언트 스크립트 및 스타일 추가 -->
    <script>
      const menuToggle = document.getElementById('menu-toggle');
      const nav = document.querySelector('.nav');
      if (menuToggle && nav) {
        menuToggle.addEventListener('click', () => {
          nav.classList.toggle('open');
          menuToggle.classList.toggle('open');
        });
      }

      // 한글 게임 준비 중 팝업 알림 처리
      document.querySelectorAll('.coming-soon-game').forEach(el => {
        el.addEventListener('click', (e) => {
          e.preventDefault();
          const lang = el.getAttribute('data-lang');
          const msg = lang === 'ko'
            ? "제작 중인 기능입니다. (Coming Soon)"
            : "Under construction. (Coming Soon)";
          alert(msg);
        });
      });
    </script>

    <style is:global>
      /* 햄버거 토글 버튼 스타일 (기본 숨김) */
      .menu-toggle {
        display: none;
        flex-direction: column;
        justify-content: space-between;
        width: 24px;
        height: 18px;
        background: transparent;
        border: none;
        cursor: pointer;
        padding: 0;
        z-index: 100;
        margin-left: auto;
      }

      .menu-toggle .icon-bar {
        width: 100%;
        height: 2px;
        background-color: var(--text-0);
        border-radius: 1px;
        transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
      }

      /* 모바일 전용 GNB 오버레이 (720px 이하) */
      @media (max-width: 720px) {
        .menu-toggle {
          display: flex;
        }
        
        .nav {
          display: none;
          flex-direction: column;
          position: absolute;
          top: 100%;
          left: 0;
          right: 0;
          background: rgba(255, 255, 255, 0.95);
          backdrop-filter: blur(20px) saturate(180%);
          -webkit-backdrop-filter: blur(20px) saturate(180%);
          border-bottom: 1.5px solid rgba(0, 0, 0, 0.06);
          padding: 20px;
          gap: 12px;
          align-items: stretch;
          box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
        }
        
        .nav.open {
          display: flex;
          animation: slideDownMenu 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }
        
        .nav > a {
          width: 100%;
          text-align: center;
          padding: 10px;
          border-radius: 8px;
          font-size: 1rem;
          background: transparent;
        }
        
        .nav > a::after {
          display: none;
        }
        
        .lang-switch {
          justify-content: center;
          margin: 4px auto;
        }
        
        .admin-orb {
          margin: 4px auto 0 auto;
        }

        .menu-toggle.open .icon-bar:nth-child(1) {
          transform: translateY(8px) rotate(45deg);
        }
        
        .menu-toggle.open .icon-bar:nth-child(2) {
          opacity: 0;
        }
        
        .menu-toggle.open .icon-bar:nth-child(3) {
          transform: translateY(-8px) rotate(-45deg);
        }
      }

      @keyframes slideDownMenu {
        from { opacity: 0; transform: translateY(-10px); }
        to { opacity: 1; transform: translateY(0); }
      }

      main.no-padding {
        padding-top: 0 !important;
        margin: 0 !important;
      }
    </style>
  </body>
</html>
