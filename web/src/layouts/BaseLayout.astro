---
import '../styles/global.css';
import { channel, homeUrl, categories, catName, categoryUrl, type Lang } from '../lib/content';
import { t } from '../lib/i18n';

interface Props {
  title: string;
  description?: string;
  lang: Lang;
  altUrl: string;       // 같은 페이지의 반대 언어 URL (언어 토글용)
  active?: 'home' | 'lessons' | 'groove';
  heroVideo?: boolean;  // 페이지 전체 배경에 졸라 왈츠 영상을 상영할지 여부
  hideHeaderFooter?: boolean; // 그루브 앱 단독 뷰 여부
}

const { title, description = '', lang, altUrl, active, heroVideo = false, hideHeaderFooter = false } = Astro.props;
const tr = t(lang);
const koUrl = lang === 'ko' ? Astro.url.pathname : altUrl;
const enUrl = lang === 'en' ? Astro.url.pathname : altUrl;
const handle = channel.youtube_handle ?? '@drjay-ed';
---
<!doctype html>
<html lang={lang === 'en' ? 'en' : 'ko'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).href} />
    {import.meta.env.PUBLIC_NAVER_VERIFICATION && (
      <meta name="naver-site-verification" content={import.meta.env.PUBLIC_NAVER_VERIFICATION} />
    )}
    {import.meta.env.PUBLIC_GOOGLE_VERIFICATION && (
      <meta name="google-site-verification" content={import.meta.env.PUBLIC_GOOGLE_VERIFICATION} />
    )}
  </head>
  <body class={heroVideo ? 'has-bg-video' : ''}>
    {heroVideo && (
      <div class="bg-stage" aria-hidden="true">
        <video class="bg-video" autoplay muted loop playsinline preload="auto" poster="/zolla_waltz_poster.jpg">
          <source src="/zolla_waltz.mp4" type="video/mp4" />
        </video>
        <div class="bg-scrim"></div>
      </div>
    )}
    {!hideHeaderFooter && (
      <header class="site-header">
        <div class="container bar">
          <a class="brand" href={homeUrl(lang)} aria-label="drjay-ed home">
            <span class="logo"><img src="/logo.png" alt="" width="28" height="28" /></span>
            <span>drjay<span class="grad-text">-ed</span></span>
          </a>
          
          <!-- 햄버거 메뉴 토글 버튼 -->
          <button id="menu-toggle" class="menu-toggle" aria-label="Toggle menu">
            <span class="icon-bar"></span>
            <span class="icon-bar"></span>
            <span class="icon-bar"></span>
          </button>
          
          <nav class="nav">
            <a href={homeUrl(lang)} class={active === 'home' ? 'active' : ''}>{tr.nav_home}</a>
            <a href={`${homeUrl(lang)}#lessons`} class={active === 'lessons' ? 'active' : ''}>{tr.nav_lessons}</a>
            <a href={lang === 'en' ? '/en/groove/' : '/groove/'} class={active === 'groove' ? 'active' : ''}>{tr.nav_groove}</a>
            <span class="lang-switch" role="group" aria-label="language">
              <a href={koUrl} class={lang === 'ko' ? 'active' : ''} hreflang="ko">KO</a>
              <a href={enUrl} class={lang === 'en' ? 'active' : ''} hreflang="en">EN</a>
            </span>
            <a class="admin-orb" href="/admin/" title={lang === 'en' ? 'Admin' : '관리자'} aria-label={lang === 'en' ? 'Admin page' : '관리자 페이지'}>
              <span class="uni">🦄</span>
            </a>
          </nav>
        </div>
      </header>
    )}

    <main class={hideHeaderFooter ? 'no-padding' : ''}>
      <slot />
    </main>

    {!hideHeaderFooter && (
      <footer class="site-footer">
        <div class="container footer-sitemap">
          <!-- Column 1: Brand / Concept -->
          <div class="footer-col">
            <h4>drjay-ed</h4>
            <p style="margin-bottom: 12px; font-weight: 500;">
              {lang === 'en' ? "Dissecting the world with a doctor's scalpel, stitching it back with a cartoonist's imagination." : "의사의 메스로 세상을 해부하고, 만화가의 상상력으로 꿰매다."}
            </p>
            <p style="font-size: 0.78rem;">
              Benchmark: TED-Ed Concept
            </p>
          </div>

          <!-- Column 2: Categories -->
          <div class="footer-col">
            <h4>{lang === 'en' ? 'Categories' : '주제 분류'}</h4>
            <ul>
              {categories.map((c) => (
                <li>
                  <a href={categoryUrl(c.code, lang)}>{catName(c, lang)}</a>
                </li>
              ))}
            </ul>
          </div>

          <!-- Column 3: Links & Utilities -->
          <div class="footer-col">
            <h4>{lang === 'en' ? 'Resources' : '바로가기'}</h4>
            <ul>
              <li><a href={homeUrl(lang)}>{tr.nav_home}</a></li>
              <li><a href={`${homeUrl(lang)}#lessons`}>{tr.nav_lessons}</a></li>
              <li><a href={lang === 'en' ? '/en/groove/' : '/groove/'}>{tr.nav_groove}</a></li>
              <li>
                <span style="display: inline-block; margin-top: 4px;">
                  <span class="lang-switch" role="group" aria-label="language">
                    <a href={koUrl} class={lang === 'ko' ? 'active' : ''} hreflang="ko">KO</a>
                    <a href={enUrl} class={lang === 'en' ? 'active' : ''} hreflang="en">EN</a>
                  </span>
                </span>
              </li>
            </ul>
          </div>
        </div>

        <div class="container footer-bottom">
          <div class="copy">
            © {new Date().getFullYear()} drjay-ed · {handle}
          </div>
          <div class="meta-links">
            <a href={`https://youtube.com/${handle}`} target="_blank" rel="noopener noreferrer">YouTube Channel</a>
          </div>
        </div>
      </footer>
    )}

    <!-- 햄버거 메뉴를 제어하는 공통 클라이언트 스크립트 및 스타일 추가 -->
    <script>
      const menuToggle = document.getElementById('menu-toggle');
      const nav = document.querySelector('.nav');
      if (menuToggle && nav) {
        menuToggle.addEventListener('click', () => {
          nav.classList.toggle('open');
          menuToggle.classList.toggle('open');
        });
      }
    </script>

    <style is:global>
      /* 햄버거 토글 버튼 스타일 (기본 숨김) */
      .menu-toggle {
        display: none;
        flex-direction: column;
        justify-content: space-between;
        width: 24px;
        height: 18px;
        background: transparent;
        border: none;
        cursor: pointer;
        padding: 0;
        z-index: 100;
        margin-left: auto;
      }

      .menu-toggle .icon-bar {
        width: 100%;
        height: 2px;
        background-color: var(--text-0);
        border-radius: 1px;
        transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
      }

      /* 모바일 전용 GNB 오버레이 (720px 이하) */
      @media (max-width: 720px) {
        .menu-toggle {
          display: flex;
        }
        
        .nav {
          display: none;
          flex-direction: column;
          position: absolute;
          top: 100%;
          left: 0;
          right: 0;
          background: rgba(255, 255, 255, 0.95);
          backdrop-filter: blur(20px) saturate(180%);
          -webkit-backdrop-filter: blur(20px) saturate(180%);
          border-bottom: 1.5px solid rgba(0, 0, 0, 0.06);
          padding: 20px;
          gap: 12px;
          align-items: stretch;
          box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
        }
        
        .nav.open {
          display: flex;
          animation: slideDownMenu 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }
        
        .nav > a {
          width: 100%;
          text-align: center;
          padding: 10px;
          border-radius: 8px;
          font-size: 1rem;
          background: transparent;
        }
        
        .nav > a::after {
          display: none;
        }
        
        .lang-switch {
          justify-content: center;
          margin: 4px auto;
        }
        
        .admin-orb {
          margin: 4px auto 0 auto;
        }

        .menu-toggle.open .icon-bar:nth-child(1) {
          transform: translateY(8px) rotate(45deg);
        }
        
        .menu-toggle.open .icon-bar:nth-child(2) {
          opacity: 0;
        }
        
        .menu-toggle.open .icon-bar:nth-child(3) {
          transform: translateY(-8px) rotate(-45deg);
        }
      }

      @keyframes slideDownMenu {
        from { opacity: 0; transform: translateY(-10px); }
        to { opacity: 1; transform: translateY(0); }
      }

      main.no-padding {
        padding-top: 0 !important;
        margin: 0 !important;
      }
    </style>
  </body>
</html>
