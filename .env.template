# ElevenLabs API Configuration
# Get your API key from ElevenLabs profile settings: https://elevenlabs.io/app/settings/api-keys
ELEVEN_API_KEY=

# Default Voice IDs (Multi-lingual supported)
# Smart Young Male (e.g. Brian)
ELEVEN_VOICE_MALE=oq1t7YrJg871G2HokpW9

# Calm Intelligent Female (e.g. Rachel)
ELEVEN_VOICE_FEMALE=21m00Tcm4TlvDq8ikWAM

# Custom Voice ID (for your cloned voice in the future)
ELEVEN_VOICE_CUSTOM=

# Active Voice mode: 'male', 'female', or 'custom'
ELEVEN_ACTIVE_VOICE=female

# TTS Model to use (eleven_multilingual_v2 is stable for Korean/English mix)
ELEVEN_MODEL=eleven_multilingual_v2
